→              }\n   112→            </script>\n   113→            <div class=\"col-5 \">\n   114→              <div class=\"p-0 input-group mb-3 mn-r-10\">\n   115→                <div class=\"input-group-prepend\">\n   116→                  <span class=\"input-group-text\">\n   117→                    @Html.Label(\"Substation\", new { @class = \"m-0 fs-14\" })\n   118→                  </span>\n   119→                </div>\n   120→                @Html.DropDownList(\"Substation\", (IEnumerable<SelectListItem>)sublist, new { @class = \"form-control\", id = \"ddlsubstation\" })\n   121→              </div>\n   122→            </div>\n   123→\n   124→            <div class=\"col-5 \">\n   125→              <div class=\"p-0 input-group mb-3 mn-r-10\">\n   126→                <div class=\"input-group-prepend\">\n   127→                  <span class=\"input-group-text\">\n   128→                    @Html.Label(\"Position\", new { @class = \"m-0 fs-14\" })\n   129→                  </span>\n   130→                </div>\n   131→                @{\n   132→                  List<SelectListItem> listItems = new List<SelectListItem>();\n   133→                  listItems.Add(new SelectListItem\n   134→                  {\n   135→                    Text = \"1\",\n   136→                    Value = \"1\"\n   137→                  });\n   138→                  listItems.Add(new SelectListItem\n   139→                  {\n   140→                    Text = \"2\",\n   141→                    Value = \"2\",\n   142→                    Selected = true\n   143→                  });\n   144→                  listItems.Add(new SelectListItem\n   145→                  {\n   146→                    Text = \"3\",\n   147→                    Value = \"3\"\n   148→                  });\n   149→                }\n   150→                @Html.DropDownList(\"Substation\", (IEnumerable<SelectListItem>)listItems, new { @class = \"form-control\", id = \"ddlposition\" })\n   151→              </div>\n   152→            </div>\n   153→\n   154→            <div class=\"col-2 \">\n   155→              <div class=\"p-0 input-group mb-3 mn-r-10\">\n   156→                <input id=\"btnUpdateSubstation\" type=\"button\" value=\"Add\" class=\"md-btn md-btn-primary md-btn-small\" />\n   157→              </div>\n   158→            </div>\n   159→          </div>\n   160→\n   161→          <script type=\"text/javascript\" nonce=\"@Html.ScriptNonce()\">\n   162→            $('#btnUpdateSubstation').click(function (e) {\n   163→              e.preventDefault(); // <------------------ stop default behaviour of button\n   164→              // Load new data\n   165→              var v_stationid = $(\"#ddlsubstation\").val();\n   166→              var v_cell = $(\"#txtstationid\").val();\n   167→              var v_pos = $(\"#ddlposition\").val();\n   168→\n   169→              var req = { stationid: v_stationid, cellid: v_cell, v_pos: v_pos };\n   170→\n   171→              ajaxfncStation(req, v_stationid);\n   172→            });\n   173→\n   174→            function updatesubstations() {\n   175→              var grid = new MvcGrid(document.querySelector('#mvcSubstations'));\n   176→              grid.requestType = 'post';\n   177→              grid.reload();\n   178→            };\n   179→\n   180→            function ajaxfncStation(column, v_stage) {\n   181→              $.ajax({\n   182→                type: \"POST\",\n   183→                url: \"/Manage/Cells/AddSubStation\",\n   184→                async: false,\n   185→                contentType: \"application/json; charset=utf-8\",\n   186→                data: JSON.stringify(column),\n   187→                success: function () {\n   188→\n   189→                  $(\"#ddlsubstation option[value='\" + v_stage + \"']\").remove();\n   190→\n   191→                  // Reload Grid\n   192→                  updatesubstations();\n   193→                }\n   194→              })\n   195→            };\n   196→\n   197→            $(document).on('click', '#mvcSubstations>table>tbody>tr>td>a.delSubStation', function (e) {\n   198→              e.preventDefault(); // <------------------ stop default behaviour of button\n   199→              var target = $(this).attr(\"href\");\n   200→\n   201→              $.ajax({\n   202→                type: \"POST\",\n   203→                url: target,\n   204→                async: false,\n   205→                contentType: \"application/json; charset=utf-8\",\n   206→                success: function () {\n   207→                  // Reload Grid\n   208→                  updatesubstations();\n   209→                }\n   210→              })\n   211→            });\n   212→\n   213→          </script>\n   214→        </li>\n   215→      </ul>\n   216→\n   217→      <div class=\"tab-pane\">\n   218→        <div class=\"form-group\">\n   219→          <div class=\"form-group mt-4 pt-4 border-top\">\n   220→            <button type=\"submit\" name=\"action:@(isNew ? \"Create\": \"Edit\")\" class=\"md-btn md-btn-primary md-btn-small\">\n   221→              Save\n   222→            </button>\n   223→\n   224→            @if (!isNew)\n   225→            {\n   226→              <button type=\"submit\" name=\"action:Delete\" class=\"md-btn md-btn-danger md-btn-small\">\n   227→                Delete\n   228→              </button>\n   229→            }\n   230→\n   231→            <div class=\"d-inline-block\">\n   232→              <span class=\"mx-2 text-light font-weight-light fs-15\">or</span>\n   233→              <i class=\"fas fa-long-arrow-alt-left fs-13 text-primary o-8\"></i>\n   234→              <a href=\"@Url.Action(\"Index\", \"Cells\")\" class=\"m-link fs-15\"> Back to list</a>\n   235→            </div>\n   236→          </div>\n   237→        </div>\n   238→      </div>\n   239→    </div>\n   240→\n   241→\n   242→  </div>\n   243→\n   244→\n   245→}\n   246→\n\n<system-reminder>\nWhenever you read a file, you should cons