            <script type="text/javascript" nonce="@Html.ScriptNonce()">
              $('#btnlabelval').click(function (e) {
                e.preventDefault(); // <------------------ stop default behaviour of button
                // Load new data
                var v_stage = $("#ddllabelvaltype").val();
                var v_partid = $("#txtPartID").val();
                var v_Format = $("#txtlabelvalFormat").val();
                var v_Quantity = $("#txtlabelvalSortno").val();
                var v_Description = $("#ddllabelvaltype option:selected").text();

                var req = { ValidationType: v_stage, PartID: v_partid, SortNo: v_Quantity, FortmatEasy: v_Format, Description: v_Description };

                $.ajax({
                  type: "POST",
                  url: "/Quality/PartNumber/AddLabelValidation",
                  async: false,
                  contentType: "application/json; charset=utf-8",
                  data: JSON.stringify(req),
                  success: function () {

                    $("#txtlabelvalFormat").val('');
                    $("#txtlabelvalSortno").val('');

                    // Reload Grid
                    updateLabelValidation();
                  }
                })
              });

              function updateLabelValidation() {
                var grid = new MvcGrid(document.querySelector('#mvcLabelValidation'));
                grid.requestType = 'post';
                grid.reload();
              };


              $(document).on('click', '#mvcLabelValidation>table>tbody>tr>td>a.DeleteLabelValidation', function (e) {
                e.preventDefault(); // <------------------ stop default behaviour of button
                var target = $(this).attr("href");

                $.ajax({
                  type: "POST",
                  url: target,
                  async: false,
                  contentType: "application/json; charset=utf-8",
                  success: function () {
                    // Reload Grid
                    updateLabelValidation();
                  }
                })
              });

            </script>
          </div>
        </div>
