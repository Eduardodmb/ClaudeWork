      @*----------------------------------------------------------AREA LOCKS-----------------------------------------------------------------*@
      <li aria-hidden="true">
        <div class="uk-grid">
          <div class="uk-width-1-1">
            @{

              SqlParameter[] parametersdif = new SqlParameter[]
              {
                 new SqlParameter("@Partid",SqlDbType.Int){Value =Model.PartID }
};
              DataTable dif = Firstronic.Framework.Queries.GetDatatableFromQuery(@"
                                                          SELECT
                                                            isnull(Part_Operation_Review_Operation.AutoID,0) as AutoID ,
                                                            Part_Operation_Review_Operation.PartID, Part_Operation_Review_Operation.CurrentAreaID,
                                                            Part_Operation_Review_Operation.PreviousAreaID,Part_Operation_Review_Operation.Facility_Key,
                                                            Part_Operation_Review_Operation.Previous_Date, isnull(Part_Operation_Review_Operation_Validate.AutoID, 0) AS Validate
                                                          FROM Part_Operation_Review_Operation
                                                          FULL JOIN
                                                            Part_Operation_Review_Operation_Validate ON Part_Operation_Review_Operation.PartID = Part_Operation_Review_Operation_Validate.PartID AND
                                                            Part_Operation_Review_Operation.CurrentAreaID = Part_Operation_Review_Operation_Validate.CurrentAreaID AND
                                                            Part_Operation_Review_Operation.PreviousAreaID = Part_Operation_Review_Operation_Validate.PreviousAreaID
                                                          WHERE (Part_Operation_Review_Operation.partid = @Partid and Part_Operation_Review_Operation.CurrentAreaID = '14')
                                                            or (Part_Operation_Review_Operation_Validate.partid = @Partid and Part_Operation_Review_Operation_Validate.CurrentAreaID = '14')", parametersdif);

              bool pasa = false;

              foreach (DataRow row in dif.Rows)
              {
                pasa = true;
                if (int.Parse(row["AutoID"].ToString()) == 0 || int.Parse(row["Validate"].ToString()) == 0)
                {
                  pasa = false;
                  break;
                }
              }

            }
            @if (pasa)
            {
              <p class="request-info text-center bg-c-green" style="background-color:greenyellow">APPROVED.</p>
            }
            else
            {
              //Check last
              SqlParameter[] parametersdifbypass = new SqlParameter[]
              {
                 new SqlParameter("@partid",SqlDbType.Int){Value =Model.PartID}
};
              DataTable difbypass = Firstronic.Framework.Queries.GetDatatableFromQuery(@"select trndate from Part_Operation_Review_Operation_ByPass where trndate>DATEADD(hh,-4,GETDATE()) and partid = @partid and CurrentAreaID = '14' order by trndate desc", parametersdifbypass);

              if (difbypass.Rows.Count > 0)
              {
                if (difbypass.Rows[0][0].ToString() == "")
                {
                  <p class="request-info text-center bg-c-red" style="background-color:firebrick">NOT APPROVED.</p>
                }
                else
                {
                  <p class="request-info text-center bg-c-yellow" style="background-color:firebrick">NOT APPROVED. By pass @difbypass.Rows[0][0].ToString() </p>
                }
              }
              else
              {
                SqlParameter[] parametersalloempty = new SqlParameter[]
               {
                                        new SqlParameter("@partid",SqlDbType.Int){Value =Model.PartID}
};
                DataTable alloempty = Firstronic.Framework.Queries.GetDatatableFromQuery(@"SELECT [ControlID] FROM [Part_Operation_Packout_No_Filters] WHERE partid=@partid", parametersalloempty);

                if (alloempty.Rows.Count > 0)
                {
                  <p class="request-info text-center bg-c-green" style="background-color:greenyellow">APPROVED WITHOUT FILTERS.</p>
                }
                else
                {
                  SqlParameter[] parametersdtallowed = new SqlParameter[]
                   {
                                              new SqlParameter("@PartID",SqlDbType.Int){Value =Model.PartID}
};
                  DataTable dtallowed = Firstronic.Framework.Queries.GetDatatableFromQuery(@"SELECT [PartID],[TrnDate],[ControlID] FROM [Part_Operation_Packout_No_Filters_Engineering] WHERE PartID=@PartID", parametersdtallowed);

                  if (dtallowed.Rows.Count > 0)
                  {
                    <p class="request-info text-center bg-c-red" style="background-color:firebrick">ENGINEERING ALLOW WITHOUT FILTERS, PLEASE APROVE IF IS NECESSARY.</p>
                  }
                  else
                  {
                    <p class="request-info text-center bg-c-red" style="background-color:firebrick">NOT APPROVED.</p>
                  }
                }
              }
            }

            @Html.AjaxGrid(Url.Action("LocksList", "PartNumber", new { Area = "Quality", id = Model.PartID }))

          <div class="row mn-t-25">
            <div class="col-12">
              <p class="request-info">Please set the a validation time limit. Por favor selecciona el limite de la approbacion (hasta cuando es valida). </p>
