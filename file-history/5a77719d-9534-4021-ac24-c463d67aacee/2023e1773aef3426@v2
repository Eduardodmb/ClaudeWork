                  error: function () {

                  }
                });
              }

            var req = { PartID: v_partid, Side: v_ParametersSide, AreaID: v_areaid, ProcessID: v_substation, Url: nurl, Comments: v_comments, DocType: v_DocType };

              $.ajax({
                type: "POST",
                url: "/Quality/PartNumber/AddAssemblyInstructions",
