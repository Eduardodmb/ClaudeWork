    public ActionResult EditQuestion(int id, int questionid = 0)
    {

      var model = new tbl_Quality_5S_FULL_partial_Question();
      SqlParameter[] parameters = new SqlParameter[]{
                            new SqlParameter("@Poll_ID",SqlDbType.Int){Value =id},
                        };
      model.Poll = db.Database.SqlQuery<tbl_Quality_5S_FULL>($@"SELECT [Poll_ID]
                          ,[User_ID]
                          ,[TrnDate]
                          ,[CloseDate]
                          ,[Comments]
                          ,[Person],[AreaID]
                      FROM [Quality_5S] WHERE Poll_ID=@Poll_ID and CloseDate is null", parameters).FirstOrDefault();

      if (questionid == 0)
      {
        questionid = 1;
      }

      model.Questions = Firstronic.Framework.Functions.Queries.GetIntFromQuery("SELECT Count(*) FROM [Quality_5S_Questions]  where question_area_id = "+model.Poll.AreaID);

     // model.Questions = Firstronic.Framework.Functions.Queries.GetIntFromQuery("SELECT Count(*) FROM [Quality_5S_Questions] ");

      if (questionid > model.Questions)
      {
      
        Firstronic.Framework.Functions.Queries.ExecuteSimpleQuery("UPDATE Quality_5S SET CloseDate=GETDATE() WHERE Poll_ID= " + id+"");

        return RedirectToAction("EndQuestions");
      }
      SqlParameter[] parametersdt_question = new SqlParameter[]{
                                   new SqlParameter("@Question_No",SqlDbType.Int){Value =questionid},
                              };
      DataTable dt_question = Firstronic.Framework.Queries.GetDatatableFromQuery("SELECT [Question_ID],[Question_Name],[Question_Type_ID] FROM [Quality_5S_Questions] where [Question_No]=" + questionid + " and question_area_id = "+model.Poll.AreaID + " order by question_no asc", parametersdt_question);

     // DataTable dt_question = Firstronic.Framework.Queries.GetDatatableFromQuery("SELECT [Question_ID],[Question_Name],[Question_Type_ID] FROM [Quality_5S_Questions] where [Question_No]=" + questionid + "", parametersdt_question);

      if (dt_question == null|| dt_question.Rows.Count==0)
      {
        this.NotifyError("5S questions does not exist.");
        return RedirectToAction("List");
      }


      if (dt_question.Rows.Count > 0)
      {
        model.QuestionNo = questionid;
        model.QuestionID = int.Parse(dt_question.Rows[0][0].ToString());
        model.Question = dt_question.Rows[0][1].ToString();
        model.QuestionType = int.Parse(dt_question.Rows[0][2].ToString());

        return View(model);
      }
      else
      {
        return RedirectToAction("List");
      }
    }

