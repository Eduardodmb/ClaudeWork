    public ActionResult UpdateComments(int id)
    {
      SqlParameter[] parameters = new SqlParameter[]{
                                                         new SqlParameter("@Poll_ID",SqlDbType.Int){Value =id},
                                                    };

      var model = db.Database.SqlQuery<tbl_Quality_5SUpdateComments>($@"SELECT 
    QANS.Poll_ID, 
    Qua.Person, 
    Qua.AreaID,
 CASE
        WHEN A.TYPEID = 1 THEN P.Area  
        ELSE C.CellName               
    END AS Area_Name,
    QANS.Question_ID, 
    Q.Question_Name,
    QANS.Answer_Text,
  QANS.ExtraComments,
    QANS.Answer_Value,
    QANS.TrnDate
   
FROM 
    [PROD_MES].[dbo].[QUALITY_5S_ANSWERS] QANS
JOIN 
    [PROD_MES].[dbo].[QUALITY_5S] Qua ON Qua.Poll_ID = QANS.Poll_ID
JOIN 
    [PROD_MES].[dbo].[QUALITY_5S_QUESTIONS] Q ON Q.Question_Area_ID = Qua.AreaID
    AND Q.Question_No = QANS.Question_ID
LEFT JOIN 
    [QUALITY_5S_AREAS] A ON A.ID = Q.Question_Area_ID 
LEFT JOIN 
    [PD_idt_areas] P ON Qua.AreaID = P.AreaID  
LEFT JOIN 
    [PD_idt_cells] C ON Qua.AreaID = C.CellID WHERE  QANS.Poll_ID =@Poll_ID",parameters).ToArray().ToList().AsQueryable();

      return View(model);
    }

    [HttpPost]
    public ActionResult UpdateComm(int Poll_ID,  int Question_ID, string Answer_Text)
    {
      
      if (Poll_ID > 0 && !string.IsNullOrEmpty(Answer_Text))
      {

        SqlParameter[] parameters = new SqlParameter[]{
                                                         new SqlParameter("@Poll_ID",SqlDbType.Int){Value =Poll_ID},
                                                    };

        var answer = db.Database.SqlQuery<tbl_Quality_5SUpdateComments>($@"SELECT 
    QANS.Poll_ID
FROM 
    [PROD_MES].[dbo].[QUALITY_5S_ANSWERS] QANS
 WHERE  QANS.Poll_ID =@Poll_ID", parameters).FirstOrDefault();
        

        if (answer != null)
        {
          // Actualizar el comentario

          SqlParameter[] parametersUpdate = new SqlParameter[]
          {
            new SqlParameter("@Poll_ID", SqlDbType.Int) { Value = Poll_ID },
            new SqlParameter("@Comments", SqlDbType.NVarChar) { Value = Answer_Text },
            
            new SqlParameter("@Question_ID", SqlDbType.NVarChar) { Value = Question_ID }
          };


          var result = db.ExecuteCommand(@"
            UPDATE QUALITY_5S_ANSWERS
            SET ExtraComments = @Comments
            WHERE Poll_ID = @Poll_ID
            AND  Question_ID = @Question_ID", parametersUpdate);

          if (result > 0)
          {
            this.NotifySuccess("Successfully updated.");
          }
          else if (result == 0)
          {
            this.NotifyError("Record not updated!");
          }
          else
          {
            this.NotifyError("Error in database.");
          }
          // Redirigir a la página de detalles de la encuesta (o donde sea necesario)
          return RedirectToAction("UpdateComments", new { id = Poll_ID });
         // return RedirectToAction("UpdateComments");
        }
        else
        {
          // Si no se encuentra la encuesta, agregar un error
          ModelState.AddModelError("", "No se encontró la encuesta con el ID proporcionado.");
        }
      }

      // Si algo sale mal, devolver a la vista con el error
      return View();

   
  



    }


