                DataTable dt_new = new DataTable();

                dt_new.Columns.Add("PartNo", typeof(string));

                foreach (DataRow item in ds_BOm.Dt.Rows)
                {
                  SqlParameter[] dtLoadeddParameters = new SqlParameter[]{
                    new SqlParameter("@StationID",SqlDbType.Int) {Value = Convert.ToInt32(dtCurrent.Rows[0]["Workcenter_Key"].ToString())},
                    new SqlParameter("@Row0",SqlDbType.VarChar) {Value = item[0].ToString()},
                  };

                  DataTable dt_loadedd = Firstronic.Framework.Queries.GetDatatableFromQuery("SELECT   [PART].Part_No,CONCAT([MachineID],'-',[TableID],'-',[PositionID]) as Position FROM            Part_Station_Material_Load INNER JOIN [PART] ON Part_Station_Material_Load.Part_Key = [PART].Part_Key where Part_Station_Material_Load.Workcenter_Key = @StationID and Part_No = @Row0", dtLoadeddParameters);

                  if (dt_loadedd.Rows.Count > 0)
                  {
                    item[1] = "OK";
                    item[2] = dt_loadedd.Rows[0][1].ToString();
                  }
                  else
                  {
                    dt_new.Rows.Add(item[0].ToString());
                    distinct = true;
                  }

                  ds_BOm.Dt.AcceptChanges();
                }

                <div class="uk-grid">
