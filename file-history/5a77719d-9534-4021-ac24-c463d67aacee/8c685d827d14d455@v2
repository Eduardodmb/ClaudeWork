                    <div class="mvc-grid mn-t-15 fs-11">
                      <table border="1">
                        <thead>
                          <tr>
                            @foreach (System.Data.DataColumn col in ds_BOm.Dt.Columns)
                            {
                              <th>@col.Caption</th>
                            }
                          </tr>
                        </thead>
                        <tbody>
                          @foreach (System.Data.DataRow rowstation in ds_BOm.Dt.Rows)
                          {
                            <tr>
                              @foreach (var cell in rowstation.ItemArray)
                              {
                                if (rowstation[1].ToString() == "")
                                {
                                  <td class="" style="color:red">@cell.ToString()</td>
                                }
                                else
                                {
                                  <td class="">@cell.ToString()</td>
                                }
                              }
                            </tr>
                          }
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              }
            }
