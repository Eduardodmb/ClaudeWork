                                var Bonus_Cell_Name = aData2[1];
                                var FirstName = aData2[2];
                                var LastName = aData2[3];
                                var Position = aData2[7];

                                for (i2 = 0; i2 < Gafete.length; i2++) {
                                  if (Position[i2] == 1) {
                                    usersstrn += "-" + Gafete[i2] + " " + FirstName[i2] + " " + LastName[i2] + "<br/>";
                                  } else if (Position[i2] == 2) {
