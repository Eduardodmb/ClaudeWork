                    var aAlias = aData[15];
                    var Workcenter_PLC_Name_1 = aData[16];
                    var Workcenter_PLC_Name_2 = aData[17];
                    var Workcenter_PLC_Name_Kanban_1 = aData[18];
                    var Workcenter_PLC_Name_Kanban_2 = aData[19];
