                        newElement.setAttribute('aColID', aColID[i]);
                        newElement.setAttribute('aRowID', aRowID[i]);
                        newElement.setAttribute('aAlias', aAlias[i]);


                        var usersstrn = "";
                        var qausersstrn = "";
                        var techusersstrn = "";
                        var leadusersstrn = "";


                      if (BonusStationID[i] == "-1") {
                        newElement.setAttribute('fill', '#cbcbcb');
                      } else if (peop[i] == "-1") {
                        newElement.setAttribute('fill', '#ffc300');
                      } else {
                        newElement.setAttribute('fill', '#13c707');

                        try {
                          var req3 = { station: aStationID[i], category_ID: selectedItems };
                          $.ajax({
                            type: "POST",
                            url: "/Dashboards/FloorShop/BonusCellChartStation_People",
                            contentType: "application/json; charset=utf-8",
