@using System.Data
@section head{
  <style>
    #mypopup {
      width: 250px;
      padding: 6px;
      font-family: Arial, sans-serif;
      font-size: 10pt !important;
      background-color: #000000;
      color: #fff;
      border-radius: 6px;
      position: absolute;
      display: none;
      min-height: 40px;
      border: 1px solid #000000;
    }

      #mypopup p {
        padding: 0px;
        margin-bottom: 0px;
      }

      #mypopup::before {
        content: "";
        width: 12px;
        height: 12px;
        transform: rotate(45deg);
        background-color: #000000;
        position: absolute;
        right: -6px;
        top: 20px;
        border-left: 1px solid #000000;
        border-bottom: 1px solid #000000;
      }

    #mypopup_ticket {
      width: 150px;
      padding: 6px;
      text-align: center;
      font-family: Arial, sans-serif;
      font-size: 10pt !important;
      background-color: #000000;
      color: #fff;
      border-radius: 6px;
      position: absolute;
      display: none;
      min-height: 40px;
      border: 1px solid #000000;
    }

      #mypopup_ticket p {
        padding: 0px;
        margin-bottom: 0px;
      }

      #mypopup_ticket::before {
        content: "";
        width: 12px;
        height: 12px;
        transform: rotate(45deg);
        background-color: #000000;
        position: absolute;
        right: 69px;
        top: 33px;
        border-right: 1px solid #000000;
        border-bottom: 1px solid #000000;
      }
  </style>
}


