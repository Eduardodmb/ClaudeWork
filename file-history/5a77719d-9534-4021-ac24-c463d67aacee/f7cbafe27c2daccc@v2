            path_small.setAttributeNS(null, "fill", "none");
            path_small.setAttributeNS(null, "stroke", "gray");
            path_small.setAttributeNS(null, "stroke-width", "0.5");

            pattern_small.appendChild(path_small);

            defs.appendChild(pattern_small);


            var pattern_medium = document.createElementNS("http://www.w3.org/2000/svg", "pattern");
            pattern_medium.id = "grid";
            pattern_medium.setAttributeNS(null, "width", "32");
            pattern_medium.setAttributeNS(null, "height", "32");
            pattern_medium.setAttributeNS(null, "patternUnits", "userSpaceOnUse");

            var rect_medium = document.createElementNS("http://www.w3.org/2000/svg", "rect");
