            pattern_small.id = "smallGrid";
            pattern_small.setAttributeNS(null, "width", "8");
            pattern_small.setAttributeNS(null, "height", "8");
            pattern_small.setAttributeNS(null, "patternUnits", "userSpaceOnUse");

            var path_small = document.createElementNS("http://www.w3.org/2000/svg", "path");
