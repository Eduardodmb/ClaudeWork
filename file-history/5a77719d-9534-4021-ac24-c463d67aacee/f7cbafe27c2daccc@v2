                  }
                  else
                  {
                    @Html.CheckBox(@row["Area"].ToString(), new { @id = "ch_" + @row["AreaID"].ToString(), @value = @row["AreaID"].ToString(), @class = "hide fst_checkbox", @checked = "Checked" })
