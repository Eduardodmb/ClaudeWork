            function secondsToTime(sec) {
                if (sec < 0) sec = 0;
                return [(sec / 3600), ((sec % 3600) / 60), ((sec % 3600) % 60)]
                    .map(v => v < 10 ? "0" + parseInt(v) : parseInt(v))
                    .join(":");
            }

