            path_medium.setAttributeNS(null, "fill", "none");
            path_medium.setAttributeNS(null, "stroke", "gray");
            path_medium.setAttributeNS(null, "stroke-width", "1");

            pattern_medium.appendChild(rect_medium);
            pattern_medium.appendChild(path_medium);

            defs.appendChild(pattern_medium);

