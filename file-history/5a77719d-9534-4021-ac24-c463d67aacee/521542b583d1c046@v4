    [Obsolete("Use GetAreasList with typed parameters to prevent SQL injection")]
    public static List<SelectListItem> GetAreasList(int? SelectedItem, string Filter = "",bool IncludeAll = false)
    {

      var options = new List<SelectListItem>();

      if (SelectedItem == null)
      {
        SelectedItem = -1;
      }

      if (IncludeAll)
      {
        var o = new SelectListItem
        {
          Value = "0",
          Text = "ALL",
          Selected = false
        };
        options.Add(o);
      }

      using (DataContext db = new DataContext())
      {
        IList<tbl_PD_idt_areas> publisherList = new List<tbl_PD_idt_areas>();

        // Add IsVisible filter intelligently
        string finalFilter = "";
        if (string.IsNullOrWhiteSpace(Filter))
        {
          // No existing filter - add WHERE clause
          finalFilter = "WHERE IsVisible = 1 ";
        }
        else if (Filter.ToUpper().Contains("WHERE"))
        {
          // Existing filter with WHERE - add AND condition
          finalFilter = Filter.TrimEnd() + " AND IsVisible = 1 ";
        }
        else
        {
          // Existing filter without WHERE - add WHERE clause before it
          finalFilter = "WHERE IsVisible = 1 AND " + Filter;
        }

        var query = db.Database.SqlQuery<tbl_PD_idt_areas>($@"SELECT AREAID, AREA  " +
        "FROM PD_idt_areas " + finalFilter + "ORDER by Area ASC").ToArray();

        var rows = query.ToList();

        foreach (var rowData in rows)
        {

          var o = new SelectListItem
          {
            Value = rowData.AreaID.ToString(),
            Text = rowData.Area.ToString(),
            Selected = rowData.AreaID == SelectedItem ? true : false
          };
          options.Add(o);
        }
      }
      return options;
    }

    //===============================================================
    // AREAS - SelectListItem Version (for dropdowns) - SAFE VERSION
    // Uses typed parameters to prevent SQL injection
    //===============================================================
    public static List<SelectListItem> GetAreasList(
      int? selectedItem = null,
      bool includeAll = false,
      int[] areaTypeIds = null,
      bool? activeReport = null,
      bool? plexOperation = null,
      bool? activeInventory = null,
      int? facilityKey = null,
      int[] includeAreaIds = null,
      int[] excludeAreaIds = null,
      string customSubquery = null)
    {
      var options = new List<SelectListItem>();

      if (includeAll)
      {
        options.Add(new SelectListItem
        {
          Value = "0",
          Text = "ALL",
          Selected = false
        });
      }

      // Get filtered areas using the safe DataTable function
      DataTable dt = GetAreasDataTable(
        areaTypeIds: areaTypeIds,
        activeReport: activeReport,
        plexOperation: plexOperation,
        activeInventory: activeInventory,
        facilityKey: facilityKey,
        includeAreaIds: includeAreaIds,
        excludeAreaIds: excludeAreaIds,
        customSubquery: customSubquery);

      foreach (DataRow row in dt.Rows)
      {
        var areaId = Convert.ToInt32(row["AreaID"]);
        options.Add(new SelectListItem
        {
          Value = areaId.ToString(),
          Text = row["Area"].ToString(),
          Selected = areaId == (selectedItem ?? -1)
        });
      }

      return options;
    }

