  <div class="md-card-content fw-600 fs-14">
    <div class="uk-clearfix">
      <div class="uk-float-left">
        DownTime @AreaName
        @Html.HiddenFor(y => y.areaid, new { id = "txtStationID" })
      </div>
      <div class="uk-float-right">
        <div class="uk-grid" uk-grid>
          <div class="uk-width-1-1 text-right fs-12">
            <a href="~/Dashboards/Downtime/Area/@prevareaid" class="pd-r-20">
              <span class="material-icons">arrow_left</span> @prevarea
            </a>
            <a href="#">
              @AreaName
            </a>
            <a href="~/Dashboards/Downtime/Area/@nextareaid" class="pd-l-20">
              @nextarea <span class="material-icons">arrow_right</span>
            </a>
            <a href="~/Dashboards/Downtime/Index" class="text-c-purple pd-l-20">
              <i class="fas fa-industry"></i> Go All
            </a>
            <a href="~/Dashboards/Portal" class="text-c-purple pd-l-20">
              <i class="fas fa-caret-square-up"></i> Go Home
            </a>
          </div>
          <div class="uk-width-1-1 text-right uk-margin-small-top fs-12">
            <a href="@Url.RouteUrl(u_yesterday)"><span class="material-icons">arrow_left</span></a>

            @Html.TextBoxFor(y => y.current, new { @id = "ddlDateUpdate", @Value = Model.current.ToString("MM/dd/yyyy"), style = "width: 80%;text-align: center;font-size: 14px;" })

            <a href="@Url.RouteUrl(u_tomorrow)"><span class="material-icons">arrow_right</span></a>
          </div>
        </div>
      </div>
    </div>
  </div>

</div>


@{
  DataTable dt_areas2 = Firstronic.Framework.Functions.Dropdowns.GetAreasDataTable(
    areaTypeIds: new int[] { 1, 2 },
    activeReport: true,
