@using System.Data
@using NonFactors.Mvc.Grid
@model Firstronic.Core.Entities.App.Engineering.tbl_CS_idt_partnumbers_FULL

@{
  var Modellist = Firstronic.Framework.Functions.Queries.GetSelectedFromQuery(@"SELECT [PartID]   ,[PartNumber] FROM [CS_idt_partnumbers] order by PartNumber asc");
  var Sidelist = Firstronic.Framework.Functions.Queries.GetSelectedFromQuery(@"SELECT [AutoID]   ,[SideName] FROM [PD_idt_sides] order by AutoID asc");

  var Arealist = Firstronic.Framework.Functions.Dropdowns.GetAreasList();
  var processlist = Firstronic.Framework.Functions.Queries.GetSelectedFromQuery("SELECT [AutoID], [ProcessName] FROM [PART_OPERATION_AREAS_PROCESS] order by ProcessName ASC");

}


<div class="md-card">
  <div class="md-card-toolbar">
    <h3 class="md-card-toolbar-heading-text"> Rabbit Edit: @Model.SSN </h3>
  </div>
  <div class="md-card-content">
    <div class="uk-grid pt-3">
      <div class="uk-width-2-3 hide">
        <div class="uk-form-row">
          <div class="uk-input-wrapper">
            @Html.Label("AutoID", new { @class = "m-0 fs-14" })
            @Html.TextBoxFor(y => y.AutoID, new { @class = "form-control", id = "ddlAutoID" })
          </div>
        </div>
      </div>
      <div class="uk-width-2-3">
        <div class="uk-form-row">
          <div class="uk-input-wrapper">
            @Html.Label("SSN Good", new { @class = "m-0 fs-14" })
            @Html.TextBoxFor(y => y.SSN, new { @class = "form-control", id = "ddlSSN" })
          </div>
        </div>
      </div>
      <div class="uk-width-1-3">
        <div class="uk-form-row">
          <div class="uk-input-wrapper">
            @Html.Label("AreaID", new { @class = "m-0 fs-14" })
            @Html.DropDownListFor(y => y.AreaID, (IEnumerable<SelectListItem>)Arealist, new { @class = "form-control", id = "ddlAreaIDR" })
          </div>
        </div>
      </div>
      <div class="uk-width-1-3">
        <div class="uk-form-row">
          <div class="uk-input-wrapper">
            @Html.Label("ProcessID", new { @class = "m-0 fs-14" })
            @Html.DropDownListFor(y => y.ProcessID, (IEnumerable<SelectListItem>)processlist, new { @class = "form-control", id = "ddlProcessIDR" })
          </div>
        </div>
      </div>
      <div class="uk-width-1-3">
        <div class="uk-form-row">
          <div class="uk-input-wrapper">
            @Html.Label("Side", new { @class = "m-0 fs-14" })
            @*@Html.TextBoxFor(y => y.Side, new { @class = "form-control", id = "ddlSides" })*@
            @Html.DropDownListFor(y => y.Side, (IEnumerable<SelectListItem>)Sidelist, new { @class = "form-control", id = "ddlSides" })


          </div>
        </div>
      </div>


      @*<div class="uk-width-2-3">
          <div class="uk-form-row">
            <div class="uk-input-wrapper">
              @Html.Label("Description", new { @class = "m-0 fs-14" })
              @Html.TextBoxFor(y => y.Description, new { @class = "form-control", id = "ddlDescription" })
            </div>
          </div>
        </div>*@

      @{
        var today2 = DateTime.Now;
      }

      <div class="uk-width-1-3">
        <div class="uk-form-row">
          <div class="uk-input-wrapper">
            @Html.Label("Calibration Date (MM/dd/YY)", new { @class = "m-0 fs-14" })
            @Html.Editor("Calibration", "{0:MM/dd/yyyy}", new { htmlAttributes = new { @class = "form-control", id = "ddlCalibration", @Value = today2.ToString("MM/dd/yy") } })
          </div>
          <script type="text/javascript" nonce="@Html.ScriptNonce()">
            $("#ddlLimitDate").datepicker({
              dateFormat: "mm/dd/y",
              changeMonth: true,
              changeYear: true,
              yearRange: "-1:+5"
            });
          </script>
        </div>
      </div>

      <div class="uk-width-1-3">
        <div class="uk-form-row">
          <div class="uk-input-wrapper">
            @Html.Label("Expiration Date (MM/dd/YY)", new { @class = "m-0 fs-14" })
            @Html.Editor("Calibration", "{0:MM/dd/yyyy}", new { htmlAttributes = new { @class = "form-control", id = "ddlExpiration", @Value = today2.AddMonths(+3).ToString("MM/dd/yy") } })
          </div>
          <script type="text/javascript" nonce="@Html.ScriptNonce()">
            $("#ddlLimitDate").datepicker({
              dateFormat: "mm/dd/y",
              changeMonth: true,
              changeYear: true,
              yearRange: "-1:+5"
            });
          </script>
        </div>
      </div>
      <div class="uk-width-2-3">
        <div class="uk-form-row">
          <div class="uk-input-wrapper">
            <input id="btnUpdateRabbits" type="button" value="Add" class="md-btn md-btn-primary md-btn-small" />
          </div>

        </div>
      </div>
      <script type="text/javascript" nonce="@Html.ScriptNonce()">

        $('#btnUPrintRabbits').click(function (e) {
          e.preventDefault(); // <------------------ stop default behaviour of button
          // Load new data
          var zpl = '^XA^FO50,60^A0,40^FDWorlds Best Griddle^FS^FO60,120^BY3^BCN,60,,,,A^FD1234ABC^FS^FO25,25^GB380,200,2^FS^XZ';

          var printWindow = window.open();
          printWindow.document.open('text/plain')
          printWindow.document.write(zpl);
          printWindow.document.close();
          printWindow.focus();
          printWindow.print();
          printWindow.close();

        });

        $('#btnUpdateRabbits').click(function (e) {
          e.preventDefault(); // <------------------ stop default behaviour of button
          // Load new data
          var v_areaid = $("#ddlAreaIDR").val();
          var v_processid = $("#ddlProcessIDR").val();
          var v_partid = $("#ddlAutoID").val();
          var v_SSN = $("#ddlSSN").val();
          var v_Side = $("#ddlSides").val();
          var v_ErrorNo = "";
          var v_Status = "";
          var v_IsActive = "";
          var v_AllPanel = "";
          var v_Description = "";
          var v_SSN2 = "";
          var v_date = $("#ddlCalibration").val();
          var v_datelimit = $("#ddlExpiration").val();

          var req = { AreaID: v_areaid, ProcessID: v_processid, partid: v_partid, SSN: v_SSN, Sides: v_Side, ErrorNo: v_ErrorNo, Status: v_Status, IsActive: v_IsActive, AllPanel: v_AllPanel, Description: v_Description, SSN2: v_SSN2, v_date: v_date, v_datelimit: v_datelimit };

          $.ajax({
            type: "POST",
            url: "/Quality/PartNumber/EditRabbits",
            async: false,
            contentType: "application/json; charset=utf-8",
            data: JSON.stringify(req),
            success: function () {
              // Reload Grid
              updateRabbits();
            }
          })
        });

        function updateRabbits() {
          //var grid = new MvcGrid(document.querySelector('#mvcRabbits'));
          //grid.requestType = 'post';
          //grid.reload();
          var one = '/Quality/PartNumber/Edit/';
          var two = $("#ddlPartID").val();
          var joined = one + two;
          window.location.href = joined;

        };

        $(document).on('click', '#mvcRabbits>table>tbody>tr>td>a.delRow', function (e) {
          e.preventDefault(); // <------------------ stop default behaviour of button
          var target = $(this).attr("href");

          $.ajax({
            type: "POST",
            url: target,
            async: false,
            contentType: "application/json; charset=utf-8",
            success: function () {
              // Reload Grid
              updateRabbits();
            }
          })
        });


        $(document).on('click', '#mvcRabbits>table>tbody>tr>td>a.delVal', function (e) {
          e.preventDefault(); // <------------------ stop default behaviour of button
          var target = $(this).attr("href");

          $.ajax({
            type: "POST",
            url: target,
            async: false,
            contentType: "application/json; charset=utf-8",
            success: function () {
              // Reload Grid
              updateRabbits();
            }
          })
        });

      </script>


    </div>
  </div>

  @Html.TextBoxFor(y => y.PartID, new { @class = "form-control hide", id = "ddlPartID", style = "display: none;" })
