## Template 3: Batch Insert (Loop Optimization)

### Find This Pattern:
```vb
For Each row As DataRow In dtBoardBarcodes.Rows
    ' ... build parameters ...
    Dim sql_insert As String = "INSERT INTO Machines_Extractor_AOI_Data ..."
    BeConnM.InsertRecords(sql_insert, InsertParameter)
Next
```

### Replace With:
```vb
' Step 1: Build list of all requests
Dim aoiInspectionRequests As New List(Of AOIInspectionRequest)

For Each row As DataRow In dtBoardBarcodes.Rows
    Dim rowPosition As Integer = row.Item("Position")
    Dim rowResult As String = row.Item("Result")
    Dim rowSSN As String = row.Item("Barcode")

    ' Add to batch list
    Dim request As New AOIInspectionRequest With {
        .Sn = rowSSN,
        .Aoiid = AOIID,
        .StationId = StationID,
        .PartId = partid,
        .Side = sideid,
        .Trndate = Fecha,
        .IsGood = (rowResult = "PASS"),
        .IsRework = False,
        .Position = rowPosition,
        .RefCir = "",
        .DefectDesc = "",
        .UserPass = Nothing,
        .FacilityKey = Nothing,
        .AreaId = AreaID
    }
    aoiInspectionRequests.Add(request)
Next

' Step 2: Submit all at once (MUCH faster!)
If aoiInspectionRequests.Count > 0 Then
    Try
        Dim batchResponse As AOIBatchResponse = AOI.SubmitInspectionBatch(aoiInspectionRequests)
        WriteToFile($"API Batch: Submitted {batchResponse.SuccessfulRecords}/{batchResponse.TotalRecords} records")

        If batchResponse.FailedRecords > 0 Then
            For Each errorMsg In batchResponse.Errors
                WriteToFile($"Batch Error: {errorMsg}")
            Next
        End If
    Catch ex As Exception
        WriteToFile($"Batch Exception: {ex.ToString()}")
    End Try
End If
```

