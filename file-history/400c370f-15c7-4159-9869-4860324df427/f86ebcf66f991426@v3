# Refactoring Templates - Quick Reference

Use these templates to quickly refactor the remaining SQL INSERT statements to use APIs.

---

## Template 1: Single Insert (Simple PASS/FAIL)

### Find This Pattern:
```vb
Dim InsertParameter() As SqlParameter = New SqlParameter() {
    New SqlParameter("@SN", SqlDbType.VarChar) With {.Value = rowSSN},
    New SqlParameter("@AOIID", SqlDbType.Int) With {.Value = AOIID},
    New SqlParameter("@StationID", SqlDbType.Int) With {.Value = StationID},
    New SqlParameter("@PartID", SqlDbType.Int) With {.Value = partid},
    New SqlParameter("@Side", SqlDbType.VarChar) With {.Value = sideid},
    New SqlParameter("@Trndate", SqlDbType.DateTime) With {.Value = Fecha},
    New SqlParameter("@IsGood", SqlDbType.Bit) With {.Value = isGood},
    New SqlParameter("@Position", SqlDbType.Int) With {.Value = position}
}
Dim sql_insert As String = "INSERT INTO Machines_Extractor_AOI_Data ..."
BeConnM.InsertRecords(sql_insert, InsertParameter)
```

### Replace With:
```vb
' Create API request
Dim request As New AOIInspectionRequest With {
    .Sn = rowSSN,
    .Aoiid = AOIID,
    .StationId = StationID,
    .PartId = partid,
    .Side = sideid,
    .Trndate = Fecha,
    .IsGood = isGood,
    .IsRework = False,
    .Position = position,
    .RefCir = "",
    .DefectDesc = "",
    .UserPass = Nothing,
    .FacilityKey = Nothing,
    .AreaId = AreaID
}

' Submit via API
Try
    Dim response As AOIDataResponse = AOI.SubmitInspection(request)
    If Not response.Success Then
        WriteToFile($"API Error: {response.Message}")
    End If
Catch ex As Exception
    WriteToFile($"API Exception: {ex.ToString()}")
End Try
```

