## Template 2: Insert with Defects

### Find This Pattern:
```vb
Dim InsertParameter() As SqlParameter = New SqlParameter() {
    ' ... standard parameters ...
    New SqlParameter("@RefCir", SqlDbType.VarChar) With {.Value = refCir},
    New SqlParameter("@DefectDesc", SqlDbType.NVarChar) With {.Value = defectDesc},
    New SqlParameter("@UserPass", SqlDbType.Bit) With {.Value = userPass}
}
BeConnM.InsertRecords(sql_insert, InsertParameter)
```

### Replace With:
```vb
' Create API request with defect information
Dim request As New AOIInspectionRequest With {
    .Sn = serialNumber,
    .Aoiid = AOIID,
    .StationId = StationID,
    .PartId = partid,
    .Side = sideid,
    .Trndate = Fecha,
    .IsGood = False, ' Has defects
    .IsRework = False,
    .Position = position,
    .RefCir = refCir,
    .DefectDesc = defectDesc,
    .UserPass = userPass,
    .Xmisfit = If(xMisfit = "", 0, CSng(xMisfit)),
    .Ymisfit = If(yMisfit = "", 0, CSng(yMisfit)),
    .Xpos = If(xPos = "", 0, CSng(xPos)),
    .Ypos = If(yPos = "", 0, CSng(yPos)),
    .FacilityKey = Nothing,
    .AreaId = AreaID
}

' Submit via API
Try
    Dim response As AOIDataResponse = AOI.SubmitInspection(request)
    If Not response.Success Then
        WriteToFile($"API Error: {response.Message}")
    End If
Catch ex As Exception
    WriteToFile($"API Exception: {ex.ToString()}")
End Try
```

