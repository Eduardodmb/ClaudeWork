## Template 4: Mixed Loop (PASS + FAIL with Defects)

### Find This Pattern:
```vb
For Each row As DataRow In dtBoardBarcodes.Rows
    If rowResult = "PASS" Then
        ' INSERT simple pass record
    Else
        ' Process defects
        For Each defect In defects
            ' INSERT defect record
        Next
    End If
Next
```

### Replace With:
```vb
' Build batch list
Dim aoiInspectionRequests As New List(Of AOIInspectionRequest)

For Each row As DataRow In dtBoardBarcodes.Rows
    Dim rowPosition As Integer = row.Item("Position")
    Dim rowResult As String = row.Item("Result")
    Dim rowSSN As String = row.Item("Barcode")

    If rowResult = "PASS" Then
        ' Add PASS record to batch
        aoiInspectionRequests.Add(New AOIInspectionRequest With {
            .Sn = rowSSN,
            .Aoiid = AOIID,
            .StationId = StationID,
            .PartId = partid,
            .Side = sideid,
            .Trndate = Fecha,
            .IsGood = True,
            .Position = rowPosition,
            .FacilityKey = Nothing,
            .AreaId = AreaID
        })
    Else
        ' Process defects and add to batch
        Dim defects = dtBoardBarcodesDetails.Select($"Position='{rowPosition}'")
        If defects.Length > 0 Then
            For Each defect In defects
                aoiInspectionRequests.Add(New AOIInspectionRequest With {
                    .Sn = rowSSN,
                    .Aoiid = AOIID,
                    .StationId = StationID,
                    .PartId = partid,
                    .Side = sideid,
                    .Trndate = Fecha,
                    .IsGood = False,
                    .Position = rowPosition,
                    .RefCir = defect("Location"),
                    .DefectDesc = defect("DefectCode"),
                    .UserPass = (defect("UserResult") = "PASS"),
                    .Xpos = If(defect("X") = "", 0, CSng(defect("X"))),
                    .Ypos = If(defect("Y") = "", 0, CSng(defect("Y"))),
                    .FacilityKey = Nothing,
                    .AreaId = AreaID
                })
            Next
        End If
    End If
Next

' Submit batch
If aoiInspectionRequests.Count > 0 Then
    Try
        Dim batchResponse As AOIBatchResponse = AOI.SubmitInspectionBatch(aoiInspectionRequests)
        WriteToFile($"Mixed Batch: {batchResponse.SuccessfulRecords}/{batchResponse.TotalRecords} successful")
    Catch ex As Exception
        WriteToFile($"Batch Error: {ex.ToString()}")
    End Try
End If
```

