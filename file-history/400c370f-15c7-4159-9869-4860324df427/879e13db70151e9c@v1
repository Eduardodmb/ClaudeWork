using System.ComponentModel.DataAnnotations;

namespace APIs_BeFirst.Models.Request
{
    /// <summary>
    /// Request model for AOI (Automated Optical Inspection) machine data submission
    /// </summary>
    public class AOIDataRequest
    {
        [Required]
        public int AOIID { get; set; }

        [Required]
        public int StationID { get; set; }

        [Required]
        [StringLength(50)]
        public string PartNumber { get; set; }

        [Required]
        public int PartID { get; set; }

        [Required]
        [StringLength(10)]
        public string Side { get; set; }  // e.g., "TOP", "BOTTOM"

        [Required]
        [StringLength(50)]
        public string SerialNumber { get; set; }

        [Required]
        public int Position { get; set; }

        [Required]
        [StringLength(20)]
        public string Result { get; set; }  // e.g., "PASS", "FAIL", "VERIFY"

        [StringLength(50)]
        public string? Operator { get; set; }

        public DateTime? InspectionDate { get; set; }

        public int? DefectCodeID { get; set; }

        public List<AOIDefectDetail>? Defects { get; set; }
    }

    /// <summary>
    /// Individual defect details from AOI inspection
    /// </summary>
    public class AOIDefectDetail
    {
        [StringLength(50)]
        public string? Location { get; set; }  // Component reference designator

        [StringLength(50)]
        public string? PinNumber { get; set; }

        public decimal? X { get; set; }  // X coordinate

        public decimal? Y { get; set; }  // Y coordinate

        [StringLength(100)]
        public string? DefectCode { get; set; }

        [StringLength(20)]
        public string? UserResult { get; set; }  // Manual review result
    }
}
