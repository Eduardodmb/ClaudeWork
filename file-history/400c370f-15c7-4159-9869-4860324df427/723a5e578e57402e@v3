using APIs_BeFirst.Models;
using APIs_BeFirst.Models.DataBase;
using APIs_BeFirst.Models.Response;
using Microsoft.AspNetCore.Identity;
using Microsoft.AspNetCore.Mvc;
using Microsoft.Extensions.Logging;
using Microsoft.EntityFrameworkCore;

namespace APIs_BeFirst.Service.Parts
{
    public class PartsService : ModelBase, IPartsService
    {

        protected readonly ProdMesDbContext _context;
        public PartsService(ProdMesDbContext context) : base(context)
        {
            _context = context;
        }





        public async Task<PartsResponse> GetAsync(int PartID ,string PartNumber)
        {

            try
            {
                var newmodel = new PartsResponse();
              
                    var dtExist = await _context.Parts
                         .Where(a => a.PartId == PartID || a.PartNumber == PartNumber)
                         .FirstOrDefaultAsync();

                    if (dtExist != null)
                    {
                    newmodel.PartID = dtExist.PartId ?? 0;
                    newmodel.PartNumber = dtExist.PartNumber ?? string.Empty;
                    newmodel.Part_Key = dtExist.PartKey ?? 0;

                    return newmodel;

                    }
                    else
                    {
                        return null;
                    }

              
            }
            catch (Exception)
            {
                return null;
            }
        }

        public async Task<Boolean?> IsControlled(string PartKey)
        {

            try
            {
                var newmodel = new IsControlled();

                var dtExist = await _context.PlexIdtPartVParts
                     .Where(a => a.PartKey == Convert.ToInt32(PartKey) && a.IsIgnored == Convert.ToBoolean(0) && (a.IsControled == Convert.ToBoolean(1) || a.MslId>3))
                     .FirstOrDefaultAsync();

                if (dtExist != null)
                {
                    return true;
                }
                else
                {
                    return false;
                }


            }
            catch (Exception)
            {
                return null;
            }
        }

        public async Task<List<PartNumberResponse>> GetAllPartsAsync()
        {
            try
            {
                var parts = await _context.CsIdtPartnumbers
                    .Select(p => new PartNumberResponse
                    {
                        PartNumber = p.PartNumber,
                        PartID = p.PartId,
                        ArrQty = p.PiecesByPanel
                    })
                    .ToListAsync();

                return parts;
            }
            catch (Exception)
            {
                return new List<PartNumberResponse>();
            }
        }

        public async Task<List<AOIQualityChangeStatusResponse>> GetAOIQualityChangeStatusAsync()
        {
            try
            {
                var query = @"SELECT [PartID],
                                     [CirRef],
                                     [ContainsText],
                                     [DefectCodeID]
                              FROM [Quality_Inspection_AOI_ChangeStatus]";

                var results = await _context.Database
                    .SqlQueryRaw<AOIQualityChangeStatusResponse>(query)
                    .ToListAsync();

                return results;
            }
            catch (Exception)
            {
                return new List<AOIQualityChangeStatusResponse>();
            }
        }

        public async Task<int> GetMergeCounterAsync(int partId)
        {
            try
            {
                var query = @"SELECT counter FROM PART_OPERATION_SERIALIZATION_MERGE_COUNTER WHERE partid = {0}";
                var counter = await _context.Database
                    .SqlQueryRaw<int>(query, partId)
                    .FirstOrDefaultAsync();

                return counter;
            }
            catch (Exception)
            {
                return 0;
            }
        }

        public async Task<int> IncrementMergeCounterAsync(int partId)
        {
            try
            {
                // Check if counter exists
                var existsQuery = @"SELECT COUNT(*) FROM PART_OPERATION_SERIALIZATION_MERGE_COUNTER WHERE partid = {0}";
                var exists = await _context.Database
                    .SqlQueryRaw<int>(existsQuery, partId)
                    .FirstOrDefaultAsync() > 0;

                if (exists)
                {
                    // Update existing counter
                    var updateQuery = @"UPDATE PART_OPERATION_SERIALIZATION_MERGE_COUNTER SET counter = counter + 1 WHERE partid = {0}";
                    await _context.Database.ExecuteSqlRawAsync(updateQuery, partId);

                    // Return new counter value
                    return await GetMergeCounterAsync(partId);
                }
                else
                {
                    // Insert new counter starting at 1
                    var insertQuery = @"INSERT INTO PART_OPERATION_SERIALIZATION_MERGE_COUNTER (partid, counter) VALUES ({0}, 1)";
                    await _context.Database.ExecuteSqlRawAsync(insertQuery, partId);
                    return 1;
                }
            }
            catch (Exception)
            {
                return 0;
            }
        }




    }
}