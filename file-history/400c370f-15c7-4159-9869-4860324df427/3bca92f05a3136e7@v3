## Refactoring Examples

### Example 1: Get AOI Machines

#### ❌ BEFORE (SQL)

```vb
' Lines 51-75 in ExService.vb
Dim ConnectionString As String = BeConnM.ConnectionString
Dim Connection As New System.Data.SqlClient.SqlConnection(ConnectionString)

Dim Sql_aoim As String = "SELECT [AutoID],[AOIID],[MachineName],[StationID],[PathGood],[PathGoodSuccess],[PathBad],[PathBadSuccess],[Active],[Brand],[Facility_Key],[Updated_Date],[IsEnabled],[IsInServer],[IsInMachine],[Message],[MessageDate],[Domain],[UserName],[Password],[ExtractorType],[LookingValue] FROM Machines_Extractor_AOI WHERE Active='1'"

If ConfStationID > 0 Then
    Sql_aoim = "SELECT [AutoID],[AOIID],[MachineName],[StationID],[PathGood],[PathGoodSuccess],[PathBad],[PathBadSuccess],[Active],[Brand],[Facility_Key],[Updated_Date],[IsEnabled],[IsInServer],[IsInMachine],[Message],[MessageDate],[Domain],[UserName],[Password],[ExtractorType],[LookingValue] FROM Machines_Extractor_AOI WHERE Active='1' AND StationID='" & ConfStationID & "'"
End If

Dim command_aoim As New System.Data.SqlClient.SqlCommand(Sql_aoim, Connection)
Dim dt_aoim As New DataTable
Dim adpt_aoim As New Data.SqlClient.SqlDataAdapter(command_aoim)

Try
    Connection.Open()
    adpt_aoim.Fill(dt_aoim)
Catch ex As Exception
    executeCorrectly = 5
    executeMessage = ex.ToString()
    WriteToFile(ex.ToString)
Finally
    Connection.Close()
End Try

' Process results
If dt_aoim.Rows.Count > 0 Then
    For Each aoimachine As DataRow In dt_aoim.Rows
        Dim FOLDER_WITH_GOOD_RESULTS As String = aoimachine.Item("PathGood")
        Dim StationID As Integer = aoimachine.Item("StationID")
        Dim Brand As String = aoimachine.Item("Brand")
        ' ... process machine ...
    Next
End If
```

#### ✅ AFTER (API)

```vb
' Use API call instead
Dim machines As List(Of AOIMachineConfig)

If ConfStationID > 0 Then
    machines = AOI.GetMachinesByStation(ConfStationID)
Else
    machines = AOI.GetAllActiveMachines()
End If

' Process results
If machines.Count > 0 Then
    For Each aoimachine As AOIMachineConfig In machines
        Dim FOLDER_WITH_GOOD_RESULTS As String = aoimachine.PathGood
        Dim StationID As Integer = aoimachine.StationId
        Dim Brand As String = aoimachine.Brand
        ' ... process machine ...
    Next
End If
```

**Benefits:**
- ✅ No SQL connection management
- ✅ No SQL injection risk
- ✅ Cleaner, more readable code
- ✅ Type-safe property access
- ✅ Automatic exception handling in API layer

