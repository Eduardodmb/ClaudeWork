    New SqlParameter("@DefectDesc", SqlDbType.NVarChar) With {.Value = ""},
    New SqlParameter("@UserPass", SqlDbType.Bit) With {.Value = DBNull.Value},
    New SqlParameter("@Position", SqlDbType.Int) With {.Value = rowPosition}
}

Dim sql_insert As String = "INSERT INTO Machines_Extractor_AOI_Data "
sql_insert &= "([SN] ,[AOIID] ,[StationID] ,[PartID] ,[Side],[Trndate] ,[IsGood] ,[IsRework],[RefCir] ,[DefectDesc] ,[UserPass],[Position]) VALUES(@SN,@AOIID,@StationID,@PartID,@Side,@Trndate,@IsGood,@IsRework,@RefCir ,@DefectDesc ,@UserPass,@Position)"

