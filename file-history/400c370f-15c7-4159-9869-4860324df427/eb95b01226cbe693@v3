## 🔧 Usage Examples

### VB.NET (Windows Service)

```vb
' Get machines
Dim machines As List(Of AOIMachineConfig) = AOI.GetMachinesByStation(7)

' Submit inspection
Dim request As New AOIInspectionRequest With {
    .Sn = "SN123456",
    .Aoiid = 1,
    .StationId = 7,
    .PartId = 100,
    .Side = "T",
    .IsGood = True,
    .Position = 1
}
Dim response As AOIDataResponse = AOI.SubmitInspection(request)

' Batch submit
Dim requests As New List(Of AOIInspectionRequest)
' ... add requests ...
Dim batchResponse As AOIBatchResponse = AOI.SubmitInspectionBatch(requests)

' Program counter
Dim counter As AOIProgramCounter = AOI.GetProgramCounter(1, 100, "T")
AOI.UpdateProgramCounter(1, 100, "T", 5)
```

