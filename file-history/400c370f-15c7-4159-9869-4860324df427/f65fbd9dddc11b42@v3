                        working_units_total = 1;
                    }

                    double HOUR_QUALITY = working_units_ok / working_units_total;

                    newModel.HOUR_Quality = HOUR_QUALITY;

                    newModel.MinutesQuality = HOUR_QUALITY * HOUR_WORKEDMINUTES;

                    double HOUR_OEE = HOUR_AVAILABILITY * HOUR_EFFICENCY * HOUR_QUALITY;

                    newModel.HOUR_OEE = HOUR_OEE;

                    if (saveHistory)
