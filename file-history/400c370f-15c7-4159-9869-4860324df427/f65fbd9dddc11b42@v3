            {
                var query = @"SELECT MANUFACTURING_TICKETS_TYPE.IssueType,
                                     PART_STATION_TICKETS.IssueID,
                                     MANUFACTURING_TICKETS.IssueDescription
                              FROM PART_STATION_TICKETS
                              INNER JOIN MANUFACTURING_TICKETS_TYPE
                                  ON PART_STATION_TICKETS.Is sueTypeID = MANUFACTURING_TICKETS_TYPE.IssueTypeID
                              INNER JOIN MANUFACTURING_TICKETS
                                  ON PART_STATION_TICKETS.IssueID = MANUFACTURING_TICKETS.IssueID
                              WHERE PART_STATION_TICKETS.StationID = {0}
                                AND PART_STATION_TICKETS.IssuesolveDate IS NULL
                                AND MANUFACTURING_TICKETS_TYPE.IssueType = 'NPI'
                              ORDER BY PART_STATION_TICKETS.TrnDate DESC";

                var results = await _context.Database
                    .SqlQueryRaw<StationNPIIssueResponse>(query, StationID)
