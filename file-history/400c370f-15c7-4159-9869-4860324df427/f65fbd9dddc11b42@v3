                    {
                        HOUR_AVAILABILITY = (double)(HOUR_TOTALMINUTES - downtime_programmed - downtime_noprogrammed) / (HOUR_TOTALMINUTES - downtime_programmed);

                        if (double.IsNaN(HOUR_AVAILABILITY) || (HOUR_TOTALMINUTES - downtime_programmed) == 0)
                        {
                            HOUR_AVAILABILITY = 0;
                        }
                    }
                    catch (Exception)
                    {

                    }

                    newModel.HOUR_Availability = HOUR_AVAILABILITY;

                    double HOUR_EFFICENCY = 0;
                    newModel.MinutesEfficency = HOUR_WORKEDMINUTES;

                    try
                    {
                        HOUR_EFFICENCY = HOUR_WORKEDMINUTES / (HOUR_TOTALMINUTES - downtime_programmed - downtime_noprogrammed);
