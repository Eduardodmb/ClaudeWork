                xpajb => new { PartID = (int?)xpajb.PSSetup.PartId, Side = (string?)xpajb.PSSetup.Side, AreaID = (int?)xpajb.PStation.AreaId },
                rute => new { PartID = (int?)rute.PartId, Side = (string?)rute.Side, AreaID = (int?)rute.AreaId },
                (xpajb, rutes) => new { xpajb.PSSetup, xpajb.PStation, xpajb.PN, xpajb.area, xpajb.job, xpajb.bin, rutes })
                .SelectMany(
                xpajbr => xpajbr.rutes.DefaultIfEmpty(),
                (xpajbr, rute) => new StationSetupID
                {
                    SetupID = xpajbr.PStation.SetupId,
                    StationID = (int)xpajbr.PSSetup.StationId,
                    StationName = xpajbr.PStation.StationName,
                    AreaID = xpajbr.PStation.AreaId,
                    Area = xpajbr.area.Area,
                    Workcenter_Key = xpajbr.PStation.WorkcenterKey1,
                    Workcenter_PLC_Name_1 = xpajbr.PStation.WorkcenterPlcName1,
                    Workcenter_Kanban_Key = xpajbr.PStation.WorkcenterKeyKanban1,
                    Workcenter_PLC_Name_Kanban_1 = xpajbr.PStation.WorkcenterPlcNameKanban1,
                    ShareLocation = xpajbr.PStation.ShareLacation ?? "",
                    WIPLocation = xpajbr.PStation.Wiplocation ?? "",
                    JobTypeID = xpajbr.PSSetup.JobTypeId,
                    JobID = xpajbr.PSSetup.JobId,
                    JobNumber = (int)xpajbr.job.JobId,
                    PartID = xpajbr.PSSetup.PartId,
                    PartNumber = xpajbr.PN.PartNumber,
                    Side = xpajbr.PSSetup.Side,
                    BinID = (int)xpajbr.PSSetup.BinId,
                    BinName = xpajbr.bin.BinName ?? "",
                    StageID = rute.Stage,
                    Regex = xpajbr.PN.PartSerialFormat,
                    RegexHumanable = xpajbr.PN.PartSerialFormatEasy,
                    PanelRegex = xpajbr.PN.PartSerialPanelFormat,
                    PanelRegexHumanable = xpajbr.PN.PartSerialPanelFormatEasy,
                    Facility_Key = xpajbr.PStation.FacilityKey,
                    Building_Key = xpajbr.PStation.BuildingKey,
                    IsNext = xpajbr.PSSetup.IsNext ? 1 : 0
                })
                .FirstOrDefaultAsync();

            if (dtStationSetup != null)
            {
                string PartFormat = dtStationSetup.Regex;
                string PartFormatEasy = dtStationSetup.RegexHumanable;
                string PanelPartFormat = dtStationSetup.PanelRegex;
                string BinName = dtStationSetup.BinName;

                // UPDATE FORMAT IF BIN>0
                if (dtStationSetup.BinID > 0)
                {

                    //dtStationSetup[0].Regex = null;
                    string newmodel = PartFormat;

                    var dtBin = await _context.PartBins
                        .Where(x => x.PartId == dtStationSetup.PartID && x.IsEnabled == true)
                        .Select(x => x.PartId)
                        .ToListAsync();

                    if (dtBin.Count > 0)
                    {
                        int binsizeinformat = 0;

                        for (int binsize = 1; binsize <= 30; binsize++)
                        {
                            string binsizetext = "[";
                            string binsizetextw = "[";

                            for (int ii = 1; ii <= binsize; ii++)
                            {
                                binsizetext += "B";
                                binsizetextw += "B";
                            }

                            binsizetext += "]";
                            binsizetextw += "W]";

                            if (PartFormatEasy.Contains(binsizetext) || PartFormatEasy.Contains(binsizetextw))
                            {
                                binsizeinformat = binsize;
                            }
                        }
                        string strBinName = BinName;

                        var strConvertion = await _context.PartBins
                            .Where(x => x.PartId == dtStationSetup.PartID && x.BinName == BinName && x.IsEnabled == true)
                            .Select(x => x.Convertion)
                            .FirstOrDefaultAsync();

                        if (strConvertion.Length > 0)
                        {
                            strBinName = strConvertion;
                        }

                        if (strBinName != "General")
                        {
                            newmodel = PartFormat.Replace(@"[\w]{" + binsizeinformat + "}", strBinName);
                            newmodel = PartFormat.Replace(".{" + binsizeinformat + "}", strBinName);
                        }
                    }
                    PartFormat = newmodel;
                }
                PartFormat = "^" + PartFormat + "$";
                PanelPartFormat = "^" + PanelPartFormat + "$";

                dtStationSetup.Regex = PartFormat;
                dtStationSetup.PanelRegex = PanelPartFormat;
            }
            return dtStationSetup;
        }

