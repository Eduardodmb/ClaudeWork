                                                        Retest = g.Count(x => x.h.Ssnindex > 1)
                                                    })
                                                    .ToListAsync();

                }

                int limitallday = seguida.Hour + 24;
                int limitallshift = seguida.Hour + 12;

                List<Task<HourOEE>> tasks = new List<Task<HourOEE>>();
                List<HourOEE> responses = new List<HourOEE>();

                for (int i = seguida.Hour; i < (shift == 0 ? limitallday : limitallshift); i++)
                {
                    //Debug.WriteLine(i);
                    seguida = seguida.AddHours(+1);

                    //tasks.Add(
                    var result = await GetOEEHourAsync(StationID, seguida, dateEnd, usetickets, dtProductionAllDay);
                    responses.Add(result);

                }

                // Procesar respuestas
                foreach (HourOEE hourdetail in responses)
                {
                    OEE_MinutesProgrammed = OEE_MinutesProgrammed - hourdetail.Downtime_Programmed;
                    OEE_MinutesAvailables = OEE_MinutesAvailables - hourdetail.Downtime_Programmed - hourdetail.Downtime_NoProgrammed; // DAY AVAILABLE
                    OEE_MinutesWorked = OEE_MinutesWorked + hourdetail.HOUR_WORKEDMINUTES;
                    OEE_MinutesWorked_retest = OEE_MinutesWorked_retest + hourdetail.HOUR_WORKEDMINUTES_RETEST;
                    Units_Defects = Units_Defects + hourdetail.Units_Defects;
                    Units_total = Units_total + hourdetail.Units_total;


                    OEE_MinutesLostWithTickets = OEE_MinutesLostWithTickets + hourdetail.MinutesLostWithTickets; // OEE GENERAL AVAILABLE
                    OEE_MinutesLostWithoutTickets = OEE_MinutesLostWithoutTickets + hourdetail.MinutesLostWithOutTickets; // OEE GENERAL AVAILABLE TO RUN
                }

                int minuteschangeoves = 0;

                //Remove changeovers from minutes availables
                OEE_MinutesProgrammed = OEE_MinutesProgrammed - minuteschangeoves;

                OEE_MinutesAvailables = OEE_MinutesAvailables - minuteschangeoves;

                // RESULTS

                if (OEE_MinutesProgrammed <= 0)
                {
                    Availability = 0;
                }
                else
                {
                    Availability = (double)OEE_MinutesAvailables / OEE_MinutesProgrammed;
                }

                if (OEE_MinutesAvailables <= 0)
                {
                    eficency = 0;
                    eficency_retest = 0;
                }
                else
                {
                    eficency = ((double)OEE_MinutesWorked / OEE_MinutesAvailables);
                    eficency_retest = ((double)OEE_MinutesWorked_retest / OEE_MinutesAvailables);
                }

                try
                {
                    if ((Units_total - Units_Defects) == 0 || Units_total == 0)
                    {
                        quality = 0;
                    }
                    else
                    {
                        quality = ((double)(Units_total - Units_Defects) / Units_total);
                    }
                }
                catch
                {

                }

                newModel.Availability = Availability;
                newModel.Efficency = eficency;
                newModel.Efficency_Retest = eficency_retest;
                newModel.Quality = quality;
                newModel.Total = Availability * eficency * quality;

                newModel.MinutesProgrammed = OEE_MinutesProgrammed;
                newModel.MinutesAvailables = OEE_MinutesAvailables;
                newModel.MinutesWorked = OEE_MinutesWorked;
                newModel.MinutesWorked_Retest = OEE_MinutesWorked_retest;
                newModel.MinutesOEE = (newModel.MinutesWorked * quality);

                newModel.MinutesLostWithOutTickets = OEE_MinutesLostWithoutTickets;
                newModel.MinutesLostWithTickets = OEE_MinutesLostWithTickets;

                if (beginDate < todaydate && shift == 0)
                {
