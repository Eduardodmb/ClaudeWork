                WorkcenterKeyKanban1 = -1,
                WorkcenterKeyKanban2 = -1,
                WorkcenterPlcName1 = "",
                WorkcenterPlcName2 = "",
                WorkcenterPlcNameKanban1 = "",
                WorkcenterPlcNameKanban2 = "",
