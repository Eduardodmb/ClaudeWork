        public async Task<StationSetupID> AddSetupID(int StationID, int PartID, string Side, int BinID, int JobTypeID, int JobID, string Hostname, string IP)
        {
            StationSetupID newModel = new StationSetupID();

            /* CHECK STATION IS AUTHORIZED */
            var resultAuthorized = await IsAuthorizedAsync(Hostname, StationID);

            if (resultAuthorized == false)
            {
                throw new InvalidOperationException("Invalid StationID");
            }
            else
            {
                bool isAuthorized = resultAuthorized;

                if (isAuthorized == false)
                {
                    throw new InvalidOperationException("Hostname Not Authorized");
                }
            }

            /* GET Workcenter Values */
            StationResponse currentStation = new StationResponse();

            var stationResponse = await GetAsync(StationID);

            if (stationResponse == null)
            {
                throw new InvalidOperationException("Invalid StationID");
            }
            else
            {
                currentStation = stationResponse;

                if (currentStation == null)
                {
                    throw new InvalidOperationException("Error trying to get StationID");
                }
            }

            /* GET JobID/JobTypeID Values if are empty */

            if (JobID == -1)
            {
                var responseSchedule = await ScheduleGet(StationID);

                if (responseSchedule == null)
                {
                    throw new InvalidOperationException("Invalid StationID");
                }
                else
                {
                    List<JobResponse> jobList = responseSchedule;

                    if (jobList == null)
                    {
                        throw new InvalidOperationException("Error trying to get Current StationID");
                    }

                    List<JobResponse> samePartID = jobList.Where(j => j.PartID == PartID && j.Side == Side && j.BinID == BinID).OrderBy(j => j.Priority).ToList();

                    if (samePartID.Count > 0)
                    {
                        JobID = samePartID.FirstOrDefault().JobID;
                        JobTypeID = samePartID.FirstOrDefault().JobTypeID;
                    }
                }
            }

            /* CHECK IF EXIST */

            bool addSetup = false;
            var setupResponse = await SetupIDGet(StationID, Hostname);

            if (setupResponse == null)
            {
                addSetup = true;
            }
            else
            {
                StationSetupID CurrentSetup = setupResponse;

                if (CurrentSetup == null)
                {
                    throw new InvalidOperationException("Error trying to get Current SetupID");
                }

                /* Check if is same Setup*/
                if (CurrentSetup.JobTypeID == JobTypeID && CurrentSetup.JobID == JobID && CurrentSetup.PartID == PartID && CurrentSetup.Side == Side && CurrentSetup.BinID == BinID)
                {
                    newModel = CurrentSetup;

                    var updsetupid = await _context.PartStationSetups
                        .FirstOrDefaultAsync(x => x.SetupId == CurrentSetup.SetupID);

                    if (updsetupid != null)
                    {
                        updsetupid.IsNext = false;
                        await _context.SaveChangesAsync();
                    }

                    addSetup = false;
                }
                else
                {
                    /* If not, Check if is next */
                    var responseNext = await SetupIDGetNext(StationID, Hostname);
                    if (responseNext == null)
                    {
                        addSetup = true;
                    }
                    else
                    {
                        StationSetupID NextSetup = responseNext;

                        if (NextSetup == null)
                        {
                            addSetup = true;
                        }
                        else
                        {
                            /* Check if is same Setup*/

                            if (NextSetup.JobTypeID == JobTypeID && NextSetup.JobID == JobID && NextSetup.PartID == PartID && NextSetup.Side == Side && NextSetup.BinID == BinID)
                            {
                                newModel = NextSetup;

                                var updpartst = await _context.PartStations
                                    .FirstOrDefaultAsync(x => x.StationId == StationID);
                                if (updpartst != null)
                                {
                                    updpartst.SetupId = NextSetup.SetupID;
                                    await _context.SaveChangesAsync();
                                }

                                var updpartstSetup = await _context.PartStationSetups
                                    .FirstOrDefaultAsync(x => x.SetupId == NextSetup.SetupID);

                                if (updpartstSetup != null)
                                {
                                    updpartstSetup.IsNext = false;
                                    await _context.SaveChangesAsync();
                                }
                            }
                            else
                            {
                                addSetup = true;
                            }
                        }
                    }
                }
            }
            /* If not exist, add new setup */

            if (addSetup)
            {
                var newSetupRes = 0;
                var newSetup = new PartStationSetup
                {
                    TrnDate = DateTime.Now,
                    StationId = StationID,
                    WorkcenterKey = currentStation.Workcenter_Key,
                    WorkcenterKanbanKey = currentStation.Workcenter_Kanban_Key,
                    JobTypeId = JobTypeID,
                    JobId = JobID,
                    PartId = PartID,
                    Side = Side,
                    BinId = BinID,
                    IsNext = false
                };
                _context.PartStationSetups.Add(newSetup);
                await _context.SaveChangesAsync();

                if (newSetup != null)
                {
                    newSetupRes = 1;
                    var updPS = await _context.PartStations
                        .FirstOrDefaultAsync(x => x.StationId == StationID);

                    if (updPS != null)
                    {
                        updPS.SetupId = newSetup.SetupId;
                        await _context.SaveChangesAsync();
                    }
                }
            }

            /* VALIDATE SETUP */

            var responseNew = await SetupIDGet(StationID, Hostname);

            if (responseNew == null)
            {
                throw new InvalidOperationException("Error trying to get SetupID");
            }
            else
            {
                StationSetupID newSetup = responseNew;

                if (newSetup == null)
                {
                    throw new InvalidOperationException("Error trying to get Current SetupID");
                }
                else
                {
                    if (newSetup.JobTypeID == JobTypeID && newSetup.JobID == JobID && newSetup.PartID == PartID && newSetup.Side == Side && newSetup.BinID == BinID)
                    {
                        newModel = newSetup;
                    }
                    else
                    {
                        throw new InvalidOperationException("Setup not ready, please try again.");
                    }
                }
            }

            return newModel;
        }

