        public async Task<StationResponse> GetAsync(int StationID = 0, string StationName = "")
        {

            var newModel = new StationResponse();

            var dtExist = await _context.PartStations
                            .Where(s => s.StationId == StationID || s.StationName == StationName)
                            .Join(_context.PartOperationAreas,
                                station => station.AreaId,
                                area => area.AreaId,
                                (station, area) => new
                                {
                                    StationName = station.Alias == "" ? station.StationName : station.Alias,
                                    StationID = station.StationId,
                                    AreaID = area.AreaId,
                                    Area = area.Area,
                                    Workcenter_Key = station.WorkcenterKey1,
                                    Workcenter_Kanban_Key = station.WorkcenterKeyKanban1
                                })
                            .OrderBy(r => r.AreaID)
                            .ThenBy(r => r.StationName)
                            .ToArrayAsync();


            if (dtExist.Count() > 0)
            {
                newModel.StationID = int.Parse(dtExist.FirstOrDefault().StationID.ToString());
                newModel.StationName = dtExist.FirstOrDefault().StationName.ToString();
                newModel.AreaID = int.Parse(dtExist.FirstOrDefault().AreaID.ToString());
                newModel.AreaName = dtExist.FirstOrDefault().Area.ToString();
                newModel.Workcenter_Key = int.Parse(dtExist.FirstOrDefault().Workcenter_Key.ToString());
                newModel.Workcenter_Kanban_Key = int.Parse(dtExist.FirstOrDefault().Workcenter_Kanban_Key.ToString());

                return newModel;
            }
            else
            {
                throw new InvalidOperationException("Invalid StationID");
            }

        }

        public async Task<bool> IsAuthorizedAsync(string Hostname, int StationID = 0)
        {
            bool newModel = false;

            var dtDetails = await _context.PartStationAuthorizeds
                                    .Where(psa => psa.MachineName == Hostname
                                               && psa.IsActive == true
                                               && (StationID == 0 || psa.StationId == StationID))
                                    .Select(psa => new
                                    {
                                        psa.AutoId,
                                        psa.StationId
                                    })
                                    .ToListAsync();


            if (dtDetails.Count() > 0)
            {
                newModel = true;
            }
            else
            {

                var dtDetailsName = await _context.PartStations
                                                  .Where(Ps => Ps.StationId == StationID && Ps.StationName == Hostname)
                                                  .Select(Ps => Ps.StationId)
                                                  .ToListAsync();

                if (dtDetailsName.Count() > 0)
                {
                    newModel = true;
                }
            }

            return newModel;

        }

        public async Task<List<StationResponse>> GetAuthorizedAsync(string Hostname)
        {

            List<StationResponse> newModel = new List<StationResponse>();

            var setting = await _context.Settings
                                        .Where(s => s.Description == "Station_ShowPackoutOption")
                                        .Select(s => s.Result)
                                        .FirstOrDefaultAsync();

            // Usa un nombre diferente para la variable de salida en TryParse
            bool addPackout = bool.TryParse(setting, out bool isPackoutEnabled) ? isPackoutEnabled : false;

            int PackoutAreaID = await _context.Settings
                                                .Where(S => S.Description == "packout_area_id")
                                                .Select(s => Convert.ToInt32(s.Result))
                                                .FirstOrDefaultAsync();

            var dtDetails = await _context.PartStations
                                            .Where(s => _context.PartStationAuthorizeds
                                                            .Where(psa => psa.MachineName == Hostname && psa.IsActive == true)
                                                            .Select(psa => psa.StationId)
                                                            .Contains(s.StationId)
                                                        || s.StationName == Hostname)
                                            .Join(_context.PartOperationAreas,
                                                    s => s.AreaId,
                                                    a => a.AreaId,
                                                    (s, a) => new
                                                    {
                                                        StationName = a.Area + " - " + (s.Alias == "" ? s.StationName : s.Alias),
                                                        s.StationId,
                                                        a.AreaId,
                                                        a.Area
                                                    })
                                            .OrderBy(x => x.AreaId)
                                            .ThenBy(x => x.StationName)
                                            .ToListAsync();


            foreach (var row in dtDetails)
            {
                StationResponse newThing = new StationResponse();

                newThing.StationID = int.Parse(row.StationId.ToString());
                newThing.StationName = row.StationName.ToString();
                newThing.AreaID = int.Parse(row.AreaId.ToString());
                newThing.AreaName = row.Area.ToString();

                newModel.Add(newThing);

                if (addPackout && (newThing.AreaID == 8))
                {
                    StationResponse newThingPackout = new StationResponse();

                    newThingPackout.StationID = int.Parse(row.StationId.ToString());
                    newThingPackout.StationName = row.StationName.ToString() + " [PACKOUT]";
                    newThingPackout.AreaID = PackoutAreaID;

                    newThingPackout.AreaName = await _context.PartOperationAreas
                                                                .Where(p => p.AreaId == newThingPackout.AreaID)
                                                                .Select(p => p.Area)
                                                                .FirstOrDefaultAsync();


                    newModel.Add(newThingPackout);
                }
            }


            return newModel;

        }

