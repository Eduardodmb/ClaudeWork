using APIs_BeFirst.Models.Request;
using APIs_BeFirst.Models.Response;

namespace APIs_BeFirst.Service.AOI
{
    /// <summary>
    /// Service interface for AOI (Automated Optical Inspection) data operations
    /// </summary>
    public interface IAOIService
    {
        /// <summary>
        /// Submit a single AOI inspection record
        /// </summary>
        Task<AOIDataResponse> SubmitInspectionAsync(AOIDataRequest request);

        /// <summary>
        /// Submit multiple AOI inspection records in batch
        /// </summary>
        Task<AOIBatchResponse> SubmitInspectionBatchAsync(List<AOIDataRequest> requests);

        /// <summary>
        /// Get AOI machine configuration
        /// </summary>
        Task<AOIMachineConfig?> GetMachineConfigAsync(int aoiId);
    }

    /// <summary>
    /// AOI machine configuration from Machines_Extractor_AOI table
    /// </summary>
    public class AOIMachineConfig
    {
        public int AutoID { get; set; }
        public int AOIID { get; set; }
        public string MachineName { get; set; }
        public int StationID { get; set; }
        public string PathGood { get; set; }
        public string PathBad { get; set; }
        public bool Active { get; set; }
        public string Brand { get; set; }
        public int Facility_Key { get; set; }
        public bool IsEnabled { get; set; }
    }
}
