using APIs_BeFirst.Framework.Queries;
using APIs_BeFirst.Models.Request;
using APIs_BeFirst.Models.Response;
using Microsoft.Data.SqlClient;
using System.Data;

namespace APIs_BeFirst.Service.AOI
{
    /// <summary>
    /// Service implementation for AOI (Automated Optical Inspection) data operations
    /// </summary>
    public class AOIService : IAOIService
    {
        private readonly IConfiguration _configuration;
        private readonly string _connectionString;

        public AOIService(IConfiguration configuration)
        {
            _configuration = configuration;
            // Assuming MES database connection (where Machines_Extractor_AOI tables reside)
            _connectionString = _configuration.GetConnectionString("MES")
                ?? throw new InvalidOperationException("MES connection string not found");
        }

        /// <summary>
        /// Submit a single AOI inspection record
        /// </summary>
        public async Task<AOIDataResponse> SubmitInspectionAsync(AOIDataRequest request)
        {
            var response = new AOIDataResponse();

            try
            {
                using (var connection = new SqlConnection(_connectionString))
                {
                    await connection.OpenAsync();

                    // Insert main AOI data record
                    var insertQuery = @"
                        INSERT INTO Machines_Extractor_AOI_Data
                        (
                            AOIID,
                            StationID,
                            PartNumber,
                            PartID,
                            Side,
                            SerialNumber,
                            Position,
                            Result,
                            Operator,
                            InspectionDate,
                            DefectCodeID,
                            CreatedDate
                        )
                        VALUES
                        (
                            @AOIID,
                            @StationID,
                            @PartNumber,
                            @PartID,
                            @Side,
                            @SerialNumber,
                            @Position,
                            @Result,
                            @Operator,
                            @InspectionDate,
                            @DefectCodeID,
                            GETDATE()
                        );
                        SELECT SCOPE_IDENTITY();";

                    using (var command = new SqlCommand(insertQuery, connection))
                    {
                        command.Parameters.AddWithValue("@AOIID", request.AOIID);
                        command.Parameters.AddWithValue("@StationID", request.StationID);
                        command.Parameters.AddWithValue("@PartNumber", request.PartNumber);
                        command.Parameters.AddWithValue("@PartID", request.PartID);
                        command.Parameters.AddWithValue("@Side", request.Side);
                        command.Parameters.AddWithValue("@SerialNumber", request.SerialNumber);
                        command.Parameters.AddWithValue("@Position", request.Position);
                        command.Parameters.AddWithValue("@Result", request.Result);
                        command.Parameters.AddWithValue("@Operator", (object?)request.Operator ?? DBNull.Value);
                        command.Parameters.AddWithValue("@InspectionDate", request.InspectionDate ?? DateTime.Now);
                        command.Parameters.AddWithValue("@DefectCodeID", (object?)request.DefectCodeID ?? DBNull.Value);

                        var mainRecordId = await command.ExecuteScalarAsync();
                        int recordsInserted = 1;

                        // Insert defect details if any
                        if (request.Defects != null && request.Defects.Any())
                        {
                            foreach (var defect in request.Defects)
                            {
                                var defectQuery = @"
                                    INSERT INTO Machines_Extractor_AOI_Data_Details
                                    (
                                        AOIDataID,
                                        Position,
                                        Location,
                                        PinNumber,
                                        X,
                                        Y,
                                        DefectCode,
                                        UserResult
                                    )
                                    VALUES
                                    (
                                        @AOIDataID,
                                        @Position,
                                        @Location,
                                        @PinNumber,
                                        @X,
                                        @Y,
                                        @DefectCode,
                                        @UserResult
                                    )";

                                using (var defectCommand = new SqlCommand(defectQuery, connection))
                                {
                                    defectCommand.Parameters.AddWithValue("@AOIDataID", mainRecordId);
                                    defectCommand.Parameters.AddWithValue("@Position", request.Position);
                                    defectCommand.Parameters.AddWithValue("@Location", (object?)defect.Location ?? DBNull.Value);
                                    defectCommand.Parameters.AddWithValue("@PinNumber", (object?)defect.PinNumber ?? DBNull.Value);
                                    defectCommand.Parameters.AddWithValue("@X", (object?)defect.X ?? DBNull.Value);
                                    defectCommand.Parameters.AddWithValue("@Y", (object?)defect.Y ?? DBNull.Value);
                                    defectCommand.Parameters.AddWithValue("@DefectCode", (object?)defect.DefectCode ?? DBNull.Value);
                                    defectCommand.Parameters.AddWithValue("@UserResult", (object?)defect.UserResult ?? DBNull.Value);

                                    await defectCommand.ExecuteNonQueryAsync();
                                    recordsInserted++;
                                }
                            }
                        }

                        response.Success = true;
                        response.Message = "AOI inspection data submitted successfully";
                        response.RecordsInserted = recordsInserted;
                    }
                }
            }
            catch (Exception ex)
            {
                response.Success = false;
                response.Message = $"Error submitting AOI data: {ex.Message}";
            }

            return response;
        }

        /// <summary>
        /// Submit multiple AOI inspection records in batch
        /// </summary>
        public async Task<AOIBatchResponse> SubmitInspectionBatchAsync(List<AOIDataRequest> requests)
        {
            var response = new AOIBatchResponse
            {
                TotalRecords = requests.Count,
                SuccessfulRecords = 0,
                FailedRecords = 0
            };

            foreach (var request in requests)
            {
                try
                {
                    var result = await SubmitInspectionAsync(request);
                    if (result.Success)
                    {
                        response.SuccessfulRecords++;
                    }
                    else
                    {
                        response.FailedRecords++;
                        response.Errors?.Add($"SN {request.SerialNumber}: {result.Message}");
                    }
                }
                catch (Exception ex)
                {
                    response.FailedRecords++;
                    response.Errors?.Add($"SN {request.SerialNumber}: {ex.Message}");
                }
            }

            response.Success = response.FailedRecords == 0;
            return response;
        }

        /// <summary>
        /// Get AOI machine configuration
        /// </summary>
        public async Task<AOIMachineConfig?> GetMachineConfigAsync(int aoiId)
        {
            try
            {
                using (var connection = new SqlConnection(_connectionString))
                {
                    await connection.OpenAsync();

                    var query = @"
                        SELECT
                            AutoID,
                            AOIID,
                            MachineName,
                            StationID,
                            PathGood,
                            PathBad,
                            Active,
                            Brand,
                            Facility_Key,
                            IsEnabled
                        FROM Machines_Extractor_AOI
                        WHERE AOIID = @AOIID AND Active = 1";

                    using (var command = new SqlCommand(query, connection))
                    {
                        command.Parameters.AddWithValue("@AOIID", aoiId);

                        using (var reader = await command.ExecuteReaderAsync())
                        {
                            if (await reader.ReadAsync())
                            {
                                return new AOIMachineConfig
                                {
                                    AutoID = reader.GetInt32(0),
                                    AOIID = reader.GetInt32(1),
                                    MachineName = reader.GetString(2),
                                    StationID = reader.GetInt32(3),
                                    PathGood = reader.GetString(4),
                                    PathBad = reader.GetString(5),
                                    Active = reader.GetBoolean(6),
                                    Brand = reader.GetString(7),
                                    Facility_Key = reader.GetInt32(8),
                                    IsEnabled = reader.GetBoolean(9)
                                };
                            }
                        }
                    }
                }
            }
            catch (Exception)
            {
                // Log exception (implement logging as needed)
                return null;
            }

            return null;
        }
    }
}
