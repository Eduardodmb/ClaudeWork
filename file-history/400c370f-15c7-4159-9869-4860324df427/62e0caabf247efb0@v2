using APIs_BeFirst.Models;
using APIs_BeFirst.Models.DataBase;
using APIs_BeFirst.Models.Request;
using APIs_BeFirst.Models.Response;
using Microsoft.EntityFrameworkCore;

namespace APIs_BeFirst.Service.Quality
{
    public class QualityService : ModelBase, IQualityService
    {
        protected readonly ProdMesDbContext _context;

        public QualityService(ProdMesDbContext context) : base(context)
        {
            _context = context;
        }

        public async Task<List<LockedUnitResponse>> GetLockedUnitsAsync(string sn)
        {
            try
            {
                var query = @"SELECT [AutoID], [SN], [DefectCodeID], [StationID], [TrnDate],
                                     [ControlID], [AreaID], [Comments], [LockDate], [IsLocked]
                              FROM [PART_UNITS_LOCKED]
                              WHERE SN = {0}";

                var results = await _context.Database
                    .SqlQueryRaw<LockedUnitResponse>(query, sn)
                    .ToListAsync();

                return results;
            }
            catch (Exception)
            {
                return new List<LockedUnitResponse>();
            }
        }

        public async Task<bool> AddLockedUnitAsync(LockedUnitRequest request)
        {
            try
            {
                var query = @"INSERT INTO [dbo].[PART_UNITS_LOCKED]
                              ([SN], [DefectCodeID], [StationID], [TrnDate], [ControlID],
                               [AreaID], [Comments], [LockDate], [IsLocked])
                              VALUES ({0}, {1}, {2}, {3}, {4}, {5}, {6}, {7}, {8})";

                await _context.Database.ExecuteSqlRawAsync(
                    query,
                    request.SN,
                    request.DefectCodeID,
                    request.StationID,
                    request.TrnDate ?? DateTime.Now,
                    request.ControlID,
                    request.AreaID,
                    request.Comments ?? "",
                    request.LockDate ?? DateTime.Now,
                    request.IsLocked
                );

                return true;
            }
            catch (Exception)
            {
                return false;
            }
        }

        public async Task<bool> DeleteLockedUnitsAsync(string sn, string commentPattern)
        {
            try
            {
                var query = @"DELETE FROM [dbo].[PART_UNITS_LOCKED]
                              WHERE SN = {0} AND [Comments] LIKE {1}";

                await _context.Database.ExecuteSqlRawAsync(query, sn, commentPattern);
                return true;
            }
            catch (Exception)
            {
                return false;
            }
        }
    }
}
