using APIs_BeFirst.Models.Request;
using APIs_BeFirst.Models.Response;
using APIs_BeFirst.Models.DataMachines;
using APIs_BeFirst.Service.AOI;
using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;

namespace APIs_BeFirst.Controllers
{
    /// <summary>
    /// API Controller for AOI (Automated Optical Inspection) data submission
    /// </summary>
    [ApiController]
    [Route("[controller]")]
    public class AOIController : ControllerBase
    {
        #region Fields
        private readonly IAOIService _aoiService;
        private readonly ILogger<AOIController> _logger;
        #endregion

        #region Ctor
        public AOIController(IAOIService aoiService, ILogger<AOIController> logger)
        {
            _aoiService = aoiService;
            _logger = logger;
        }
        #endregion

        /// <summary>
        /// Submit a single AOI inspection record
        /// </summary>
        /// <param name="request">AOI inspection data</param>
        /// <returns>Submission result</returns>
        /// <remarks>
        /// POST /AOI/SubmitInspection
        ///
        /// Sample request:
        ///
        ///     POST /AOI/SubmitInspection
        ///     {
        ///       "sn": "SN123456789",
        ///       "aoiid": 1,
        ///       "stationId": 7,
        ///       "partId": 456,
        ///       "side": "T",
        ///       "isGood": true,
        ///       "position": 1,
        ///       "facilityKey": 1,
        ///       "areaId": 1
        ///     }
        ///
        /// </remarks>
        [Authorize]
        [HttpPost("SubmitInspection")]
        [ProducesResponseType(typeof(AOIDataResponse), StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status401Unauthorized)]
        [ProducesResponseType(StatusCodes.Status500InternalServerError)]
        public async Task<ActionResult<AOIDataResponse>> SubmitInspection([FromBody] AOIDataRequest request)
        {
            try
            {
                _logger.LogInformation($"AOI data submission received: AOIID={request.Aoiid}, SN={request.Sn}");

                if (!ModelState.IsValid)
                {
                    return BadRequest(ModelState);
                }

                var result = await _aoiService.SubmitInspectionAsync(request);

                if (result.Success)
                {
                    _logger.LogInformation($"AOI data submitted successfully: {result.RecordsInserted} records");
                    return Ok(result);
                }
                else
                {
                    _logger.LogWarning($"AOI data submission failed: {result.Message}");
                    return BadRequest(result);
                }
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error in SubmitInspection endpoint");
                return StatusCode(500, new AOIDataResponse
                {
                    Success = false,
                    Message = $"Internal server error: {ex.Message}"
                });
            }
        }

        /// <summary>
        /// Submit multiple AOI inspection records in batch
        /// </summary>
        /// <param name="requests">List of AOI inspection data</param>
        /// <returns>Batch submission result</returns>
        /// <remarks>
        /// POST /AOI/SubmitInspectionBatch
        ///
        /// Accepts an array of AOI inspection records for bulk submission.
        /// Useful when processing multiple boards from a panel.
        /// </remarks>
        [Authorize]
        [HttpPost("SubmitInspectionBatch")]
        [ProducesResponseType(typeof(AOIBatchResponse), StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status400BadRequest)]
        [ProducesResponseType(StatusCodes.Status401Unauthorized)]
        [ProducesResponseType(StatusCodes.Status500InternalServerError)]
        public async Task<ActionResult<AOIBatchResponse>> SubmitInspectionBatch([FromBody] List<AOIDataRequest> requests)
        {
            try
            {
                _logger.LogInformation($"AOI batch submission received: {requests.Count} records");

                if (requests == null || !requests.Any())
                {
                    return BadRequest("Request list cannot be empty");
                }

                var result = await _aoiService.SubmitInspectionBatchAsync(requests);

                _logger.LogInformation($"AOI batch processed: {result.SuccessfulRecords}/{result.TotalRecords} successful");

                if (result.Success)
                {
                    return Ok(result);
                }
                else
                {
                    return StatusCode(207, result); // 207 Multi-Status (partial success)
                }
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error in SubmitInspectionBatch endpoint");
                return StatusCode(500, new AOIBatchResponse
                {
                    Success = false,
                    Errors = new List<string> { $"Internal server error: {ex.Message}" }
                });
            }
        }

        /// <summary>
        /// Get AOI machine configuration
        /// </summary>
        /// <param name="aoiId">AOI machine ID</param>
        /// <returns>Machine configuration</returns>
        /// <remarks>
        /// GET /AOI/GetMachineConfig?aoiId=1
        ///
        /// Returns configuration for a specific AOI machine including paths,
        /// station assignments, and facility information.
        /// </remarks>
        [Authorize]
        [HttpGet("GetMachineConfig")]
        [ProducesResponseType(typeof(MachinesExtractorAoi), StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        [ProducesResponseType(StatusCodes.Status401Unauthorized)]
        [ProducesResponseType(StatusCodes.Status500InternalServerError)]
        public async Task<ActionResult<MachinesExtractorAoi>> GetMachineConfig(int aoiId)
        {
            try
            {
                _logger.LogInformation($"AOI machine config requested: AOIID={aoiId}");

                var config = await _aoiService.GetMachineConfigAsync(aoiId);

                if (config == null)
                {
                    _logger.LogWarning($"AOI machine not found: AOIID={aoiId}");
                    return NotFound($"AOI machine with ID {aoiId} not found or inactive");
                }

                return Ok(config);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error in GetMachineConfig endpoint");
                return StatusCode(500, $"Internal server error: {ex.Message}");
            }
        }

        /// <summary>
        /// Get AOI machines by station ID
        /// </summary>
        /// <param name="stationId">Station ID</param>
        /// <returns>List of AOI machines for the station</returns>
        [Authorize]
        [HttpGet("GetMachinesByStation")]
        [ProducesResponseType(typeof(List<MachinesExtractorAoi>), StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status404NotFound)]
        [ProducesResponseType(StatusCodes.Status401Unauthorized)]
        public async Task<ActionResult<List<MachinesExtractorAoi>>> GetMachinesByStation(int stationId)
        {
            try
            {
                _logger.LogInformation($"AOI machines requested for station: {stationId}");

                var machines = await _aoiService.GetMachinesByStationAsync(stationId);

                if (machines == null || machines.Count == 0)
                {
                    _logger.LogWarning($"No AOI machines found for station: {stationId}");
                    return NotFound($"No active AOI machines found for station {stationId}");
                }

                return Ok(machines);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error in GetMachinesByStation endpoint");
                return StatusCode(500, $"Internal server error: {ex.Message}");
            }
        }

        /// <summary>
        /// Get all active AOI machines
        /// </summary>
        /// <returns>List of all active AOI machines</returns>
        [Authorize]
        [HttpGet("GetAllActiveMachines")]
        [ProducesResponseType(typeof(List<MachinesExtractorAoi>), StatusCodes.Status200OK)]
        [ProducesResponseType(StatusCodes.Status401Unauthorized)]
        public async Task<ActionResult<List<MachinesExtractorAoi>>> GetAllActiveMachines()
        {
            try
            {
                _logger.LogInformation("All active AOI machines requested");

                var machines = await _aoiService.GetAllActiveMachinesAsync();

                return Ok(machines);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error in GetAllActiveMachines endpoint");
                return StatusCode(500, $"Internal server error: {ex.Message}");
            }
        }

        /// <summary>
        /// Health check endpoint for AOI service
        /// </summary>
        /// <returns>Health status</returns>
        [HttpGet("Health")]
        [ProducesResponseType(StatusCodes.Status200OK)]
        public IActionResult Health()
        {
            return Ok(new
            {
                Status = "Healthy",
                Service = "AOI Controller",
                Timestamp = DateTime.Now
            });
        }
    }
}
