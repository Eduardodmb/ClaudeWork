using APIs_BeFirst.Models;
using APIs_BeFirst.Framework.Queries;
using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using Microsoft.Data.SqlClient;
using System.Data;
using System.Security.Cryptography;
using static APIs_BeFirst.Service.Plex.BePlex;
using System.Diagnostics;
using System.Xml.Linq;
using APIs_BeFirst.Models.Response;
using APIs_BeFirst.Service.Container;
using APIs_BeFirst.Service.Station;
using APIs_BeFirst.Framework.Functions;

namespace APIs_BeFirst.Controllers
{
    [ApiController]
    [Route("[controller]")]
    public class StationController : ControllerBase
    {

        #region Fields
        private readonly IStationService _stationService;
        #endregion

        #region Ctor
        public StationController(IStationService stationService)
        {
            _stationService = stationService;
        }
        #endregion

        [Authorize]
        [HttpPost("Add")]
        public async Task<ActionResult<bool>> Add(string StationName, string Area)
        {
            try
            {

                bool result = await _stationService.AddAsync(StationName, Area);

                return result;
            }
            catch (InvalidOperationException ex)
            {
                return BadRequest(ex.Message); // Devuelve un mensaje de error
            }
            catch (Exception ex)
            {
                return StatusCode(500, $"Internal server error: {ex.Message}"); // Error general
            }
        }

        [Authorize]
        [HttpGet("Get")]
        public async Task<ActionResult<StationResponse>> Get(int StationID = 0, string StationName = "")
        {
            try
            {
                var box = await _stationService.GetAsync(StationID, StationName);
                return Ok(box); // Retorna el objeto creado
            }
            catch (InvalidOperationException ex)
            {
                return BadRequest(ex.Message); // Devuelve un mensaje de error
            }
            catch (Exception ex)
            {
                return StatusCode(500, $"Internal server error: {ex.Message}"); // Error general
            }
        }

        [Authorize]
        [HttpGet("IsAuthorized")]
        public async Task<ActionResult<bool>> IsAuthorized(string Hostname, int StationID = 0)
        {
            try
            {

                bool result = await _stationService.IsAuthorizedAsync(Hostname, StationID);

                return result;
            }
            catch (Exception ex)
            {
                return BadRequest(ex.ToString());
            }
        }

        [Authorize]
        [HttpGet("GetAuthorized")]
        public async Task<ActionResult<List<StationResponse>>> GetAuthorized(string Hostname)
        {
            try
            {
                var newModel = await _stationService.GetAuthorizedAsync(Hostname);

                return newModel;
            }
           
            catch
            {
                return BadRequest();
            }
        }

        /*=====================================
         OEE: Get Current OEE
         =====================================*/

        [Authorize]
        [HttpGet("GetOEE")]
        public async Task<ActionResult<OEE>> GetOEE(int StationID, int year = 0, int month = 0, int day = 0, int shift = 0, bool getLastSaved = false)
        {
            try
            {
                var box = await _stationService.GetOEEAsync(StationID, year, month, day, shift, getLastSaved);
                return Ok(box); // Retorna el objeto creado
            }
            catch (InvalidOperationException ex)
            {
                return BadRequest(ex.Message); // Devuelve un mensaje de error
            }
            catch (Exception ex)
            {
                return StatusCode(500, $"Internal server error: {ex.Message}"); // Error general
            }
        }

        [Authorize]
        [HttpGet("GetHourOEE")]
        public async Task<ActionResult<HourOEE>> GetHourOEE(int StationID, int year = 0, int month = 0, int day = 0, int hour = 6, bool getLastSaved = false)
        {
            try
            {
                var box = await _stationService.GetHourOEEAsync(StationID, year, month, day, hour, getLastSaved);
                return Ok(box); // Retorna el objeto creado
            }
            catch (InvalidOperationException ex)
            {
                return BadRequest(ex.Message); // Devuelve un mensaje de error
            }
            catch (Exception ex)
            {
                return StatusCode(500, $"Internal server error: {ex.Message}"); // Error general
            }
        }

        /*=====================================
         Schedule: Get Current Schedule
         =====================================*/
        [Authorize]
        [HttpGet("Schedule/Get")]
        public async Task<ActionResult<List<Job>>> ScheduleGet(int StationID, int Job_Status_Key = 2396)
        {
            try
            {
                var schedule = await _stationService.ScheduleGet(StationID, Job_Status_Key);
                return Ok(schedule); // Retorna el objeto creado

            }
            catch (Exception ex)
            {
                return StatusCode(500, $"Internal server error: {ex.Message}"); // Error general
            }
        }




        /*=====================================
         SETUP IDs: Use this to get and set setup ID. Becarefoul, only one machine are able to change it. 
         =====================================*/

        [Authorize]
        [HttpPost("Setup/Add")]
        public async Task<ActionResult<StationSetupID>> SetupIDAdd(int StationID, int PartID = -1, string Side = "A", int BinID = -1, int JobTypeID = -1, int JobID = -1, string Hostname = "", string IP = "")
        {
            try
            {

                var newModel = await _stationService.AddSetupID(StationID, PartID, Side, BinID, JobTypeID, JobID, Hostname, IP);

                return newModel;
            }
            catch (InvalidOperationException ex)
            {
                return NotFound(ex.Message);
            }
            catch (Exception ex)
            {
                return StatusCode(500, $"Internal server error: {ex.Message}"); // Error general
            }
        }


        [Authorize]
        [HttpGet("Setup/Get")]
        public async Task<ActionResult<StationSetupID>> SetupIDGet(int StationID, string Hostname = "")
        {
            try
            {
                var GetSetupID = await _stationService.SetupIDGet(StationID, Hostname);
                if (GetSetupID == null)
                {
                    return BadRequest("Error while getting the SetupID.");
                }
                return GetSetupID;
            }
            catch (Exception ex)
            {
                return BadRequest();
            }
        }

        [Authorize]
        [HttpGet("Setup/GetNext")]
        public async Task<ActionResult<StationSetupID>> SetupIDGetNext(int StationID, string Hostname = "")
        {
            try
            {
                var GetSetupIdNext = await _stationService.SetupIDGetNext(StationID, Hostname);
                if (GetSetupIdNext == null)
                {
                    return BadRequest("Error while getting the SetupID Next.");
                }
                return Ok(GetSetupIdNext);
            }
            catch (Exception ex)
            {
                return BadRequest();
            }
        }


        //   /*=====================================
        //    STATION CONTAINERS: 
        //    =====================================*/

        [Authorize]
        [HttpPost("Container/Load")]
        public async Task<ActionResult<Boolean>> ContainerLoad(int StationID, int Workcenter_Key, string Serial_No, string Feeder_No, string position)
        {
            try
            {
                var ContLoad = await _stationService.ContainerLoad(StationID, Workcenter_Key, Serial_No, Feeder_No, position);
                if (ContLoad == null)
                {
                    return BadRequest("Error while loading the container.");
                }
                return Ok(ContLoad);
            }
            catch
            {
                return BadRequest();
            }
        }


    }

}
