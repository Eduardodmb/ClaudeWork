                                       widget="monetary"
                                       options="{'currency_field': 'company_currency'}"
                                       readonly="1"/>
                                <field name="x_bom_summary_total_subcontractor"
                                       widget="monetary"
                                       options="{'currency_field': 'company_currency'}"
                                       readonly="1"/>
                                <field name="x_bom_summary_calculated_total"
                                       widget="monetary"
                                       options="{'currency_field': 'company_currency'}"
