        <template id="project_bom_summary_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="project">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <t t-set="bom_report_currency" t-value="project.bom_summary_currency_for_report()"/>

                            <div class="text-center mt-4 mb-4">
                                <h2>BOM Summary</h2>
                                <h4><span t-field="project.name"/></h4>
                                <p><strong>Customer: </strong> <span t-field="project.partner_id"/></p>
                            </div>

                            <!-- Cost Summary Section -->
                            <t t-set="totals" t-value="project.get_bom_summary_totals()"/>
                            
                            <div class="mb-4">
                                <table class="table table-bordered" style="width:100%; max-width: 1300px; margin: 0 auto;">
                                    <thead class="thead-dark">
                                        <tr>
                                            <th colspan="7" class="text-center" style="font-size: 1.1em;">Cost Summary - All Divisions</th>
                                        </tr>
                                        <tr class="thead-light">
                                            <th style="width:18%;">Category</th>
                                            <th class="text-right" style="width:13%;">Calculated Total</th>
                                            <th class="text-right" style="width:13%;">Est. Budget</th>
                                            <th class="text-right" style="width:13%;">Buyout</th>
                                            <th class="text-right" style="width:13%;">Current Expense</th>
                                            <th class="text-right" style="width:12%;">Balance</th>
                                            <th class="text-right" style="width:13%;">Final Modified Price</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-if="totals['total_items'] > 0 or totals['items_adjustment'] != 0 or totals['items_buyout'] != 0 or totals['items_current_expense'] != 0">
                                            <td><strong>Total Materials:</strong></td>
                                            <td class="text-right"><span t-out="project.bom_summary_format_amount(totals['total_items'])"/></td>
                                            <td class="text-right">
                                                <t t-if="totals['items_adjustment'] >= 0">
