                                        <table class="table table-sm table-bordered" style="width:100%;">
                                            <thead class="thead-light">
                                                <tr class="font-weight-bold">
                                                    <th style="width:30%;">EXPENSE ITEM</th>
                                                    <th class="text-center" style="width:25%;">QTY</th>
                                                    <th class="text-center" style="width:25%;">RATE</th>
                                                    <th class="text-right" style="width:20%;">COST</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr class="border-bottom">
                                                    <td>MEALS</td>
                                                    <td class="text-center"><t t-esc="'%.2f' % te.expense_meals_qty"/></td>
                                                    <td class="text-center"><span t-out="project.bom_summary_format_amount(te.expense_meals_rate)"/></td>
                                                    <td class="text-right"><span t-out="project.bom_summary_format_amount(te.expense_meals_cost)"/></td>
                                                </tr>
                                                <tr class="border-bottom">
                                                    <td>HOTEL (ROOMS/NIGHTS)</td>
                                                    <td class="text-center"><t t-esc="'%.2f' % te.expense_hotel_qty"/></td>
                                                    <td class="text-center"><span t-out="project.bom_summary_format_amount(te.expense_hotel_rate)"/></td>
                                                    <td class="text-right"><span t-out="project.bom_summary_format_amount(te.expense_hotel_cost)"/></td>
                                                </tr>
                                                <tr class="border-bottom">
                                                    <td>TRAVEL TIME (HRS)</td>
                                                    <td class="text-center"><t t-esc="'%.2f hrs' % te.expense_travel_time_qty"/></td>
                                                    <td class="text-center"><span t-out="project.bom_summary_format_amount(te.expense_travel_time_rate)"/></td>
                                                    <td class="text-right"><span t-out="project.bom_summary_format_amount(te.expense_travel_time_cost)"/></td>
                                                </tr>
                                                <tr class="border-bottom">
                                                    <td>FUEL LUMP SUM</td>
                                                    <td class="text-center"><t t-esc="'%.2f' % te.expense_fuel_lump_sum_qty"/></td>
                                                    <td class="text-center"><span t-out="project.bom_summary_format_amount(te.expense_fuel_lump_sum_rate)"/></td>
                                                    <td class="text-right"><span t-out="project.bom_summary_format_amount(te.expense_fuel_lump_sum_cost)"/></td>
                                                </tr>
                                                <tr class="border-bottom bg-light">
                                                    <td class="font-weight-bold">IRS MILE COST (Miles/Cents)</td>
                                                    <td class="text-center"><t t-esc="'%.2f' % te.expense_irs_mile_qty"/> <small class="text-muted">miles</small></td>
                                                    <td class="text-center"><span t-out="project.bom_summary_format_amount(te.expense_irs_mile_rate)"/> <small class="text-muted">/mile</small></td>
                                                    <td class="text-right"><span t-out="project.bom_summary_format_amount(te.expense_irs_mile_cost)"/></td>
                                                </tr>
                                                <tr class="border-bottom">
                                                    <td>DISPATCH</td>
                                                    <td class="text-center"><t t-esc="'%.2f' % te.expense_dispatch_qty"/></td>
                                                    <td class="text-center"><span t-out="project.bom_summary_format_amount(te.expense_dispatch_rate)"/></td>
                                                    <td class="text-right"><span t-out="project.bom_summary_format_amount(te.expense_dispatch_cost)"/></td>
                                                </tr>
                                                <tr class="border-bottom">
                                                    <td>OTHER</td>
                                                    <td class="text-center"><t t-esc="'%.2f' % te.expense_other_qty"/></td>
                                                    <td class="text-center"><span t-out="project.bom_summary_format_amount(te.expense_other_rate)"/></td>
                                                    <td class="text-right"><span t-out="project.bom_summary_format_amount(te.expense_other_cost)"/></td>
                                                </tr>
                                                <tr class="border-bottom">
                                                    <td>CAR RENTAL</td>
                                                    <td class="text-center"><t t-esc="'%.2f' % te.expense_car_rental_qty"/></td>
                                                    <td class="text-center"><span t-out="project.bom_summary_format_amount(te.expense_car_rental_rate)"/></td>
                                                    <td class="text-right"><span t-out="project.bom_summary_format_amount(te.expense_car_rental_cost)"/></td>
                                                </tr>
                                            </tbody>
                                            <tfoot>
                                                <tr class="py-3 font-weight-bold" style="font-size: 1.1em;">
                                                    <td colspan="3" class="text-right">TOTAL TRAVEL EXPENSE COST:</td>
                                                    <td class="text-right"><span t-out="project.bom_summary_format_amount(te.total_travel_expense_cost)"/></td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </t>
                                    <t t-if="not te">
                                        <div class="alert alert-warning">No Travel Expenses recorded for this division.</div>
                                    </t>
                                </div>
                                
                                <div style="page-break-after: always;"></div>
                            </t> 
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>