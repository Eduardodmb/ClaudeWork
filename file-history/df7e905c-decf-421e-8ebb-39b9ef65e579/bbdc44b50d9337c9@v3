                                       widget="monetary"
                                       options="{'currency_field': 'company_currency'}"
                                       readonly="1"
                                       style="font-weight: bold;"/>
                            </group>
                            <group string="Cost Adjustment (Buyout)">
                                <field name="x_bom_summary_items_buyout"
                                       widget="monetary"
                                       options="{'currency_field': 'company_currency'}"/>
                                <field name="x_bom_summary_labor_buyout"
                                       widget="monetary"
                                       options="{'currency_field': 'company_currency'}"/>
                                <field name="x_bom_summary_equipment_buyout"
                                       widget="monetary"
                                       options="{'currency_field': 'company_currency_id'}"/>
                                <field name="x_bom_summary_travel_buyout"
                                       widget="monetary"
                                       options="{'currency_field': 'company_currency'}"/>
                                <field name="x_bom_summary_subcontractor_buyout"
                                       widget="monetary"
                                       options="{'currency_field': 'company_currency'}"/>
                                <field name="x_bom_summary_freight_buyout"
                                       widget="monetary"
                                       options="{'currency_field': 'company_currency_id'}"/>
                                <field name="x_bom_summary_bond_buyout"
                                       widget="monetary"
                                       options="{'currency_field': 'company_currency_id'}"/>
                                <field name="x_bom_summary_miscellaneous_buyout"
                                       widget="monetary"
