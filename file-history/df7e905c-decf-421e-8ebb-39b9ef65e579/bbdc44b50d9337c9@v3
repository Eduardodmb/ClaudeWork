                                       widget="monetary"
                                       options="{'currency_field': 'company_currency'}"/>
                                <field name="x_bom_summary_subcontractor_adjustment"
                                       widget="monetary"
                                       options="{'currency_field': 'company_currency'}"/>
                                <field name="x_bom_summary_freight_adjustment"
                                       widget="monetary"
                                       options="{'currency_field': 'company_currency_id'}"/>
