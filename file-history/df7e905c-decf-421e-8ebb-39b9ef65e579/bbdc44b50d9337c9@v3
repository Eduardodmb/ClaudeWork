                                       widget="monetary"
                                       options="{'currency_field': 'company_currency_id'}"/>
                                <field name="x_bom_summary_miscellaneous_adjustment"
                                       widget="monetary"
                                       options="{'currency_field': 'company_currency_id'}"/>
