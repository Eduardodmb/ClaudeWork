              $("#txtEfi_@StationID").html((eficiencia * 100).toFixed(2));
              $("#txtCal_@StationID").html((calidad * 100).toFixed(2));

              $("#txtEfiT_@StationID").html(minutesworked);
              $("#txtEfiH_@StationID").html(eficienciaH);

              $("#txtProgW_@StationID").html(minutesavailables);
                  $("#txtProgA_@StationID").html(minutesprogrammed);

                  $("#txtQuaT_@StationID").html(minutesOEE);
                    $("#txtQuaH_@StationID").html(minutesworked);

                // CALCULATE OEE
                  var good = Math.floor(((parseFloat(disponibilidad) * parseFloat(eficiencia) * parseFloat(calidad))) * 100);
                  var bad = 100 - good;

                  totalminutesprogrammed = totalminutesprogrammed + minutesprogrammed;
                  totalMinutesOEE = totalMinutesOEE + minutesOEE;

                  $("#txt_Summary").html(parseFloat(good).toFixed(2) + "%");
                  $("#txt_SummaryOEE").html(totalMinutesOEE);
                  $("#txt_SummaryTotal").html(totalminutesprogrammed);


                var data_fg = JSON.stringify({
                  'good': good,
                  'bad': bad
                });

              var colors_array = ['#bc3c3c', '#79bc3c'];

              if (good == 0) {
                colors_array[0] = "#888";
                colors_array[1] = "#888";
              }

                //GET DATA FOR BAR
                $.ajax({
                  type: "POST",
                  data: data_fg,
                  url: "/Dashboards/Manufacturing/CurrentOEE",
                  contentType: "application/json; charset=utf-8",
                  success: function (chData) {
                    var aData = $.parseJSON(chData);

