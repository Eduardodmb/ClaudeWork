                        formatter: function (x) { return x + "%" },
                        colors: colors_array,
                        resize: true,
                        redraw: true
                      });
                      morrisDonut.select(1);
                    }
                  },
                  async: false
                });
              };

              $(document).ready(function () {
                updatehistory_@StationID.ToString()_f();
              })
              </script>


