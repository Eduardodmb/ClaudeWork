@* MACHINES *@

<div class="uk-card">
  <div class="uk-grid" uk-grid>

    @{
      DataTable dt_machines = Firstronic.Framework.Queries.GetDatatableFromQuery(@"SELECT  Maintenance_Machines_Position.PositionID, Maintenance_Machines_Position.Equipment_Key AS Expr2, Maintenance_Machines_Position.Read_Connection, Maintenance_Machines_Position.Write_Connection, PLEX_Maintenance_v_Equipment.*, PLEX_Maintenance_v_Equipment_Type.Equipment_Type FROM            Maintenance_Machines_Position INNER JOIN PLEX_Maintenance_v_Equipment ON Maintenance_Machines_Position.Equipment_Key = PLEX_Maintenance_v_Equipment.Equipment_Key INNER JOIN PLEX_Maintenance_v_Equipment_Type ON PLEX_Maintenance_v_Equipment.Equipment_Type_Key = PLEX_Maintenance_v_Equipment_Type.Equipment_Type_Key WHERE Maintenance_Machines_Position.stationid=@StationID AND PLEX_Maintenance_v_Equipment.Equipment_ID not like '%ANUAL%' AND PLEX_Maintenance_v_Equipment.Equipment_ID not like '%TRIMESTRAL%' AND PLEX_Maintenance_v_Equipment.Equipment_ID not like '%TRIMETRAL%' ORDER BY PositionID ASC", stationParameters);
    }


    @if (dt_machines.Rows.Count > 0)
    {
      foreach (DataRow machine in dt_machines.Rows)

      {

        <div class="uk-width-1-10@l uk-width-1-5@m uk-width-1-2@s mvc-grid mvc-grid-excel-mode">
          <table id="myTable" class="table text-center bg-white" cellspacing="0">
            <thead>
              <tr>
                <th><a href="~/Dashboards/Machines/Index/@machine["Equipment_Key"].ToString()">@machine["Equipment_ID"].ToString().Split(' ')[0].ToString()</a></th>
              </tr>
            </thead>
            <tbody>
              <tr style="height:80px;vertical-align:middle;">
                <td>
                  @switch (@machine["Equipment_Type"].ToString())
                  {
                    case "SMT Loader":
                      <img src="~/Content/img/machine/smticons/c_loader.jpg" class="h-81" />
                      break;
                    case "SMT Paste Print":
                      <img src="~/Content/img/machine/smticons/c_dek.jpg" class="h-81" />
                      break;
                    case "SMT Glue":
                      <img src="~/Content/img/machine/smticons/c_dek.jpg" class="h-81" />
                      break;
                    case "SMT Conveyor":
                      <img src="~/Content/img/machine/smticons/c_conveyor.jpg" class="h-81" />
                      break;
                    case "SMT Inspection":
                      <img src="~/Content/img/machine/smticons/c_aoi.jpg" class="h-81" />
                      break;
                    case "SMT Placement":
                      <img src="~/Content/img/machine/smticons/c_smt.jpg" class="h-81" />
                      break;
                    case "SMT Reflow":
                      <img src="~/Content/img/machine/smticons/c_oven.jpg" class="h-81" />
                      break;
                    default:
                      <img src="~/Content/img/missing.png" class="h-81" />
                      break;
                  }

                </td>
              </tr>

              <tr>
                @if (@machine["Read_Connection"].ToString() == "1")
                {
                  <td>
                    Read:
                    <img src="~/Content/img/machine/btngreen.png" width="12" class="mn-l-5" />
                  </td>
                }
                else if (@machine["Read_Connection"].ToString() == "0")
                {
                  <td>
                    Read:
                    <img src="~/Content/img/machine/btnred.png" width="12" class="mn-l-5" />
                  </td>
                }
                else
                {
                  <td>
                    Read:
                    <img src="~/Content/img/machine/btngray.png" width="12" class="mn-l-5" />
                  </td>
                }
              </tr>

              <tr>
                @if (@machine["Write_Connection"].ToString() == "-1")
                {
                  <td>
                    Write:
                    <img src="~/Content/img/machine/btngray.png" width="12" class="mn-l-5" />
                  </td>
                }
                else
                {
                  <td>
                    Write:
                    <img src="~/Content/img/machine/btngreen.png" width="12" class="mn-l-5" />
                  </td>
                }
              </tr>
            </tbody>
          </table>
        </div>
      }

      <div class="uk-width-1-10@l uk-width-1-5@m uk-width-1-2@s mvc-grid mvc-grid-excel-mode">
        <table id="myTable" class="table text-center bg-white" cellspacing="0">
          <thead>
            <tr>
              <th><a href="~/Dashboards/Station/Connectivity/@StationID?year=@Model.year&month=@Model.month&day=@Model.day">Dashboard</a></th>
            </tr>
          </thead>
          <tbody>
            <tr style="height:80px;vertical-align:middle;">
              <td>
                <img src="~/Content/img/missing.png" class="h-81" />
              </td>
            </tr>
            <tr>
              <td>
                Read:
                <img src="~/Content/img/machine/btngray.png" width="12" class="mn-l-5" />
              </td>
            </tr>
            <tr>
              <td>
                Write:
                <img src="~/Content/img/machine/btngray.png" width="12" class="mn-l-5" />
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    }
    else
    {
      <div class="col-12 text-center pd-t-20">
        <h5 class="l1-txt1 txt-center p-b-10">
          Data No Available
        </h5>
        <p>
          <img src="~/Content/img/machine/brokenconnection.png" width="80" />
        </p>
        <p class="txt-center l1-txt2 p-b-60">
          This station doesn't have any data connection, please wait for a update.
        </p>
      </div>
    }
  </div>
</div>


@* EXTRA INFO *@

<div class="uk-card mn-t-25">
  <div class="uk-grid" uk-grid>
    <div class="uk-width-2-3@m uk-width-1-1@s">
      <div class="md-card">
        <div class="md-card-toolbar">
          <h3 class="md-card-toolbar-heading-text">Timeline</h3>
        </div>
        <div class="md-card-content">
          <div class="uk-grid">
            <div id="TimeLine" class="col-12"></div>
            <div id="TimeLineLocks" class="col-12"></div>
            <div id="TimeLineTickets" class="col-12"></div>
            <div class="portal-widget-small-dash col-12 disabled text-right">
              <div class="row justify-content-end">
                <div class="col-sm-3">
                  @if (areaid == "1")
                  {
                    <a style="color:#000000;width:120px" href="~/Dashboards/Station/Loaded_Material/@Model.stationid.ToString()">
                      <h5 class="mb-0">Clic to see loaded material</h5>
                    </a>
                  }
                </div>

              </div>
            </div>
            <script type="text/javascript" nonce="@Html.ScriptNonce()">

                $(document).ready(function () {

                    GetTimeLineChart();

                    GetTimeUnlockChart();

                    GetTimeTicketChart();


                });

                function downtime_details(evt) {

                        alert("General: " + evt.getAttribute("RazonGral") + "\nDetails: " + evt.getAttribute("RazonDtsl") + "\nStart: " + parseJsonDate(evt.getAttribute("RazonInicia")) + "\nEnd: " + parseJsonDate(evt.getAttribute("RazonFinaliza")));
                };

                function hidePopup_details(evt) {
                  mypopup_details.style.display = "none";
                }

                function showPopup_details(evt) {
                  var iconPos = evt.getBoundingClientRect();
                  var ScrollY = window.scrollY;
                  var ScrennY = window.screenY;
                  mypopup_details.style.left = (iconPos.left + 10 + 130 ) + "px";
                  mypopup_details.style.top = (iconPos.top + window.scrollY - 20 ) + "px";
                  mypopup_details.style.display = "block";
                  mypopup_details.style.zIndex = "99999";
                  mypopup_details.innerHTML = "";

                  var h3 = document.createElement("h6");
                  h3.innerHTML = "Category: " + evt.getAttribute("RazonGral");
                  mypopup_details.appendChild(h3);

                  var p1 = document.createElement("p");
                  p1.innerHTML = "Details: " + evt.getAttribute("RazonDtsl");
                  mypopup_details.appendChild(p1);

                  var p2 = document.createElement("p");
                  p2.innerHTML = "Start: " + parseJsonDate(evt.getAttribute("RazonInicia")) ;
                  mypopup_details.appendChild(p2);

                  var p3 = document.createElement("p");
                  p3.innerHTML = "End: " + parseJsonDate(evt.getAttribute("RazonFinaliza"));
                  mypopup_details.appendChild(p3);
                }

                  function GetTimeLineChart() {

                      $('#TimeLine').html("");

                      const c_width = $('#TimeLine').width(), c_height = 40;

                      var pardata = JSON.stringify({
                          'year': @Model.year,
                          'month': @Model.month,
                          'day': @Model.day,
                          'StationID': @Model.stationid,'Width': c_width
                          });

                      var svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
                      var div = document.getElementById('TimeLine');
                      svg.id = "Timeline_map";
                      svg.setAttribute("width", c_width);
                      svg.setAttribute("height", c_height);
                      svg.setAttribute("zIndex", 8);
                      svg.style.border = "1px solid #adadad";
                      svg.style.background = "#13c707";

                      var svg0 = document.createElementNS("http://www.w3.org/2000/svg", "svg");
                      svg0.setAttribute("width", c_width);
                      svg0.setAttribute("height", 14);
                      svg0.setAttribute("zIndex", 8);

                      div.appendChild(svg0);
                      div.appendChild(svg);

                      $.ajax({
                          type: "POST",
                          data: pardata,
                          url: "/Dashboards/Station/DowntimeChart",
                          contentType: "application/json; charset=utf-8",
                          success: function (chData) {

                              var aData = chData;
                              var aDateTime = aData[0];
                              var aDateTim2 = aData[1];
                              var aDetails = aData[2];
                              var aRazonGral = aData[3];
                              var aMinutes = aData[4];
                              var aPosmin = aData[5];
                              var aPosline = aData[6];

                              for (i = 0; i < aPosline.length; i++) {

                                  let newElement = document.createElementNS("http://www.w3.org/2000/svg", "rect");
                                  if (aRazonGral[i] == "Cambio de modelo") {
                                      newElement.setAttribute('fill', '#0780c7');
                                  } else if (aRazonGral[i] == "No yet") {
                                      newElement.setAttribute('fill', '#F8F8F8');
                                  } else {
                                      newElement.setAttribute('fill', '#c70739');
                                  }
                                  newElement.setAttribute('x', aPosline[i]);
                                  newElement.setAttribute('y', 0);
                                  newElement.setAttribute('width', aPosmin[i]);
                                  newElement.setAttribute('height', c_height);
                                  newElement.setAttribute('RazonGral', aRazonGral[i]);
                                  newElement.setAttribute('RazonDtsl', aDetails[i]);
                                  newElement.setAttribute('RazonInicia', aDateTime[i]);
                                newElement.setAttribute('RazonFinaliza', aDateTim2[i]);

                                newElement.setAttribute('onmousemove', 'showPopup_details(this)');
                                newElement.setAttribute('onmouseout', 'hidePopup_details(this)');
                                newElement.setAttribute('onclick', 'downtime_details(this)');

                                  svg.appendChild(newElement);
                              }

                              var c_ww = Math.floor(c_width / 24);

                              for (i = 6; i < 31; i++) {

                                  let newElement = document.createElementNS("http://www.w3.org/2000/svg", "text");
                                  newElement.setAttribute('x', c_ww * (i-6));
                                  newElement.setAttribute('y', 10);
                                  newElement.setAttribute('style', 'font-family: Times New Roman; font-size: 10;');

                                  var h = i;
                                  if (h >= 24) {
                                      h = h - 24;
                                  }

                                  var t = document.createTextNode(h);
                                  newElement.appendChild(t);

                                  svg0.appendChild(newElement);
                              }

                              var minutesno = 0;
                              var minutesdw = 0;

                              for (var k in aMinutes) {
                                  if (aDetails[k]==="No yet") {
                                      minutesno = minutesno + aMinutes[k];
                                  } else {
                                      minutesdw = minutesdw + aMinutes[k];
                                  }
                              }

                              var minutesday = 1440 - minutesno;

                              var el = document.getElementById("tb_uti");
                              el.innerHTML = "ON " + (minutesday - minutesdw);


                              var el = document.getElementById("tb_uti2");
                              el.innerHTML = "OFF " + minutesdw;

                              var el = document.getElementById("tb_uti0");
                              el.innerHTML = "Machine Downtime: " + Math.floor(((minutesday - minutesdw) / minutesday) * 100) + "%";

                          },
                          async: false
                      });

                  };

                  function unlock_details(evt) {
                      alert("Date: " + parseJsonDate(evt.getAttribute("aTrnDate")) + "\nDefects: " + evt.getAttribute("aDefect") + "\nPartnumber: " + evt.getAttribute("aPartNumber") + " " + evt.getAttribute("aSide") + "\nQty: " + evt.getAttribute("aQty") + "\nUnlock By: " + evt.getAttribute("aUnlockBy") + "\nComments: " + evt.getAttribute("aComments"));
                  };

                  function GetTimeUnlockChart() {

                      $('#TimeLineLocks').html("");

                      const c_width = $('#TimeLineLocks').width(), c_height = 10;

                      var pardata = JSON.stringify({
