
@using System.Data;
@using System.Data.SqlClient;

@model Firstronic.Areas.Dashboards.Models.customreport_station

@{
  /**/
  SqlParameter[] stationParameters = new SqlParameter[]{
  new SqlParameter("@StationID",SqlDbType.Int) {Value = Model.stationid},
};

  DateTime dia_current = new DateTime(Model.year, Model.month, Model.day);
  DateTime dia_yesterday = dia_current.AddDays(-1);
  DateTime dia_tomorrow = dia_current.AddDays(+1);

  var u_yesterday = new RouteValueDictionary(Url.RequestContext.RouteData.Values);
  u_yesterday.Add("year", dia_yesterday.Year);
  u_yesterday.Add("month", dia_yesterday.Month);
  u_yesterday.Add("day", dia_yesterday.Day);

  var u_tomorrow = new RouteValueDictionary(Url.RequestContext.RouteData.Values);
  u_tomorrow.Add("year", dia_tomorrow.Year);
  u_tomorrow.Add("month", dia_tomorrow.Month);
  u_tomorrow.Add("day", dia_tomorrow.Day);

  Model.current = dia_current;

  DataTable dt_workcenters = Firstronic.Framework.Queries.GetDatatableFromQuery(@"SELECT    PD_idt_stations.StationID, PD_idt_stations.StationName, PD_idt_stations.AreaID, PD_idt_stations.IsActive, PD_idt_stations.DownTimeCodeID, PD_idt_stations.LastPieceTime, PD_idt_stations.LastPartID, PD_idt_stations.LastJob, PD_idt_stations.LastJobText, PD_idt_stations.LastJobType, PD_idt_stations.LastJobQty, PD_idt_stations.LastJobQtyBuild, PD_idt_stations.LastHourQty, PD_idt_stations.LastRate, PD_idt_stations.LastSide, PD_idt_stations.BeFirstActive, PD_idt_stations.LockStatus, PD_idt_stations.LastFormat, PD_idt_stations.DashVisible, PD_idt_stations.ProdVisible, PD_idt_stations.LockMachines, PD_idt_stations.Alias, PD_idt_stations.LastBinID, PD_idt_stations.PLC_Name, PD_idt_stations.Workcenter_Key, PD_idt_stations.Workcenter_Key_Kanban, PD_idt_stations.Workcenter_PLC_Name, PD_idt_stations.Workcenter_PLC_Name_Kanban, PD_idt_stations.AutoID, PD_idt_stations.Facility_Key, PD_idt_stations.Allow_Plex_Transactions, PD_idt_stations.Workcenter_Key_1, PD_idt_stations.Workcenter_Key_2, PD_idt_stations.Workcenter_Key_Kanban_1, PD_idt_stations.Workcenter_Key_Kanban_2, PD_idt_stations.Workcenter_PLC_Name_1, PD_idt_stations.Workcenter_PLC_Name_2, PD_idt_stations.Workcenter_PLC_Name_Kanban_1, PD_idt_stations.Workcenter_PLC_Name_Kanban_2, PD_idt_stations.Allow_LoadMaterial, PD_idt_stations.Custom_Labels, PD_idt_stations.Allow_Plex_Transactions_2, CS_idt_partnumbers.PartNumber, EN_idt_downtimes_codes.RazonSpecific,datediff(MINUTE,LastPieceTime,GETDATE()) as Downtime FROM            PD_idt_stations LEFT JOIN CS_idt_partnumbers ON PD_idt_stations.LastPartID = CS_idt_partnumbers.PartID LEFT JOIN EN_idt_downtimes_codes ON PD_idt_stations.DownTimeCodeID = EN_idt_downtimes_codes.DownTimeCodeID WHERE (PD_idt_stations.stationid = @StationID)", stationParameters);

  var StationID = Model.stationid;
  var StationName = "";
  var areaid = "0";
  try
  {
    StationName = dt_workcenters.Rows[0]["StationName"].ToString();
    areaid = dt_workcenters.Rows[0]["AreaID"].ToString();
  }
  catch
  {

  }

  SqlParameter[] areaParameters = new SqlParameter[]{
  new SqlParameter("@AreaID",SqlDbType.Int) {Value = areaid},
};

  DataTable dt_areas = Firstronic.Framework.Queries.GetDatatableFromQuery(@"SELECT    PD_idt_stations.StationID, PD_idt_stations.StationName, PD_idt_stations.AreaID, PD_idt_stations.IsActive, PD_idt_stations.DownTimeCodeID, PD_idt_stations.LastPieceTime, PD_idt_stations.LastPartID, PD_idt_stations.LastJob, PD_idt_stations.LastJobText, PD_idt_stations.LastJobType, PD_idt_stations.LastJobQty, PD_idt_stations.LastJobQtyBuild, PD_idt_stations.LastHourQty, PD_idt_stations.LastRate, PD_idt_stations.LastSide, PD_idt_stations.BeFirstActive, PD_idt_stations.LockStatus, PD_idt_stations.LastFormat, PD_idt_stations.DashVisible, PD_idt_stations.ProdVisible, PD_idt_stations.LockMachines, PD_idt_stations.Alias, PD_idt_stations.LastBinID, PD_idt_stations.PLC_Name, PD_idt_stations.Workcenter_Key, PD_idt_stations.Workcenter_Key_Kanban, PD_idt_stations.Workcenter_PLC_Name, PD_idt_stations.Workcenter_PLC_Name_Kanban, PD_idt_stations.AutoID, PD_idt_stations.Facility_Key, PD_idt_stations.Allow_Plex_Transactions, PD_idt_stations.Workcenter_Key_1, PD_idt_stations.Workcenter_Key_2, PD_idt_stations.Workcenter_Key_Kanban_1, PD_idt_stations.Workcenter_Key_Kanban_2, PD_idt_stations.Workcenter_PLC_Name_1, PD_idt_stations.Workcenter_PLC_Name_2, PD_idt_stations.Workcenter_PLC_Name_Kanban_1, PD_idt_stations.Workcenter_PLC_Name_Kanban_2, PD_idt_stations.Allow_LoadMaterial, PD_idt_stations.Custom_Labels, PD_idt_stations.Allow_Plex_Transactions_2, CS_idt_partnumbers.PartNumber, EN_idt_downtimes_codes.RazonSpecific, datediff(MINUTE, LastPieceTime, GETDATE()) as Downtime FROM            PD_idt_stations LEFT JOIN CS_idt_partnumbers ON PD_idt_stations.LastPartID = CS_idt_partnumbers.PartID LEFT JOIN EN_idt_downtimes_codes ON PD_idt_stations.DownTimeCodeID = EN_idt_downtimes_codes.DownTimeCodeID WHERE (PD_idt_stations.AreaID = @AreaID) AND (PD_idt_stations.DashVisible = 1) Order by PD_idt_stations.SortNo", areaParameters);


  string nextareaid = Model.stationid.ToString();
  string nextarea = StationName;

  string prevareaid = Model.stationid.ToString();
  string prevarea = StationName;

  int index = -1;
  DataRow[] rows = dt_areas.Select("StationID='" + Model.stationid + "'");
  if (rows.Count() > 0)
  {
    index = dt_areas.Rows.IndexOf(rows[0]);
  }

  try
  {
    nextareaid = dt_areas.Rows[index + 1][0].ToString();
    nextarea = dt_areas.Rows[index + 1][1].ToString();
  }
  catch
  {
    nextareaid = dt_areas.Rows[0][0].ToString();
    nextarea = dt_areas.Rows[0][1].ToString();
  }

  try
  {
    prevareaid = dt_areas.Rows[index - 1][0].ToString();
    prevarea = dt_areas.Rows[index - 1][1].ToString();
  }
  catch
  {
    prevareaid = dt_areas.Rows[dt_areas.Rows.Count - 1][0].ToString();
    prevarea = dt_areas.Rows[dt_areas.Rows.Count - 1][1].ToString();
  }

}

