      foreach (DataRow fila in dt_first.Rows)
      {
        DateTime datet = fila.Field<DateTime>("Trndate");
        TimeSpan posinicial = new TimeSpan(datet.Ticks - counter);
        double duracion = fila.Field<Int32>("posmin1");

        if (duracion > 1440)
        {
          duracion = 30;
        }

        fila["posmin"] = System.Convert.ToInt32(duracion * factorred);
        fila["posline"] = System.Convert.ToInt32(posinicial.TotalMinutes * factorred);
      }

      DataTable dt = dt_first;

      //Looping and extracting each DataColumn to List<Object>    
      foreach (DataColumn dc in dt.Columns)
      {
