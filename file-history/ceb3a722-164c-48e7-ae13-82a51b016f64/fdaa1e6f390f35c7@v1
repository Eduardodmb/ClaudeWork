    // FUNCTION: DOnwtimeCharts
    //===============================================================
    [HttpPost]
    public JsonResult DowntimeChart(int StationID, int Width = 600, int year = 0, int month = 0, int day = 0)
    {
      List<object> iData = new List<object>();

      DateTime current = DateTime.Now;

      if (year == 0 || month == 0 || day == 0)
      {
        year = DateTime.Now.Year;
        month = DateTime.Now.Month;
        day = DateTime.Now.Day;
      }

      DateTime _seguida = new DateTime(year, month, day, 6, 0, 0);

      DateTime _seguidas = _seguida;

      DateTime _seguidae = _seguida.AddHours(+24);


      SqlParameter[] parameters = new SqlParameter[] {
        new SqlParameter("@StationID", SqlDbType.Int) { Value = StationID },
        new SqlParameter("@Seguidas", SqlDbType.DateTime) { Value = _seguidas},
        new SqlParameter("@SeguidaE", SqlDbType.DateTime) { Value = _seguidae}
      };


      // Check if is >today

      DataTable TableDWU = new DataTable();
      // Define columns
      TableDWU.Columns.Add("Inicio", typeof(System.DateTime));
      TableDWU.Columns.Add("Fin", typeof(System.DateTime));
      TableDWU.Columns.Add("Razon", typeof(System.String));
      TableDWU.Columns.Add("Categoria", typeof(System.String));
      TableDWU.Columns.Add("Minutes", typeof(System.Int32));

      DataTable dt_first = Firstronic.Framework.Queries.GetDatatableFromQuery("Select Top 1 Dtstart, Dtend,CASE WHEN dt.RazonSpecific='Otro' THEN dt.RazonGral ELSE dt.RazonSpecific END as Razon,dt.RazonGral as Categoria FROM PD_tbl_downtimes_history INNER JOIN EN_idt_downtimes_codes dt ON PD_tbl_downtimes_history.DownTimeCodeID=dt.DownTimeCodeID Where StationID=@StationID AND DTStart<@Seguidas order by DTStart DESC", parameters);

      if (dt_first.Rows.Count > 0)
      {
        if (dt_first.Rows[0].Field<DateTime>("Dtend") > _seguidas && dt_first.Rows[0].Field<DateTime>("Dtend") < _seguidae)
        {
          DateTime ends = dt_first.Rows[0].Field<DateTime>("Dtend");
          TableDWU.Rows.Add(new DateTime(ends.Year, ends.Month, ends.Day, 6, 0, 0), ends, dt_first.Rows[0].Field<string>("Razon"), dt_first.Rows[0].Field<string>("Categoria"), (ends - new DateTime(ends.Year, ends.Month, ends.Day, 6, 0, 0)).TotalMinutes);
        }
      }

      DataTable dt_middle = Firstronic.Framework.Queries.GetDatatableFromQuery("Select Dtstart, Dtend,CASE WHEN dt.RazonSpecific='Otro' THEN dt.RazonGral ELSE dt.RazonSpecific END as Razon,dt.RazonGral as Categoria FROM PD_tbl_downtimes_history INNER JOIN EN_idt_downtimes_codes dt ON PD_tbl_downtimes_history.DownTimeCodeID=dt.DownTimeCodeID Where StationID=@StationID AND DTStart > @Seguidas and DTend<@SeguidaE order by DTStart ASC", parameters);


      if (dt_middle.Rows.Count > 0)
      {
        for (int tes = 0; tes <= dt_middle.Rows.Count - 1; tes++)
        {
          TableDWU.Rows.Add(dt_middle.Rows[tes].Field<DateTime>("DtStart"), dt_middle.Rows[tes].Field<DateTime>("Dtend"), dt_middle.Rows[tes].Field<string>("Razon"), dt_middle.Rows[tes].Field<string>("Categoria"), (dt_middle.Rows[tes].Field<DateTime>("Dtend") - dt_middle.Rows[tes].Field<DateTime>("DtStart")).TotalMinutes);
        }
      }

      DataTable dt_last = Firstronic.Framework.Queries.GetDatatableFromQuery("Select Top 1 Dtstart, Dtend,CASE WHEN dt.RazonSpecific='Otro' THEN dt.RazonGral ELSE dt.RazonSpecific END as Razon,dt.RazonGral as Categoria FROM PD_tbl_downtimes_history INNER JOIN EN_idt_downtimes_codes dt ON PD_tbl_downtimes_history.DownTimeCodeID=dt.DownTimeCodeID Where StationID=@StationID AND DTend>@SeguidaE order by DTend ASC", parameters);

      if (dt_last.Rows.Count > 0)
      {
        if (dt_last.Rows[0].Field<DateTime>("Dtstart") < _seguidae && dt_last.Rows[0].Field<DateTime>("Dtstart") > _seguidas)
        {
          DateTime ends = dt_last.Rows[0].Field<DateTime>("Dtstart");
          TableDWU.Rows.Add(ends, (new DateTime(_seguidae.Year, _seguidae.Month, _seguidae.Day, 6, 0, 0)).AddSeconds(-1), dt_last.Rows[0].Field<string>("Razon"), dt_last.Rows[0].Field<string>("Categoria"), ((new DateTime(_seguidae.Year, _seguidae.Month, _seguidae.Day, 6, 0, 0)).AddSeconds(-1) - ends).TotalMinutes);
        }
      }

      DataTable dv = new DataTable();
      dv.Columns.Add("Inicio", typeof(System.DateTime));
      dv.Columns.Add("Fin", typeof(System.DateTime));
      dv.Columns.Add("Razon", typeof(System.String));
      dv.Columns.Add("Categoria", typeof(System.String));
      dv.Columns.Add("Minutes", typeof(System.Int32));
      dv.Columns.Add("Shift", typeof(System.Int32));

      foreach (DataRow row in TableDWU.Rows)
      {
        DateTime Dia = row.Field<DateTime>("Inicio");
        // =============== Veo el dia y turno de la semana...
        var dfi = DateTimeFormatInfo.CurrentInfo;
        var calendar = dfi.Calendar;
        int semanasystema = calendar.GetWeekOfYear(Dia, dfi.CalendarWeekRule, DayOfWeek.Sunday);

        bool none = true;
        // 0 de domingo a 6 sabado
        if (semanasystema % 2 == 0)
        {
          none = false;
        }

        int dayofwk = (int)Dia.DayOfWeek;

        // Turno
        int shift = 1;
        int nextshift = 2;
        if (Dia.Hour < 6)
        {
          shift = 4;
          nextshift = 1;
        }
        else if (dayofwk <= 3 & Dia.Hour < 6)
        {
          shift = 2;
          nextshift = 1;
          if (dayofwk == 3 & none == true)
          {
            nextshift = 3;
          }
        }
        else if (dayofwk < 3 & Dia.Hour < 18)
        {
          shift = 1;
          nextshift = 2;
        }
        else if (dayofwk < 3 & Dia.Hour < 24)
        {
          shift = 2;
          nextshift = 1;
          if (dayofwk == 2 & none == true)
          {
            nextshift = 3;
          }
        }
        else if (dayofwk >= 4 & Dia.Hour >= 18)
        {
          shift = 4;
          nextshift = 3;
          if (dayofwk == 6)
          {
            nextshift = 1;
          }
        }
        else if (dayofwk >= 4 & Dia.Hour >= 6)
        {
          shift = 3;
          nextshift = 4;
        }
        else if (dayofwk > 4 & Dia.Hour < 6)
        {
          shift = 4;
          nextshift = 3;
        }
        else if (dayofwk == 4 & Dia.Hour < 6 & none == false)
        {
          shift = 4;
          nextshift = 3;
        }
        else if (dayofwk == 4 & Dia.Hour < 6 & none == true)
        {
          shift = 2;
          nextshift = 3;
        }
        else if (dayofwk == 3 & Dia.Hour < 18 & none == false)
        {
          shift = 1;
          nextshift = 4;
        }
        else if (dayofwk == 3 & Dia.Hour < 18 & none == true)
        {
          shift = 3;
          nextshift = 2;
        }
        else if (dayofwk == 3 & Dia.Hour < 24 & none == false)
        {
          shift = 4;
          nextshift = 3;
        }
        else if (dayofwk == 3 & Dia.Hour < 24 & none == true)
        {
          shift = 2;
          nextshift = 3;
        }

        DateTime fin = row.Field<DateTime>("Fin");


        if (shift == 1 | shift == 3)
        {
          if (fin > new DateTime(Dia.Year, Dia.Month, Dia.Day, 18, 0, 0))
          {
            var temp = (new DateTime(Dia.Year, Dia.Month, Dia.Day, 18, 0, 0)).AddSeconds(-1);
            dv.Rows.Add(row.Field<DateTime>("Inicio"), temp, row["Razon"], row["Categoria"], (temp - Dia).TotalMinutes, shift);
            dv.Rows.Add((new DateTime(Dia.Year, Dia.Month, Dia.Day, 18, 0, 0)), row.Field<DateTime>("Fin"), row["Razon"], row["Categoria"], (fin - temp).TotalMinutes, nextshift);
          }
          else
          {
            dv.Rows.Add(row.Field<DateTime>("Inicio"), row.Field<DateTime>("Fin"), row["Razon"], row["Categoria"], row["minutes"], shift);
          }
        }
        else if (Dia.Hour < 24)
        {
          if (fin > (new DateTime(Dia.Year, Dia.Month, Dia.Day, 6, 0, 0)).AddHours(+24))
          {
            var temp = (new DateTime(Dia.Year, Dia.Month, Dia.Day, 6, 0, 0)).AddHours(+24).AddSeconds(-1);
            dv.Rows.Add(row.Field<DateTime>("Inicio"), temp, row["Razon"], row["Categoria"], (temp - Dia).TotalMinutes, shift);
            dv.Rows.Add(temp, row.Field<DateTime>("Fin"), row["Razon"], row["Categoria"], (fin - temp).TotalMinutes, nextshift);
          }
          else
          {
            dv.Rows.Add(row.Field<DateTime>("Inicio"), row.Field<DateTime>("Fin"), row["Razon"], row["Categoria"], row["minutes"], shift);

          }
        }
        else if (fin > (new DateTime(Dia.Year, Dia.Month, Dia.Day, 6, 0, 0)))
        {
          var temp = (new DateTime(Dia.Year, Dia.Month, Dia.Day, 6, 0, 0)).AddSeconds(-1);
          dv.Rows.Add(row.Field<DateTime>("Inicio"), temp, row["Razon"], row["Categoria"], (temp - Dia).TotalMinutes, shift);
          dv.Rows.Add(temp, row.Field<DateTime>("Fin"), row["Razon"], row["Categoria"], (fin - temp).TotalMinutes, nextshift);
        }
        else
        {
          dv.Rows.Add(row.Field<DateTime>("Inicio"), row.Field<DateTime>("Fin"), row["Razon"], row["Categoria"], row["minutes"], shift);
        }
      }

      DataTable dvF = new DataTable();
      dvF.Columns.Add("Inicio", typeof(System.DateTime));
      dvF.Columns.Add("Fin", typeof(System.DateTime));
      dvF.Columns.Add("Razon", typeof(System.String));
      dvF.Columns.Add("Categoria", typeof(System.String));
      dvF.Columns.Add("Minutes", typeof(System.Int32));

      foreach (DataRow row in dv.Rows)
      {
        dvF.Rows.Add(row.Field<DateTime>("Inicio"), row.Field<DateTime>("Fin"), row["Razon"], row["Categoria"], row["minutes"]);
      }

      dvF.Columns.Add("posmin", typeof(System.Int64));
      dvF.Columns.Add("posline", typeof(System.Int64));

      DateTime tod = DateTime.Now;

      if (tod < _seguidae)
      {
        dvF.Rows.Add(tod, _seguidae, "No yet", "No yet", (_seguidae - tod).TotalMinutes);
      }

      int dimensionpanel = Width;
      var minendia = 1440;

      double factorred = dimensionpanel / (double)minendia;

      long counter = 0;
      counter = _seguida.Ticks;


      foreach (DataRow fila in dvF.Rows)
      {
        DateTime datet = fila.Field<DateTime>("Inicio");
        TimeSpan posinicial = new TimeSpan(datet.Ticks - counter);
        DateTime datet2 = fila.Field<DateTime>("Fin");
        DateTime datet3 = fila.Field<DateTime>("Inicio");
        double duracion = (datet2 - datet3).TotalMinutes;


        fila["posmin"] = System.Convert.ToInt32(duracion * factorred);
        fila["posline"] = System.Convert.ToInt32(posinicial.TotalMinutes * factorred);
      }

      DataTable dt = dvF;

      //Looping and extracting each DataColumn to List<Object>    
      foreach (DataColumn dc in dt.Columns)
      {
        List<object> x = new List<object>();
        x = (from DataRow drr in dt.Rows select drr[dc.ColumnName]).ToList();
        iData.Add(x);
      }
      ViewBag.ChartData = iData;
      //Source data returned as JSON    
      return Json(iData, JsonRequestBehavior.AllowGet);
    }

