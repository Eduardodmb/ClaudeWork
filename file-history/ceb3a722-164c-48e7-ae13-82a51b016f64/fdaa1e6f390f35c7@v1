      DataTable dt_first = Firstronic.Framework.Queries.GetDatatableFromQuery(@"SELECT TOP 1 cast(@Seguidas as datetime) as TrnDate, PD_tbl_station_issues.IssueComments, PD_tbl_station_issues.IssueSolve, PD_tbl_station_issues.IssueSolution, PD_tbl_station_issues.Side,PD_tbl_station_issues.IssueSolveDate,PD_idt_issuestype.IssueType, PD_tbl_issue_ids.IssueDescription, CS_idt_partnumbers.PartNumber,DATEDIFF(MINUTE,cast(@Seguidas as datetime),isnull(IssueSolveDate,getdate())) as posmin1 FROM            PD_tbl_station_issues LEFT JOIN PD_idt_stations ON PD_tbl_station_issues.StationID = PD_idt_stations.StationID LEFT JOIN PD_idt_areas ON PD_idt_stations.AreaID = PD_idt_areas.AreaID LEFT JOIN PD_idt_issuestype ON PD_tbl_station_issues.IssueTypeID = PD_idt_issuestype.IssueTypeID LEFT JOIN PD_tbl_issue_ids ON PD_tbl_station_issues.IssueID = PD_tbl_issue_ids.IssueID LEFT JOIN CS_idt_partnumbers ON PD_tbl_station_issues.PartID = CS_idt_partnumbers.PartID WHERE PD_tbl_station_issues.StationID=@StationID AND PD_tbl_station_issues.Trndate < @Seguidas AND IssueSolveDate>@Seguidas and PD_idt_issuestype.Downtime=1 order by Trndate desc", parameters);

