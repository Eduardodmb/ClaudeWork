    public async Task<ActionResult> Index(int id = 0, int year = 0, int month = 0, int day = 0)
    {
      var model = new customreport_station();

      if (year == 0 || month == 0 || day == 0)
      {
        year = DateTime.Now.Year;
        month = DateTime.Now.Month;
        day = DateTime.Now.Day;
      }

      model.month = month;
      model.year = year;
      model.day = day;
      model.stationid = id;

      List<Task<HourOEE>> tasks = new List<Task<HourOEE>>();

      DateTime recordtime = new DateTime(year, month, day);

      for (int i = 6; i < 30; i++)
      {
        DateTime recordWithHour = recordtime.AddHours(+i);

        tasks.Add(Firstronic.Framework.APIs.Station.getHourOEEAsync(id, recordWithHour.Year, recordWithHour.Month, recordWithHour.Day, recordWithHour.Hour));
      }

      // Esperar a que todas las tareas se completen
      HourOEE[] responses = await Task.WhenAll(tasks);

      List<HourOEE> Items = new List<HourOEE>();

      foreach (HourOEE response in responses)
      {
        Items.Add(response);
      }

      model.Items = Items;

      return View(model);
    }


