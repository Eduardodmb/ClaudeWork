      dt_first.Merge(dt_middle);

      DataTable dt_fin = Firstronic.Framework.Queries.GetDatatableFromQuery(@"SELECT PD_tbl_station_issues.TrnDate, PD_tbl_station_issues.IssueComments, PD_tbl_station_issues.IssueSolve, PD_tbl_station_issues.IssueSolution, PD_tbl_station_issues.Side,cast(@SeguidaE as datetime) as IssueSolveDate, PD_idt_issuestype.IssueType, PD_tbl_issue_ids.IssueDescription,  CS_idt_partnumbers.PartNumber,DATEDIFF(MINUTE,TrnDate,cast(@SeguidaE as datetime)) as posmin1 FROM PD_tbl_station_issues LEFT JOIN PD_idt_stations ON PD_tbl_station_issues.StationID = PD_idt_stations.StationID LEFT JOIN PD_idt_areas ON PD_idt_stations.AreaID = PD_idt_areas.AreaID LEFT JOIN PD_idt_issuestype ON PD_tbl_station_issues.IssueTypeID = PD_idt_issuestype.IssueTypeID LEFT JOIN PD_tbl_issue_ids ON PD_tbl_station_issues.IssueID = PD_tbl_issue_ids.IssueID LEFT JOIN CS_idt_partnumbers ON PD_tbl_station_issues.PartID = CS_idt_partnumbers.PartID WHERE PD_tbl_station_issues.StationID=@StationID AND PD_tbl_station_issues.Trndate <@SeguidaE AND isnull(IssueSolveDate,getdate())>@SeguidaE and PD_idt_issuestype.Downtime=1 order by Trndate desc", parameters);

      dt_first.Merge(dt_fin);

      dt_first.Columns.Add("posmin", typeof(System.Int64));
      dt_first.Columns.Add("posline", typeof(System.Int64));

      DateTime tod = DateTime.Now;

      int dimensionpanel = Width;
