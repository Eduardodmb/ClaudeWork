      @*-------------------------------------------------------------------------------------------AREAS TCP----------*@
      <li aria-hidden="true">
        <div class="uk-grid">
          <div class="uk-width-1-1">
            <p class="request-info">
              TCP Connections per Area, allow define TCP/IP connections per area and side.
            </p>
          </div>
        </div>

        <div class="uk-width-1-1">
          @Html.AjaxGrid(Url.Action("GetAreasTCP", "PartNumber", new { id = Model.PartID }))
        </div>

        @{
          var arealistTCP = Firstronic.Framework.Functions.Dropdowns.GetAreasList(null, "", true);

          var clientorserverlistTCP = new List<SelectListItem>();
          var otcpa1 = new SelectListItem { Value = "CLIENT", Text = "CLIENT", Selected = true };
          clientorserverlistTCP.Add(otcpa1);
          var otcpa2 = new SelectListItem { Value = "SERVER", Text = "SERVER", Selected = false };
          clientorserverlistTCP.Add(otcpa2);
          var otcpa3 = new SelectListItem { Value = "ARDUINO", Text = "ARDUINO", Selected = false };
          clientorserverlistTCP.Add(otcpa3);

          var SlaveNumTCP = Firstronic.Framework.Functions.Queries.GetSelectedFromQuery(@"WITH contador AS ( SELECT 0 AS numero UNION ALL SELECT numero + 1 FROM contador WHERE numero < 10 ) SELECT case when numero = numero then numero else '' end as columna, numero FROM contador OPTION (MAXRECURSION 11)");
        }

        <div class="uk-grid mn-t-15">
          <div>
            <div class="p-0 input-group mb-3 mn-r-10">
              @Html.Label("Area", new { @class = "m-0 fs-14" })
              @Html.DropDownList("AreaID", (IEnumerable<SelectListItem>)arealistTCP, new { @class = "md-input", id = "ddlAreaIdAreasTCP" })
            </div>
          </div>
          <div>
            <div class="p-0 input-group mb-3 mn-r-10">
              @Html.Label("Side", new { @class = "m-0 fs-14" })
              @Html.DropDownListFor(model => model.Side,
                 new SelectList(new List<SelectListItem>
                 {
                       new SelectListItem { Text = "A", Value = "A" },
                       new SelectListItem { Text = "B", Value = "B" }
                 }, "Value", "Text"),
                 new { @class = "md-input", id = "intSideAreasTCP" })
            </div>
          </div>
          <div>
            <div class="p-0 input-group mb-3 mn-r-10">
              @Html.Label("IP 127.0.0.1", new { @class = "m-0 fs-14" })
              @Html.TextBox("IP", null, new { @class = "md-input", id = "intIPAreasTCP" })
            </div>
          </div>
          <div>
            <div class="p-0 input-group mb-3 mn-r-10">
              @Html.Label("PORT 50200", new { @class = "m-0 fs-14" })
              @Html.TextBox("Port", null, new { @class = "md-input", id = "intPortAreasTCP" })
            </div>
          </div>
          <div class="uk-width-1-3@m">
            <div class="input-group mb-3">
              @Html.Label("CLIENT OR SERVER", new { @class = "m-0 fs-14" })
              @Html.DropDownList("SERVER", (IEnumerable<SelectListItem>)clientorserverlistTCP, new { @class = "md-input", id = "intClientServerAreasTCP" })
            </div>
          </div>
          <div>
            <div class="p-0 input-group mb-3 mn-r-10">
              @Html.Label("TCP TYPE", new { @class = "m-0 fs-14" })
              @Html.DropDownList("TCP_TYPE", new List<SelectListItem>
              {
                    new SelectListItem { Text = "InSight Vision Cognex", Value = "InSight Vision Cognex", Selected = true }
              }, new { @class = "md-input", id = "intTcpTypeAreasTCP" })
            </div>
          </div>
          <div>
            <div class="p-0 input-group mb-3 mn-r-10">
              @Html.Label("SLAVE", new { @class = "m-0 fs-14" })
              @Html.DropDownList("numero", (IEnumerable<SelectListItem>)SlaveNumTCP, new { @class = "md-input", id = "intSlaveAreasTCP" })
            </div>
          </div>
          <div>
            <div class="p-0 input-group mb-3 mn-r-10">
              <input id="btnAddAreasTCP" type="button" value="Add" class="md-btn md-btn-primary md-btn-small" />
            </div>
          </div>
        </div>

        <script type="text/javascript" nonce="@Html.ScriptNonce()">
          $('#btnAddAreasTCP').click(function (e) {
            e.preventDefault();
            var v_PartId = $("#txtPartID").val();
            var v_AreaID = $("#ddlAreaIdAreasTCP").val();
            var v_Side = $("#intSideAreasTCP").val();
            var v_IP = $("#intIPAreasTCP").val();
            var v_Port = $("#intPortAreasTCP").val();
            var v_ClientServer = $("#intClientServerAreasTCP").val();
            var v_TcpType = $("#intTcpTypeAreasTCP").val();
            var v_Slave = $("#intSlaveAreasTCP").val();

            var req = { PartID: v_PartId, AreaID: v_AreaID, Side: v_Side, IP: v_IP, Port: v_Port, CLIENTORSERVER: v_ClientServer, TCPTYPE: v_TcpType, Slave: v_Slave };

            ajaxfncAreasTCP(req);
          });

          function updateAreasTCP() {
            var grid = new MvcGrid(document.querySelector('#mvcAreasTCP'));
            grid.requestType = 'post';
            grid.reload();
          };

          function ajaxfncAreasTCP(req) {
            $.ajax({
              type: "POST",
              url: "/Engineering/PartNumber/AddAreasTCP",
              async: false,
              contentType: "application/json; charset=utf-8",
              data: JSON.stringify(req),
              success: function () {
                updateAreasTCP();
              }
            })
          };

          $(document).on('click', '#mvcAreasTCP>table>tbody>tr>td>a.delRow', function (e) {
            e.preventDefault();
            var target = $(this).attr("href");

            $.ajax({
              type: "POST",
              url: target,
              async: false,
              contentType: "application/json; charset=utf-8",
              success: function () {
                updateAreasTCP();
              }
            })
          });
        </script>
      </li>

      @*-------------------------------------------------------------------------------------------SMB PATHS----------*@
    <li aria-hidden="true">
      <div class="uk-grid">
        <div class="uk-width-1-1">
          <p class="request-info">
            Configure SMB network paths for automated file monitoring per casilla. Each path configuration enables the production application to poll network folders for material data files (.txt, .csv, etc.) and automatically process incoming content.
          </p>
        </div>
      </div>

      @{
        var arealistSBM = Firstronic.Framework.Functions.Dropdowns.GetAreasList(null, "", true);

       }

      <div class="uk-grid mn-t-15">
        @Html.AjaxGrid(Url.Action("GetSMBPathsList", "PartNumber", new { id = Model.PartID }))
      </div>

      <div class="uk-grid mn-t-15">
        <div class="uk-width-1-1">
          <div class="uk-card uk-card-default uk-card-body uk-card-small">
            <h4 class="uk-card-title">Add SMB Path Configuration</h4>
            <div class="uk-grid-small" uk-grid>
              <div class="uk-width-1-4@m">
                <label class="uk-form-label">Area <span class="uk-text-danger">*</span></label>
                @Html.DropDownList("ddlSMBArea", (IEnumerable<SelectListItem>)arealistSBM, "-- Select Area --", new { @class = "uk-select" })
              </div>
              <div class="uk-width-1-6@m">
                <label class="uk-form-label">Side <span class="uk-text-danger">*</span></label>
                @Html.DropDownList("ddlSMBSide", new SelectList(new[] {
                  new { Value = "A", Text = "A" },
                  new { Value = "B", Text = "B" }
                }, "Value", "Text"), "-- Select --", new { @class = "uk-select" })
              </div>
              <div class="uk-width-1-3@m">
                <label class="uk-form-label">SMB Path <span class="uk-text-danger">*</span></label>
                @Html.TextBox("txtSMBPath", "", new { @class = "uk-input", placeholder = @"\\server\share\folder" })
              </div>
              <div class="uk-width-1-6@m">
                <label class="uk-form-label">File Pattern</label>
                @Html.TextBox("txtSMBFilePattern", "*.TXT", new { @class = "uk-input" })
              </div>
              <div class="uk-width-1-6@m">
                <label class="uk-form-label">Interval (ms)</label>
                @Html.TextBox("txtSMBInterval", "5000", new { @class = "uk-input", type = "number" })
              </div>
              <div class="uk-width-1-4@m">
                <label class="uk-form-label">SMB Type</label>
                @Html.DropDownList("ddlSMBType", new SelectList(new[] {
                  new { Value = "InSight Vision Cognex", Text = "InSight Vision Cognex" },
                  new { Value = "Material Data", Text = "Material Data" },
                  new { Value = "Serial Import", Text = "Serial Import" },
                  new { Value = "Custom", Text = "Custom" }
                }, "Value", "Text"), "-- Select Type --", new { @class = "uk-select" })
              </div>
              <div class="uk-width-1-6@m">
                <label class="uk-form-label">&nbsp;</label>
                <label><input id="chkSMBEnabled" type="checkbox" class="uk-checkbox" checked /> Enabled</label>
              </div>
            </div>

            <hr class="uk-divider-small" />
            <h5 class="uk-heading-line"><span>Network Credentials (Optional)</span></h5>
            <p class="uk-text-small uk-text-muted">Leave blank to use Windows authentication. Provide credentials only if accessing network share requires different user.</p>

            <div class="uk-grid-small" uk-grid>
              <div class="uk-width-1-3@m">
                <label class="uk-form-label">Domain</label>
                @Html.TextBox("txtSMBDomain", "", new { @class = "uk-input", placeholder = "DOMAIN or WORKGROUP" })
              </div>
              <div class="uk-width-1-3@m">
                <label class="uk-form-label">Username</label>
                @Html.TextBox("txtSMBUsername", "", new { @class = "uk-input", placeholder = "username or DOMAIN\\username" })
              </div>
              <div class="uk-width-1-3@m">
                <label class="uk-form-label">Password</label>
                @Html.Password("txtSMBPassword", "", new { @class = "uk-input", placeholder = "••••••••", autocomplete = "off" })
              </div>
            </div>

            <div class="uk-grid-small uk-margin-top" uk-grid>
              <div class="uk-width-1-1@m">
                <button id="btnAddSMBPath" type="button" class="uk-button uk-button-primary uk-button-small">
                  <span uk-icon="icon: plus"></span> Add SMB Path
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <script type="text/javascript" nonce="@Html.ScriptNonce()">
        $('#btnAddSMBPath').click(function (e) {
          e.preventDefault();

          var partId = $("#txtPartID").val();
          var areaId = $("#ddlSMBArea").val();
          var side = $("#ddlSMBSide").val();
          var smbPath = $("#txtSMBPath").val();
          var filePattern = $("#txtSMBFilePattern").val();
          var interval = $("#txtSMBInterval").val();
          var smbType = $("#ddlSMBType").val();
          var enabled = $("#chkSMBEnabled").is(':checked');
          var domain = $("#txtSMBDomain").val();
          var username = $("#txtSMBUsername").val();
          var password = $("#txtSMBPassword").val();

          if (!areaId || !side || !smbPath) {
            UIkit.modal.alert('Please fill in all required fields (Area, Side, SMB Path)');
            return false;
          }

          var req = {
            PartID: partId,
            AreaID: areaId,
            Side: side,
            SMB_PATH: smbPath,
            SMB_FILE_PATTERN: filePattern,
            SMB_READ_INTERVAL: interval,
            SMB_ENABLED: enabled,
            SMB_TYPE: smbType,
            SMB_DOMAIN: domain,
            SMB_USERNAME: username,
            SMB_PASSWORD: password
          };

          $.ajax({
            type: "POST",
            url: "/Engineering/PartNumber/AddSMBPath",
            async: false,
            contentType: "application/json; charset=utf-8",
            data: JSON.stringify(req),
            success: function () {
              updateSMBPathsList();
              $("#ddlSMBArea").val("");
              $("#ddlSMBSide").val("");
              $("#txtSMBPath").val("");
              $("#txtSMBFilePattern").val("*.TXT");
              $("#txtSMBInterval").val("5000");
              $("#ddlSMBType").val("");
              $("#chkSMBEnabled").prop('checked', true);
              $("#txtSMBDomain").val("");
              $("#txtSMBUsername").val("");
              $("#txtSMBPassword").val("");
            },
            error: function (xhr, status, error) {
              UIkit.modal.alert('Error adding SMB path: ' + error);
            }
          });
        });

        function updateSMBPathsList() {
          var grid = new MvcGrid(document.querySelector('#mvcSMBPathsList'));
          grid.requestType = 'post';
          grid.reload();
        };

        $(document).on('click', '#mvcSMBPathsList>table>tbody>tr>td>a.delRow', function (e) {
          e.preventDefault();
          var target = $(this).attr("href");

          $.ajax({
            type: "POST",
            url: target,
            async: false,
            contentType: "application/json; charset=utf-8",
            success: function () {
              updateSMBPathsList();
            }
          })
        });
      </script>
    </li>

      @*-------------------------------------------------------------------------------------------LASER SKIP----------*@
      <li aria-hidden="true">
        <div class="uk-grid">
          <div class="uk-width-1-1">
            <p class="request-info">
              Configure laser serialization skip logic. When enabled, allows units to bypass laser marking operations under specific conditions (rework, pre-serialized components, customer-supplied serials).
            </p>
          </div>
        </div>

        <div class="uk-grid mn-t-15">
          @Html.AjaxGrid(Url.Action("GetLaserSkip", "PartNumber", new { id = Model.PartID }))
        </div>

        <div class="uk-grid mn-t-15">
          <div>
            <div class="p-0 input-group mb-3 mn-r-10">
              <input id="btnAddLaserSkip" type="button" value="Add" class="md-btn md-btn-primary md-btn-small" />
            </div>
          </div>
        </div>

        <script type="text/javascript" nonce="@Html.ScriptNonce()">
          $('#btnAddLaserSkip').click(function (e) {
            e.preventDefault();
            var v_PartId = $("#txtPartID").val();

            if (v_PartId == '' || v_PartId == 0) {
              UIkit.modal.alert('Part ID is required');
              return false;
            }

            var url = '@Url.Action("AddLaserSkip", "PartNumber")';
            $.ajax({
              data: { PartID: v_PartId },
              type: "POST",
              url: url,
              async: false,
              contentType: "application/json; charset=utf-8",
              success: function (data) {
                updateLaserSkip();
              },
              error: function () {
                UIkit.modal.alert('Error adding laser skip configuration');
              }
            });
          });

          function updateLaserSkip() {
            new MvcGrid(document.querySelector('#mvcLaserSkip')).reload();
          }

          $(document).on('click', '#mvcLaserSkip>table>tbody>tr>td>a.delRow', function (e) {
            e.preventDefault();
            var target = $(this).attr('href');
            UIkit.modal.confirm('Are you sure you want to delete this configuration?', function () {
              $.ajax({
                type: "POST",
                url: target,
                async: false,
                contentType: "application/json; charset=utf-8",
                success: function () {
                  updateLaserSkip();
                }
              })
            });
          });
        </script>
      </li>
    </ul>

