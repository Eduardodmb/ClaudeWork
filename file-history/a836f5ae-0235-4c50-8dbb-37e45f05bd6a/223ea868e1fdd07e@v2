    public ActionResult Failures_Report(DateTime? stardate, DateTime? enddate, bool execute = false)
    {

      DateTime stardate2 = DateTime.Now.Date;
      DateTime enddate2 = DateTime.Now.Date;

      if (stardate != null)
      {
        stardate2 = stardate ?? DateTime.Now.Date;
      }

      if (enddate != null)
      {
        enddate2 = enddate ?? DateTime.Now.Date;
      }

      var model = new Failures_Report();

      model.stardate = stardate2.AddHours(+6);

      model.enddate = enddate2.AddHours(+6).AddDays(+1);

      model.execute = execute;


      return View("Failures_Report", model);
    }

