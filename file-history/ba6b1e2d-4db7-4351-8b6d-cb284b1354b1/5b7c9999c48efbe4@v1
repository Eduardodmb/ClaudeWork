    Private Sub btnManual_Click(sender As Object, e As EventArgs) Handles btnManual.Click
        loadEmptyTable()
        CurrentIndex = 0

        Dim contador As Integer = ExFunctions.getMergeCounter(ExData.Selected_Area.Selected_Casilla.PartID)
        Dim dt = DateTime.Now
        Dim jDate = String.Format("{0}{1}", dt.ToString("yy"), dt.DayOfYear.ToString("000"))
        ExData.parenssn = ExData.Selected_Area.Selected_Casilla.PartNumber.Substring(3, 5) & "-" & jDate & contador.ToString("00000")

        If txtParent.Text.Length > 0 Then
            Dim childParentVarcharParameter() As SqlParameter = New SqlParameter() _
                        {
                            New SqlParameter("@Parente", SqlDbType.VarChar) With {.Value = txtParent.Text.Replace("'", "")}
                        }

            Dim dtparent As DataTable = BeConn.GetDt("SELECT [Parente]  FROM [PD_tbl_parents_smt] where parente =@Parente", childParentVarcharParameter)
            If dtparent.Rows.Count > 0 Then
                MsgBox("Parent duplicated")
                KeyenceReader.ExecCommand("LOFF", 2000)
                txtParent.Text = ""
                txtParent.Select()
                Exit Sub
            Else
                ExData.parenssn = txtParent.Text
            End If
        End If

        tblManual.Enabled = True

        CurrentIndex = 1
        lblNo.Text = CurrentIndex

        'painttable()

        txt_serial.Text = ""
        txt_serial.Select()

    End Sub


