        End If
    End Sub

    Private Sub btnaddm_Click(sender As Object, e As EventArgs) Handles btnaddm.Click
        Dim ssn As String = txt_serial.Text.Replace("'", "").ToUpper

        serialescazados = 0

        If chMoveParent.Checked Then
            Dim ssnVarcharParameter() As SqlParameter = New SqlParameter() _
                {
                    New SqlParameter("@SSN", SqlDbType.VarChar) With {.Value = ssn}
                }

            Dim dtParent As DataTable = BeConn.GetDt("SELECT [Parente] ,[Child] ,[Sort_No] FROM [PD_tbl_parents_smt] WHERE Child=@SSN", ssnVarcharParameter)

            If dtParent.Rows.Count > 0 Then
                ExData.parenssn = dtParent.Rows(0).Item("Parente")
                For Each rowChil As DataRow In dtParent.Rows
                    ExData.ChildsSerials.Rows.Add(rowChil.Item("Child"))
                    serialescazados = serialescazados + ExFunctions.getMergeQty(rowChil.Item("Child"), ExData.Selected_Area.Selected_Casilla.PartIdFormat)
                Next
            Else
                MsgBox("Panel no cazado")
            End If
        Else
            'Agregar a lista hasta acompletar cantidad de seriales
            Dim rows() = ExData.ChildsSerials.Select("`Child`='" & ssn & "'")
            If rows.Length = 0 Then
                Dim regex1 As Regex
                regex1 = New Regex(ExData.Selected_Area.Selected_Casilla.PartIdFormat)
                Dim match As Match = regex1.Match(ssn)
                If match.Success Then
                    If ExFunctions.getMergeQty(ssn, ExData.Selected_Area.Selected_Casilla.PartIdFormat) = 0 Then
                        ExData.ChildsSerials.Rows.Add(ssn)

                        Dim selected = dt_array.Select("ToIndex='" & CurrentIndex & "'")

                        If selected.Length > 0 Then
                            selected(0)("SSN") = ssn
                        End If

                        dt_array.AcceptChanges()

                        painttable()
                        CurrentIndex += 1
                    End If
                End If
            End If
        End If

        txt_serial.Text = ""
        txt_serial.Select()

        If ExData.ChildsSerials.Rows.Count = ExData.Selected_Area.Selected_Casilla.pzspanel Then
            tblManual.Enabled = False
            If serialescazados > 0 And chMoveParent.Checked = False Then
                ShowMSG(My.Resources.Messages.prod_serial_merge_ready3 & serialescazados & My.Resources.Messages.prod_serial_merge_ready4, My.Resources.Messages.prod_serial_merge_ready)
            ElseIf serialescazados = ExData.Selected_Area.Selected_Casilla.pzspanel And chMoveParent.Checked = True Then
                publicar()

            Else
                publicar()

            End If
        End If
    End Sub

