    Private Sub ReceivedDataWrite(receivedData As String)

        'tmrKeyence.Stop()

        If receivedData.Length > 10 Then

            Dim items = receivedData.Trim.Split(",")

            For Each item In items

                Dim parts = item.Split(":")

                If parts.Length = 3 Then

                    Dim ssn As String = parts(0)

                    Dim positionID As String = parts(1)

                    Dim MasterID As String = parts(2)

                    Dim selected = dt_array.Select("MasterID='" & MasterID & "' AND PositionID='" & positionID & "'")

                    If selected.Length > 0 Then

                        selected(0)("SSN") = ssn

                    End If

                    dt_array.AcceptChanges()

                End If
            Next
        End If
    End Sub

    Private Squares As List(Of SquareItem) = Nothing

    Private Class SquareItem
        Property Bounds As Rectangle
        Property Clicked As Boolean
        Property ClickedColor As Color
    End Class

    Public Sub loadEmptyTable()
        ExData.ChildsSerials.Clear()

        dt_array = BeConn.GetDt("SELECT [AutoID],[PartID],[MasterID],[PositionID],[ToIndex],'' as SSN,[Col],[Row] FROM [Part_Operation_Serialization_Array_Index]  WHERE PartID='" & ExData.Selected_Area.Selected_Casilla.PartID & "' Order by ToIndex ASC")

        dgvlist.DataSource = dt_array

        dgvlist.Columns("AutoID").Visible = False
        dgvlist.Columns("PartID").Visible = False
        dgvlist.Columns("MasterID").Visible = False
        dgvlist.Columns("PositionID").Visible = False
        dgvlist.Columns("Col").Visible = False
        dgvlist.Columns("Row").Visible = False

        Dim cols As Integer = BeConn.GetInteger("SELECT MAX(Col) FROM [Part_Operation_Serialization_Array_Index] WHERE PartID='" & ExData.Selected_Area.Selected_Casilla.PartID & "'")

        Dim Rows As Integer = BeConn.GetInteger("SELECT MAX(Row) FROM [Part_Operation_Serialization_Array_Index] WHERE PartID='" & ExData.Selected_Area.Selected_Casilla.PartID & "'")

        pnlLayer.Controls.Clear()

        Try
            Squares = New List(Of SquareItem)

            Dim SquareSpacing As Integer = 2

            Dim SquaresPerRow As Integer = cols

            Dim TotalRows = Rows

            Dim SquareEdgeLength As Integer = Math.Ceiling((pnlLayer.Width - (SquareSpacing * SquaresPerRow)) \ SquaresPerRow)

            Dim SquareEdgeLengthH As Integer = Math.Ceiling((pnlLayer.Height - (SquareSpacing * TotalRows)) \ TotalRows)

            If SquareEdgeLength > 0 And SquareEdgeLengthH > 0 Then

                Dim SquareSize As New Size(SquareEdgeLength, SquareEdgeLength)

                Dim RowPoint As Integer = 1

                Dim ColPoint As Integer = 1

                Dim itemno As Integer = 1

                For i As Integer = 1 To TotalRows

                    ColPoint = 1

                    For j As Integer = 1 To SquaresPerRow
                        Dim smlpanel As Panel = New Panel()

                        smlpanel.Width = SquareEdgeLength

                        smlpanel.Height = SquareEdgeLengthH

                        smlpanel.Location = New Point(ColPoint, RowPoint)

                        ColPoint = ColPoint + (SquareEdgeLength + SquareSpacing)

                        smlpanel.BackColor = Color.Gray

                        smlpanel.Margin = New Padding(0, 0, 0, 0)

                        smlpanel.Name = "arrayUnit_" & i & "_" & j

                        Dim toIndex As String = ""

                        Dim selected = dt_array.Select("Row='" & i & "' AND Col='" & j & "'")

                        If selected.Length > 0 Then
                            toIndex = selected(0)("ToIndex").ToString()

                            If toIndex = 1 Then
                                smlpanel.BackColor = Color.Yellow
                            End If
                        End If

                        'Agregar texto de orden

                        Dim smltexto As Label = New Label

                        smltexto.Dock = DockStyle.None
                        smltexto.Anchor = AnchorStyles.None

                        smltexto.ForeColor = Color.White

                        smltexto.Font = New Font("Segoe UI", smlpanel.Height - 4, FontStyle.Regular)

                        smltexto.Text = toIndex

                        smlpanel.Controls.Add(smltexto)

                        pnlLayer.Controls.Add(smlpanel)

                        itemno += 1
                    Next

                    RowPoint += (SquareEdgeLengthH + SquareSpacing)
                Next
            End If
        Catch ex As Exception

        End Try


    End Sub

