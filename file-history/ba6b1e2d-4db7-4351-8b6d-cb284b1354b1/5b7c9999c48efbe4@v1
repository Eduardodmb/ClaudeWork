    Private Function getAllFilesInSrFolder(ByVal reader As ReaderAccessor, ByVal srcFolder As String) As List(Of String)
        Dim fileList As List(Of String) = reader.GetFileList(srcFolder)
        Return fileList
    End Function

    Private Sub frm_merge_mergefull_Load(sender As Object, e As EventArgs) Handles MyBase.Load
        loadEmptyTable()

        shiftall = GetShift(DateTime.Now())


        If My.Computer.Network.Ping("192.168.100.100", 100) Then



            Dim path_master As String = "\\" & ExData.SERVERFILESIP & "\BeFirstData\scanconfig\" & ExData.Selected_Area.Selected_Casilla.PartNumber.Substring(3, 5) & "\MASTER\CONFIG8.PTC"

            Dim path_slave As String = "\\" & ExData.SERVERFILESIP & "\BeFirstData\scanconfig\" & ExData.Selected_Area.Selected_Casilla.PartNumber.Substring(3, 5) & "\SLAVE\CONFIG8.PTC"

            If My.Computer.Network.Ping("192.168.100.100", 100) Then
                KeyenceReader = New ReaderAccessor("192.168.100.100")
                'KeyenceReader.IpAddress = "192.168.100.100"

                Try
                    'Dim reader As ReaderAccessor = New ReaderAccessor("192.168.100.100")
                    KeyenceReader.OpenFtp()

                    If IO.File.Exists(path_master) Then
                        KeyenceReader.ExecCommand("BLOAD")
                        Thread.Sleep(1000)

                        Dim fileList As List(Of String) = getAllFilesInSrFolder(KeyenceReader, "CONFIG")
                        MsgBox("Loading..." & path_master & vbNewLine & String.Join(",", fileList))

                        KeyenceReader.PutFile(path_master, "CONFIG\CONFIG8.PTC")
                        Thread.Sleep(1000)
                        KeyenceReader.ExecCommand("BLOAD,8")
                    Else
                        MsgBox(My.Resources.Messages.Keyence_SetupNotExist)
                    End If

                    KeyenceReader.CloseFtp()
                Catch ex As Exception
                    MsgBox(ex.ToString())
                End Try

                KeyenceReader.Connect(AddressOf ReceivedDataAction)
            Else
                MsgBox("No PING")
            End If

            If My.Computer.Network.Ping("192.168.100.101", 100) Then
                KeyenceReader101 = New ReaderAccessor("192.168.100.101")
                'KeyenceReader101.IpAddress = "192.168.100.101"
                Try
                    KeyenceReader101.OpenFtp()

                    If IO.File.Exists(path_slave) Then
                        KeyenceReader101.ExecCommand("BLOAD")
                        Thread.Sleep(1000)

                        Dim fileList As List(Of String) = getAllFilesInSrFolder(KeyenceReader101, "CONFIG")
                        MsgBox("Loading..." & path_master & vbNewLine & String.Join(",", fileList))

                        KeyenceReader101.PutFile(path_slave, "CONFIG\CONFIG8.PTC")
                        Thread.Sleep(1000)
                        KeyenceReader101.ExecCommand("BLOAD,8")
                    Else
                        MsgBox(My.Resources.Messages.Keyence_SetupNotExist)
                    End If
                    KeyenceReader101.CloseFtp()
                Catch ex As Exception
                    MsgBox(ex.ToString())
                End Try
            Else
                MsgBox("No PING")
            End If

            Try
                Try
                    liveviewForm1.EndReceive()
                    'Set ip address of liveview.
                    liveviewForm1.IpAddress = "192.168.100.100"

                    'Start liveview.
                    liveviewForm1.BeginReceive()
                Catch ex2 As Exception

                End Try

            Catch ex As Exception

            End Try
        Else

        End If

    End Sub

