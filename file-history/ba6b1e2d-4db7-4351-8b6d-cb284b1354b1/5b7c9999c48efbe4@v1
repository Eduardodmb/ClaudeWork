    Dim serialescazados As Integer = 0

    Private Sub TgrBtn_Click(sender As Object, e As EventArgs) Handles TgrBtn.Click
        loadEmptyTable()

        ReceivedDataWrite(KeyenceReader.ExecCommand("LON", 2000))

        dgvlist.DataSource = dt_array

        'Check if all serial numbers are ready. 
        Dim selected = dt_array.Select("SSN=''")

        If selected.Length > 0 Then
            'Marcar errror

            MsgBox("Escaneo incompleto, realizar manual.")

            btnManual.PerformClick()

        Else
            'Enviar a Merge.... 
            '

            Dim contador As Integer = ExFunctions.getMergeCounter(ExData.Selected_Area.Selected_Casilla.PartID)
            Dim dt = DateTime.Now
            Dim jDate = String.Format("{0}{1}", dt.ToString("yy"), dt.DayOfYear.ToString("000"))
            ExData.parenssn = ExData.Selected_Area.Selected_Casilla.PartNumber.Substring(3, 5) & "-" & jDate & contador.ToString("00000")

            If txtParent.Text.Length > 0 Then
                Dim childParentVarcharParameter() As SqlParameter = New SqlParameter() _
                        {
                            New SqlParameter("@Parente", SqlDbType.VarChar) With {.Value = txtParent.Text.Replace("'", "")}
                        }

                Dim dtparent As DataTable = BeConn.GetDt("SELECT [Parente]  FROM [PD_tbl_parents_smt] where parente =@Parente", childParentVarcharParameter)
                If dtparent.Rows.Count > 0 Then
                    MsgBox("Parent duplicated")
                    KeyenceReader.ExecCommand("LOFF", 2000)
                    txtParent.Text = ""
                    txtParent.Select()
                    Exit Sub
                Else
                    ExData.parenssn = txtParent.Text
                End If
            End If

            serialescazados = 0

            'Revisar duplicados
            For Each item As DataRow In dt_array.Rows
                Dim ssn As String = item.Item("SSN")

                Dim regex1 As Regex
                regex1 = New Regex(ExData.Selected_Area.Selected_Casilla.PartIdFormat)
                Dim match As Match = regex1.Match(ssn)
                If match.Success Then
                    ExData.ChildsSerials.Rows.Add(ssn)

                    serialescazados += ExFunctions.getMergeQty(ssn, ExData.Selected_Area.Selected_Casilla.PartIdFormat)
                End If
            Next

            CheckPaintTable()

            If ExData.ChildsSerials.Rows.Count = ExData.Selected_Area.Selected_Casilla.pzspanel Then
                If serialescazados > 0 And chMoveParent.Checked = False Then
                    ShowMSG(My.Resources.Messages.prod_serial_merge_ready3 & serialescazados & My.Resources.Messages.prod_serial_merge_ready4, My.Resources.Messages.prod_serial_merge_ready)
                ElseIf serialescazados = ExData.Selected_Area.Selected_Casilla.pzspanel And chMoveParent.Checked = True Then
                    publicar()
                Else
                    publicar()
                End If
            End If
        End If

        KeyenceReader.ExecCommand("LOFF", 2000)

    End Sub

