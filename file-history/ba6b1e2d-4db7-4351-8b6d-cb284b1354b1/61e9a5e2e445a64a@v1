                                        End Try

                                    End Try


                                Next

                            Catch ex As Exception
                                WriteToFile($"Error: {ex.ToString}")
                            End Try

                        End If
                    Next
                End If
            Catch ex2 As Exception

            End Try
        Catch ex As Exception
            WriteToFile(strServiceName & " Service Error on: {0} " + ex.ToString + ex.StackTrace)
        End Try


        WriteToFile("END:" & DateTime.Now.ToString)

        Try
            If executeCorrectly = 3 Then
                BeAgent.Active("Execute End")
            ElseIf executeCorrectly = 4 Then
                BeAgent.Caution(executeMessage)
            Else
                BeAgent.Serious(executeMessage)
            End If
        Catch ex As Exception
            WriteToFile(ex.ToString)
        End Try


        Return Result
    End Function

