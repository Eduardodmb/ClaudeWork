                            }
                        }
                        else
                        {
                            throw new InvalidOperationException("Child is under defective status: " + child);
                        }
                    }
                    else
                    {
                        if (child.Length > 5)
                        {
                            throw new InvalidOperationException("Child without part/Serial sin numero de parte: " + child);
                        }
                    }
                }

                // Load Subassebly or Validate Datatable is fully.

                bool isComplete = false;
                bool templateIsComplete = true;

                foreach (var rowItem in dt_ToMerge)
                {
                    if (rowItem.Child_SSN.ToString() == "" || (int)rowItem.Child_Quantity > 0)
                    {
                        templateIsComplete = false;
                    }
                }

                isComplete = templateIsComplete;

                if (isComplete == true)
                {
                    //Add to Linkage Table
                    foreach (var rowItem in dt_ToMerge)
                    {
                        if (rowItem.Child_SSN.ToString() != "NO REQUIRED")
