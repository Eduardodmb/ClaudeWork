                                                                            .OrderByDescending(p => p.TrnDate)
                                                                            .Select(p => (int?)Convert.ToInt32(p.Ssn))
                                                                            .ToListAsync();


                                        if (dtHaveConversionBefore.Count() > 0)
                                        {
                                            tempn_conversion = dtHaveConversionBefore.FirstOrDefault().ToString();
                                        }
                                        else
                                        {

                                            dtHaveConversionBefore = await _context.PartUnitsConvertions
                                                                        .Where(p => p.Ssn == ssnChild)
                                                                        .OrderByDescending(p => p.TrnDate)
                                                                        .Select(p => (int?)Convert.ToInt32(p.ChildSsn))
                                                                        .ToListAsync();

                                            if (dtHaveConversionBefore.Count() > 0)
                                            {
                                                tempn_conversion = dtHaveConversionBefore.FirstOrDefault().ToString();
                                            }
                                        }
                                    }
                                }

                                List<UnitsHistory> History = new List<UnitsHistory>();

                                var useAPIS = await _context.Settings
                                   .Where(x => x.Description == "Production_Use_APIS")
                                   .Select(x => x.Result)
                                   .FirstOrDefaultAsync();

                                if (useAPIS != null && useAPIS == "1")
                                {
                                    History.AddRange(await GetUnitResultHistory(ssnChild, "", "", "", ""));
                                    if (ssnChild != tempn_conversion)
                                    {
                                        History.AddRange(await GetUnitResultHistory(tempn_conversion, "", "", "", ""));
                                    }

                                    if (Check_Other_Site != "")
                                    {
                                        History.AddRange(await GetUnitResultHistorySiteAsync(Check_Other_Site, ssnChild, "", "", "", ""));
                                        if (ssnChild != tempn_conversion)
                                        {
                                            History.AddRange(await GetUnitResultHistorySiteAsync(Check_Other_Site, tempn_conversion, "", "", "", ""));
                                        }
                                    }

                                    History = History.OrderByDescending(h => h.TrnDate).ToList();

                                    // 0.1 Check if more that scan allowed
                                    if (dtMaxScans.Count() > 0)
                                    {

                                        var AreaName = await _context.PartOperationAreas
                                                        .Where(x => x.AreaId == AreaID)
                                                        .Select(x => x.Area).FirstOrDefaultAsync();

                                        var trackingArea = History.Where(step => step.Area == AreaName && step.Side == Side)
                                                            .OrderByDescending(step => step.TrnDate)
                                                            .ToArray();

                                        var maxScans = dtMaxScans.Where(row => row.AreaID == AreaID && row.Side == Side)
                                                            .ToArray();

                                        int maxScansQuantity = 5;

                                        if (maxScans.Length > 0)
                                        {
                                            maxScansQuantity = maxScans.FirstOrDefault().Quantity.Value;

                                            if (trackingArea.Length > maxScansQuantity)
                                            {
                                                insertTracking = false;
                                                messageerror = "Maximum quantity exceded by Area. SCRAP UNIT. Maximo de pruebas alcanzado, llamar a CFT si hay dudas. SCRAPEAR UNIDAD";
                                            }
                                        }
                                    }

                                    // 0.2 Check if more that scan allowed Per PART
                                    if (dtMaxScansByPart.Count() > 0)
                                    {

                                        var AreaName = await _context.PartOperationAreas
                                                        .Where(x => x.AreaId == AreaID)
                                                        .Select(x => x.Area).FirstOrDefaultAsync();

                                        var trackingArea = History.Where(step => step.Area == AreaName && step.Side == Side)
                                                                        .OrderByDescending(step => step.TrnDate)
                                                                        .ToArray();

                                        var maxScans = dtMaxScansByPart.Where(row => row.AreaID == AreaID && row.Side == Side).ToArray();


                                        int maxScansQuantity = 5;

                                        if (maxScans.Length > 0)
                                        {
                                            maxScansQuantity = maxScans.FirstOrDefault().Quantity.Value;

                                            if (trackingArea.Length > maxScansQuantity)
                                            {
                                                insertTracking = false;
                                                messageerror = "Maximum quantity exceded by Part. Call CFT.";
                                            }
                                        }
                                    }

                                    //0 - Check if units is locked due failure in process   allowFailuresInArea
                                    if (insertTracking)
                                    {
                                        if (History.Count > 0)
                                        {
                                            if (History[0].IsGood == false)
                                            {
                                                if (allowFailuresInArea > 0)
                                                {
                                                    var AreaName = await _context.PartOperationAreas
                                                         .Where(x => x.AreaId == AreaID)
                                                         .Select(x => x.Area).FirstOrDefaultAsync();

                                                    int countBadItems = History.Where(step => step.IsGood == false && step.Area == AreaName && step.Side == Side)
                                                                                    .Count();

                                                    if (countBadItems < allowFailuresInArea)
                                                    {

                                                    }
                                                    else
                                                    {
                                                        insertTracking = false;
                                                        messageerror = "Maximum bad quantity exceded.";
                                                    }
                                                }
                                                else
                                                {
                                                    insertTracking = false;
                                                    messageerror = "Bad Unit!";
                                                }
                                            }
                                        }
                                    }

                                    //1 - Custom Areas Validations
                                    if (insertTracking)
                                    {
                                        if (dtAreastoReview.Count() > 0)
                                        {
                                            foreach (var rowArea in dtAreastoReview)
                                            {
                                                bool pasaprueba = false;

                                                bool pasaFCTafterRework = true;

                                                var AreaName = await _context.PartOperationAreas
                                                                .Where(x => x.AreaId == rowArea.AreaID)
                                                                .Select(x => x.Area).FirstOrDefaultAsync();

                                                if (AreaName == "FCT")
                                                {
                                                    pasaFCTafterRework = false;

                                                    List<UnitsHistory> results = History
                                                        .Where(h => h.Area == AreaName || h.Area == "Retrabajo")
                                                        .OrderByDescending(h => h.TrnDate).ToList();

                                                    if (results.Count > 0)
                                                    {
                                                        if (results[0].Area == AreaName)
                                                        {
                                                            pasaFCTafterRework = true;
                                                        }
                                                    }
                                                }

                                                if (pasaFCTafterRework)
                                                {

                                                    List<UnitsHistory> results = History
                                                                                .Where(h => h.Area == AreaName && h.Side == rowArea.Side)
                                                                                .OrderByDescending(h => h.TrnDate).ToList();

                                                    if (results.Count > 0)
                                                    {
                                                        if (results[0].IsGood == true)
                                                        {
                                                            pasaprueba = true;
                                                        }
                                                        else
                                                        {
                                                            pasaprueba = false;
                                                            messageerror = "Last record is BAD for area " + AreaName + " side " + rowArea.Side.ToString();
                                                        }
                                                    }
                                                    else
                                                    {
                                                        pasaprueba = false;
                                                        messageerror = "Missing " + AreaName + " side " + rowArea.Side.ToString();
                                                    }

                                                }

                                                if (pasaprueba == false)
                                                {
                                                    insertTracking = false;
                                                }
                                            }
                                        }
                                    }

                                    //2 - CHECK AOI RESULTS
                                    if (insertTracking)
                                    {
                                        if (dtAreasToReveiwAOI.Count() > 0)
                                        {

                                            foreach (var rowArea in dtAreasToReveiwAOI)
                                            {
                                                bool pasaprueba = false;

                                                // INTERPLANT: TODO

                                                var resultAOI = await AOIGetAsync(ssnChild, int.Parse(rowArea.AreaID.ToString()), rowArea.Side.ToString());

                                                if (resultAOI == null)
                                                {
                                                    pasaprueba = false;
                                                }
                                                else
                                                {
                                                    ResponseUnits unitAOI = resultAOI;

                                                    if (unitAOI.IsGood)
                                                    {
                                                        pasaprueba = true;
                                                    }
                                                    else
                                                    {
                                                        pasaprueba = false;
                                                    }
                                                }

                                                if (pasaprueba)
                                                {

                                                }
                                                else
                                                {
                                                    insertTracking = false;
                                                    messageMissingAOI++;
                                                    messageerror = "Missing AOI inspection.";
                                                }
                                            }
                                        }
                                    }

                                    //3 - Check If Ignoer after failure
                                    if (insertTracking)
                                    {


                                    }

                                    //4 - Check if units is locked by QA
                                    if (insertTracking)
                                    {
                                        // INTERPLANT: TODO

                                        var dtLocked = await _context.PartUnitsFaileds
                                                                    .Where(p => p.Ssn == ssnChild || p.Ssn == tempn_conversion)
                                                                    .Select(p => p.Ssn)
                                                                    .ToListAsync();

                                        if (dtLocked.Count() > 0)
                                        {
                                            if (dtLocked.Count() > allowFailuresInArea)
                                            {
                                                insertTracking = false;
                                                messageRework++;
                                                messageerror = "Unit locked until Rework.";
                                            }
                                        }
                                    }

                                    //5 Check if units is rework and not QA...
                                    if (insertTracking)
                                    {
                                        var req_rework_threesteps = await _context.Settings
                                               .Where(x => x.Description == "Rework_in_three_steps")
                                               .Select(x => x.Result)
                                               .FirstOrDefaultAsync();

                                        if (req_rework_threesteps != null && req_rework_threesteps == "1")
                                        {
                                            List<UnitsHistory> results = History
                                                        .Where(h => h.Area == "Retrabajo" || h.Area == "Diagnostico" || h.Area == "Retouch area")
                                                        .OrderByDescending(h => h.TrnDate).ToList();

                                            if (results.Count > 0)
                                            {
                                                if (results[0].Area == "Retrabajo" || results[0].Area == "Diagnostico")
                                                {
                                                    insertTracking = false;
                                                    messageRework++;
                                                    messageerror = "Unit locked until Rework.";
                                                }
                                            }
                                        }
                                    }



                                }
                                else
                                {
                                    // 0 - Max Scan in same area

                                    List<DtSteps> dtSteps = new List<DtSteps>();

                                    if (dtMaxScans.Count() > 0 || dtMaxScansByPart.Count() > 0 || dtAreastoReview.Count() > 0)
                                    {


                                        dtSteps = await _context.PdTblUnitsTrackings
                                            .AsNoTracking()
                                            .Where(p => (p.Ssn == ssnChild || p.Ssn == tempn_conversion) && p.PartId == PartID)
                                            .OrderByDescending(p => p.TrnDate)
                                            .Select(p => new DtSteps
                                            {
                                                IsGood = p.IsGood,
                                                AreaId = p.AreaId,
                                                TrnDate = p.TrnDate,
                                                Side = p.JobSide
                                            })
                                            .ToListAsync();

                                    }

                                    // 0.1 Check if more that scan allowed Per AREA
                                    if (dtMaxScans.Count() > 0)
                                    {
                                        var trackingArea = dtSteps.Where(step => step.AreaId == AreaID && step.Side == Side)
                                                            .OrderByDescending(step => step.TrnDate)
                                                            .ToArray();

                                        var maxScans = dtMaxScans.Where(row => row.AreaID == AreaID && row.Side == Side)
                                                            .ToArray();

                                        int maxScansQuantity = 5;

                                        if (maxScans.Length > 0)
                                        {
                                            maxScansQuantity = maxScans.FirstOrDefault().Quantity.Value;

                                            if (trackingArea.Length > maxScansQuantity)
                                            {
                                                insertTracking = false;
                                                messageerror = "Maximum quantity exceded by Area. SCRAP UNIT. Maximo de pruebas alcanzado, llamar a CFT si hay dudas. SCRAPEAR UNIDAD";
                                            }
                                        }
                                    }

                                    // 0.2 Check if more that scan allowed Per PART
                                    if (dtMaxScansByPart.Count() > 0)
                                    {
                                        var trackingArea = dtSteps.Where(step => step.AreaId == AreaID && step.Side == Side)
                                                                        .OrderByDescending(step => step.TrnDate)
                                                                        .ToArray();

                                        var maxScans = dtMaxScansByPart.Where(row => row.AreaID == AreaID && row.Side == Side).ToArray();


                                        int maxScansQuantity = 5;

                                        if (maxScans.Length > 0)
                                        {
                                            maxScansQuantity = maxScans.FirstOrDefault().Quantity.Value;

                                            if (trackingArea.Length > maxScansQuantity)
                                            {
                                                insertTracking = false;
                                                messageerror = "Maximum quantity exceded by Part. Call CFT.";
                                            }
                                        }
                                    }

                                    //0 - Check if units is locked due failure in process

                                    // 1 - Custom Areas Validations
                                    if (insertTracking)
                                    {
                                        if (dtAreastoReview.Count() > 0)
                                        {
                                            foreach (var rowArea in dtAreastoReview)
                                            {
                                                bool recordIsOK = false;

                                                var trackingArea = dtSteps.Where(step => step.AreaId == AreaID && step.Side == Side)
                                                                            .OrderByDescending(step => step.TrnDate)
                                                                            .ToArray();

                                                //SqlParameter[] getAreaParameters = new SqlParameter[]{
                                                //    new SqlParameter("@AreaID",SqlDbType.Int){Value =rowArea["AreaID"].ToString()}
                                                //};

                                                if (trackingArea.Length > 0)
                                                {
                                                    if (bool.Parse(trackingArea.FirstOrDefault().IsGood.ToString()))
                                                    {
                                                        recordIsOK = true;
                                                    }
                                                    else
                                                    {
                                                        string areaName = await _context.PartOperationAreas
                                                                                .Where(a => a.AreaId == rowArea.AreaID)
                                                                                .Select(a => a.Area)
                                                                                .FirstOrDefaultAsync();

                                                        recordIsOK = false;
                                                        messageerror = "Last record is BAD for area " + areaName + " side " + rowArea.Side.ToString();


