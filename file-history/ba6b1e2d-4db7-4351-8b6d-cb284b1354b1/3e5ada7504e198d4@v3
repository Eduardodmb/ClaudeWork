                                            values.Child_Quantity = (int)values.Child_Quantity - 1;


                                            var selectbines2 = dt_ToMerge.Where(item => item.Child_PartID == values.Child_PartID);

                                            foreach (var values2 in selectbines2)
                                            {
                                                if (values2.Child_SSN.ToString() == "")
                                                {
                                                    values2.Child_SSN = "NO REQUIRED";
                                                    values2.Child_Quantity = (int)values2.Child_Quantity - 1;
                                                }


                                            }
                                        }
                                        else if ((int)values.Child_Quantity > 1)
                                        {
                                            if (values.Child_SSN.ToString() == "")
                                            {
                                                values.Child_SSN = child;
                                            }
                                            else
                                            {
                                                values.Child_SSN = values.Child_SSN + ";" + child;
                                            }

                                            values.Child_Quantity = (int)values.Child_Quantity - 1;

                                        }

                                        break;
                                    }
                                    else
                                    {
                                        // Nothing to do. 
                                    }
                                }
                            }

                            if (pass == false)
                            {
                                string Part_No = "";

                                Part_No = await _context.Parts
                                                        .Where(cs => cs.PartId == getPartID)
