# Create Symbolic Links - Simplified Version
# Run as Administrator for best results

$vaultPath = "C:\Users\emarquez\OneDrive\16 - Obsidian\00_Claude"
$claudePath = "C:\Users\emarquez\.claude"

Write-Host ""
Write-Host "==================================================" -ForegroundColor Cyan
Write-Host "  Claude Context Vault - Link Setup" -ForegroundColor Cyan
Write-Host "==================================================" -ForegroundColor Cyan
Write-Host ""

# Check admin
$isAdmin = ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
if (-not $isAdmin) {
    Write-Host "WARNING: Not running as Administrator" -ForegroundColor Yellow
    Write-Host "         Using junctions instead of symlinks" -ForegroundColor Yellow
    Write-Host ""
}

# Verify paths exist
if (-not (Test-Path $claudePath)) {
    Write-Host "ERROR: Claude directory not found: $claudePath" -ForegroundColor Red
    Write-Host "       Install Claude Code first." -ForegroundColor Red
    Write-Host ""
    exit 1
}

if (-not (Test-Path $vaultPath)) {
    Write-Host "ERROR: Vault directory not found: $vaultPath" -ForegroundColor Red
    Write-Host "       Wait for OneDrive sync." -ForegroundColor Red
    Write-Host ""
    exit 1
}

Write-Host "Creating links..." -ForegroundColor Green
Write-Host ""

# Link 1: CLAUDE.md
$source1 = "$claudePath\CLAUDE.md"
$target1 = "$vaultPath\01-Personal-Context\CLAUDE.md"

Write-Host "• CLAUDE.md: " -NoNewline
if (Test-Path $target1) {
    Write-Host "Already exists" -ForegroundColor Yellow
} elseif (-not (Test-Path $source1)) {
    Write-Host "Source not found" -ForegroundColor Red
} else {
    if ($isAdmin) {
        New-Item -ItemType SymbolicLink -Path $target1 -Target $source1 -Force | Out-Null
        Write-Host "Created (symlink)" -ForegroundColor Green
    } else {
        Copy-Item -Path $source1 -Destination $target1 -Force
        Write-Host "Copied (no admin)" -ForegroundColor Yellow
    }
}

# Link 2: Learning directory
$source2 = "$claudePath\learning"
$target2 = "$vaultPath\02-Learnings\_claude-learning"

Write-Host "• Learning: " -NoNewline
if (Test-Path $target2) {
    Write-Host "Already exists" -ForegroundColor Yellow
} elseif (-not (Test-Path $source2)) {
    Write-Host "Source not found" -ForegroundColor Red
} else {
    if ($isAdmin) {
        New-Item -ItemType SymbolicLink -Path $target2 -Target $source2 -Force | Out-Null
        Write-Host "Created (symlink)" -ForegroundColor Green
    } else {
        cmd /c mklink /J "$target2" "$source2" 2>&1 | Out-Null
        if ($LASTEXITCODE -eq 0) {
            Write-Host "Created (junction)" -ForegroundColor Green
        } else {
            Write-Host "Failed" -ForegroundColor Red
        }
    }
}

