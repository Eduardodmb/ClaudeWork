    [HttpPost]
    [ValidateAntiForgeryToken]
    [Authorize(Roles = "BF Administrator")]
    [MultipleButtonAction(Name = "action", Argument = "Delete")]
    public ActionResult Delete(tbl_COMMON_CUSTOMER_FULL model)
    {
      if (ModelState.IsValid)
      {
        SqlParameter[] parameters = new SqlParameter[]{
          new SqlParameter("@Id", SqlDbType.Int){ Value = model.Customer_No }
        };

        var record = db.Database.SqlQuery<tbl_COMMON_CUSTOMER>(@"
          SELECT * FROM COMMON_CUSTOMER WHERE Customer_No = @Id
        ", parameters).FirstOrDefault();

        if (record == null)
        {
          this.NotifyError("Customer not found.");
          return RedirectToAction("Index");
        }

        try
        {
          Firstronic.Framework.Queries.ExecuteQuery("DELETE FROM COMMON_CUSTOMER WHERE Customer_No = @Id", parameters);
          this.NotifySuccess("Customer deleted successfully.");
        }
        catch (Exception ex)
        {
          this.NotifyError("Error: " + ex.Message);
        }
      }
      return RedirectToAction("Index");
    }
    protected override void Dispose(bool disposing)
    {
      if (disposing) db.Dispose();
      base.Dispose(disposing);
    }
  }
