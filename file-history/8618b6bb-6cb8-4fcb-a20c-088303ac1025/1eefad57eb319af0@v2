namespace Firstronic.Areas.Engineering.Controllers
{
  public class CustomerController : BaseSecurityController
  {
    private readonly DataContext db;
    public CustomerController()
    {
      db = new DataContext();
      db.Configuration.UseDatabaseNullSemantics = true;
    }
    public ActionResult Index()
    {
      var model = db.Database.SqlQuery<tbl_COMMON_CUSTOMER_FULL>(@"
        SELECT cc.*, cf.Facility_Name
        FROM COMMON_CUSTOMER cc
        LEFT OUTER JOIN Common_Facilities cf ON cc.Facility_Key = cf.Facility_Key
        ORDER BY cc.Name
      ").ToArray().ToList().AsQueryable();
      return View(model);
    }
    [Authorize(Roles = "BF Administrator,BF Part Edit")]
    public ActionResult Create()
    {
      var getNextIdResult = Firstronic.Framework.Queries.GetIntFromQuery(@"
            SELECT ISNULL(MAX(Customer_No), 0) + 1 FROM COMMON_CUSTOMER
          ", new SqlParameter[] { });

      int nextCustomer_No = Convert.ToInt32(getNextIdResult);

      var model = new tbl_COMMON_CUSTOMER_FULL();
      model.FacilityList = Framework.Functions.Dropdowns.GetFirstronicFacilitiesList(null);
      model.Customer_No = nextCustomer_No;

      return View(model);
    }
    [HttpPost]
    [ValidateAntiForgeryToken]
    [Authorize(Roles = "BF Administrator,BF Part Edit")]
    [MultipleButtonAction(Name = "action", Argument = "Create")]
    public ActionResult Create(tbl_COMMON_CUSTOMER_FULL model)
    {
      if (ModelState.IsValid)
      {
        try
        {



          SqlParameter[] parameters = new SqlParameter[]{
            new SqlParameter("@Customer_No", SqlDbType.Int){ Value = model.Customer_No},
            new SqlParameter("@Facility_Key", SqlDbType.Int){ Value = (object)model.Facility_Key ?? DBNull.Value },
            new SqlParameter("@Customer_Code", SqlDbType.VarChar, 35){ Value = (object)model.Customer_Code ?? DBNull.Value },
            new SqlParameter("@CustomerName", SqlDbType.VarChar, 35){ Value = (object)model.Customer_Code ?? DBNull.Value },
            new SqlParameter("@Name", SqlDbType.VarChar, 150){ Value = model.Name },
            new SqlParameter("@Customer_Status", SqlDbType.VarChar, 50){ Value = (object)model.Customer_Status ?? DBNull.Value },
            new SqlParameter("@Customer_Type", SqlDbType.VarChar, 60){ Value = (object)model.Customer_Type ?? DBNull.Value },
            new SqlParameter("@Contact_Note", SqlDbType.VarChar, 50){ Value = (object)model.Contact_Note ?? DBNull.Value },
            new SqlParameter("@Phone", SqlDbType.VarChar, 50){ Value = (object)model.Phone ?? DBNull.Value },
            new SqlParameter("@Fax", SqlDbType.VarChar, 50){ Value = (object)model.Fax ?? DBNull.Value },
            new SqlParameter("@Email", SqlDbType.VarChar, 50){ Value = (object)model.Email ?? DBNull.Value },
            new SqlParameter("@Web_Address", SqlDbType.VarChar, 100){ Value = (object)model.Web_Address ?? DBNull.Value },
            new SqlParameter("@Assigned_To", SqlDbType.Int){ Value = (object)model.Assigned_To ?? DBNull.Value },
            new SqlParameter("@Terms", SqlDbType.VarChar, 75){ Value = (object)model.Terms ?? DBNull.Value },
            new SqlParameter("@Customer_Supplier_Code", SqlDbType.VarChar, 25){ Value = (object)model.Customer_Supplier_Code ?? DBNull.Value },
            new SqlParameter("@Business_Type", SqlDbType.VarChar, 50){ Value = (object)model.Business_Type ?? DBNull.Value },
            new SqlParameter("@Products_And_Markets", SqlDbType.VarChar, 500){ Value = (object)model.Products_And_Markets ?? DBNull.Value },
            new SqlParameter("@Tax_ID_No", SqlDbType.VarChar, 50){ Value = (object)model.Tax_ID_No ?? DBNull.Value },
            new SqlParameter("@Payment_Method", SqlDbType.VarChar, 50){ Value = (object)model.Payment_Method ?? DBNull.Value },
            new SqlParameter("@Customer_Since", SqlDbType.SmallDateTime){ Value = (object)model.Customer_Since ?? DBNull.Value }
          };
          var result = Firstronic.Framework.Queries.ExecuteQuery(@"
            INSERT INTO COMMON_CUSTOMER
            (Customer_No,Facility_Key, Customer_Code, Name, Customer_Status, Customer_Type,
             Contact_Note, Phone, Fax, Email, Web_Address, Assigned_To, Terms,
             Customer_Supplier_Code, Business_Type, Products_And_Markets,
             Tax_ID_No, Payment_Method, Customer_Since, Add_Date,CustomerName)
            VALUES
            (@Customer_No,@Facility_Key, @Customer_Code, @Name, @Customer_Status, @Customer_Type,
             @Contact_Note, @Phone, @Fax, @Email, @Web_Address, @Assigned_To, @Terms,
             @Customer_Supplier_Code, @Business_Type, @Products_And_Markets,
             @Tax_ID_No, @Payment_Method, @Customer_Since, GETDATE(),@CustomerName)
          ", parameters);
          if (result > 0)
          {
            this.NotifySuccess("Customer created successfully.");
            return RedirectToAction("Index");
          }
          else
          {
            this.NotifyError("Failed to save customer. Please try again.");
          }
        }
        catch (Exception ex)
        {
          this.NotifyError("Error: " + ex.Message);
          ModelState.AddModelError("", "Database error: " + ex.Message);
        }
      }

      // Repopulate dropdown when validation fails or save fails
      model.FacilityList = Framework.Functions.Dropdowns.GetFirstronicFacilitiesList(model.Facility_Key);
      return View(model);
    }
    [Authorize(Roles = "BF Administrator,BF Part Edit")]
    public ActionResult Edit(int id)
    {
      SqlParameter[] parameters = new SqlParameter[]{ new SqlParameter("@Id", SqlDbType.Int){ Value = id } };
      var model = db.Database.SqlQuery<tbl_COMMON_CUSTOMER_FULL>(@"
        SELECT CC.Customer_No,CC.Facility_Key, CC.Customer_Code, CC.Name, CC.Customer_Status, CC.Customer_Type,
             CC.Contact_Note, CC.Phone, CC.Fax, CC.Email, CC.Web_Address, CC.Assigned_To, CC.Terms,
             CC.Customer_Supplier_Code, CC.Business_Type, CC.Products_And_Markets,
             CC.Tax_ID_No, CC.Payment_Method, CC.Customer_Since, CC.Add_Date,CC.CustomerName, cf.Facility_Name
        FROM COMMON_CUSTOMER cc
        LEFT OUTER JOIN Common_Facilities cf ON cc.Facility_Key = cf.Facility_Key
        WHERE cc.Customer_No = @Id
      ", parameters).FirstOrDefault();
      if (model == null)
      {
        this.NotifyError("Customer not found.");
        return RedirectToAction("Index");
      }
      model.FacilityList = Framework.Functions.Dropdowns.GetFirstronicFacilitiesList(null);
      return View(model);
    }

