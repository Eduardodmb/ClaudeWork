        Customer_No = model0.Customer_No,
        Packout_Validation = model0.Packout_Validation,
        CFT_ID = model0.CFT_ID
      };
      return View(model);//
    }


    // POST EDIT
    [HttpPost]
    [ValidateAntiForgeryToken]
    [MultipleButtonAction(Name = "action", Argument = "Edit")]
    public ActionResult Edit(tbl_CS_idt_external_customers model)
    {
      if (ModelState.IsValid)
      {
        var id = model.CustomerID;
        SqlParameter[] parameters = new SqlParameter[]{
          new SqlParameter("@Id",SqlDbType.Int){Value = model.CustomerID},
        };

        var record = Framework.Functions.Utilies.ConvertTo<tbl_CS_idt_external_customers>(Firstronic.Framework.Queries.GetDatatableFromQuery("SELECT *   FROM CS_idt_external_customers WHERE CustomerID=@Id ", parameters)).FirstOrDefault();

        if (record is null)
        {
          this.NotifyError("Record not found.");
          return RedirectToAction("Index");
        }

        SqlParameter[] updateParameters = new SqlParameter[]{
          new SqlParameter("@CustomerID",SqlDbType.Int){Value = model.CustomerID},
          new SqlParameter("@CustomerName",SqlDbType.VarChar){Value =(model.CustomerName ?? "").ToString()},
          new SqlParameter("@PVS_DB",SqlDbType.VarChar){Value =(model.PVS_DB ?? "").ToString()},
          new SqlParameter("@PVS_NAME",SqlDbType.VarChar){Value =(model.PVS_NAME ?? "").ToString()},
          new SqlParameter("@Customer_No",SqlDbType.Int){Value =model.Customer_No},
          new SqlParameter("@Facility_Key",SqlDbType.Int){Value =model.Facility_Key},
          new SqlParameter("@Packout_Validation",SqlDbType.Bit){Value =model.Packout_Validation},
          new SqlParameter("@CFT_ID",SqlDbType.Int){Value =model.CFT_ID},
          new SqlParameter("@IsVisible",SqlDbType.Bit){Value =model.IsVisible},
        };

        var result = Firstronic.Framework.Queries.ExecuteQuery("UPDATE CS_idt_external_customers SET " +
                    "CustomerName = @CustomerName," +
                    "PVS_DB = @PVS_DB," +
                    "PVS_NAME = @PVS_NAME," +
                    "Customer_No = @Customer_No," +
                    "Facility_Key = @Facility_Key," +
                    "Packout_Validation = @Packout_Validation," +
                    "CFT_ID = @CFT_ID," +
                    "IsVisible = @IsVisible WHERE CustomerID = @CustomerID", updateParameters);

        if (result > 0)
        {
          this.NotifySuccess("Successfully saved.");
        }
        else if (result == 0)
          this.NotifyError("Record can not save!");
        else
          this.NotifyError("Error in database.");

        return RedirectToAction("Edit", new { id = record.CustomerID });
      }

      return View(model);
    }


    // POST DELETE
    [HttpPost]
    [ValidateAntiForgeryToken]
    [MultipleButtonAction(Name = "action", Argument = "Delete")]
    public ActionResult Delete(tbl_CS_idt_external_customers model)
    {
      if (ModelState.IsValid)
      {
        SqlParameter[] parameters = new SqlParameter[]{
          new SqlParameter("@Id",SqlDbType.Int){Value = model.CustomerID},
        };

        var record = Framework.Functions.Utilies.ConvertTo<tbl_CS_idt_external_customers>(Firstronic.Framework.Queries.GetDatatableFromQuery("SELECT *   FROM CS_idt_external_customers WHERE CustomerID=@Id ", parameters)).FirstOrDefault();

        if (record is null)
        {
          this.NotifyError("Record not found.");
          return RedirectToAction("Index");
        }

        SqlParameter[] delParameters = new SqlParameter[]{
          new SqlParameter("@Id",SqlDbType.Int){Value = model.CustomerID},
        };

        var result = Firstronic.Framework.Queries.ExecuteQuery("DELETE FROM CS_idt_external_customers " +
           " WHERE CustomerID=@Id ", delParameters);

        if (result > 0)
          this.NotifySuccess("Successfully saved.");
        else if (result == 0)
          this.NotifyError("Record can not save!");
        else
          this.NotifyError("Error in database.");

        return RedirectToAction("Index");
      }

      return View(model);
    }

  }
