using Firstronic.Core.Entities.App.First;
using Firstronic.Framework.Data;
using Firstronic.Framework.Attributes;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Web;
using System.Web.Mvc;
using System.Data.SqlClient;
using System.Data;

namespace Firstronic.Areas.Manage.Controllers
{
  [Authorize(Roles = "BF Administrator")]
  public class CustomersController : BaseSecurityController
  {
    #region Fields
    private readonly DataContext db;
    private readonly DataContext db2;
    #endregion Fields
    #region Ctor
    public CustomersController()
    {
      db = new DataContext();
      db2 = new DataContext();
    }
    #endregion Ctor

    public ActionResult Index()
    {
      var model = db.Database.SqlQuery<tbl_CS_idt_external_customers>($@"SELECT [CustomerID] ,[CustomerName] ,[PVS_DB] ,[PVS_NAME] ,[Customer_No] ,[Packout_Validation] ,[CFT_ID] FROM  [CS_idt_external_customers]").ToArray().ToList().AsQueryable();

      return View(model);
    }


    public ActionResult Create()
    {
      var model = new tbl_CS_idt_external_customers();
      var FirstronicFacilitiesList = new List<SelectListItem>();
      FirstronicFacilitiesList = Framework.Functions.Dropdowns.GetFirstronicFacilitiesList(null);
      model.FacilityList = FirstronicFacilitiesList;

      return View(model);
    }

    [HttpPost]
    [ValidateInput(false)]
    [ValidateAntiForgeryToken]
    [MultipleButtonAction(Name = "action", Argument = "Create")]
    public ActionResult Create(tbl_CS_idt_external_customers model)
    {
      if (ModelState.IsValid)
      {
        SqlParameter[] parameters = new SqlParameter[]{
          new SqlParameter("@CustomerName",SqlDbType.VarChar){Value =(model.CustomerName ?? "").ToString()},
          new SqlParameter("@PVS_DB",SqlDbType.VarChar){Value =(model.PVS_DB ?? "").ToString()},
          new SqlParameter("@PVS_NAME",SqlDbType.VarChar){Value =(model.PVS_NAME ?? "").ToString()},         
          new SqlParameter("@Customer_No",SqlDbType.Int){Value =model.Customer_No},
          new SqlParameter("@Facility_Key",SqlDbType.Int){Value =model.Facility_Key},
          new SqlParameter("@Packout_Validation",SqlDbType.Bit){Value =model.Packout_Validation},
          new SqlParameter("@CFT_ID",SqlDbType.Int){Value =model.CFT_ID},
          new SqlParameter("@IsVisible",SqlDbType.Bit){Value =model.IsVisible}
        };

        var result = Firstronic.Framework.Queries.InsertQuery($@"INSERT INTO [dbo].[CS_idt_external_customers]
                   (CustomerName,
					PVS_DB,
					PVS_NAME,
					Customer_No,
					Facility_Key,
					Packout_Validation,
					CFT_ID,
					IsVisible)
					VALUES
                   (@CustomerName,
					@PVS_DB,
					@PVS_NAME,
					@Customer_No,
					@Facility_Key,
					@Packout_Validation,
					@CFT_ID,
					@IsVisible)", parameters );

        if (result > 0)
        {
          this.NotifySuccess("Successfully saved.");
          return RedirectToAction("Edit", new { Id = result });
        }
        else if (result == 0)
        {
          this.NotifyError("Record can not save!");
          return RedirectToAction("Index");
        }
        else
        {
          this.NotifyError("Error in database.");
          return RedirectToAction("Index");
        }
      }

      return View(model);
    }

    public ActionResult Edit(string id)
    {

      SqlParameter[] parameters = new SqlParameter[]{
        new SqlParameter("@Id",SqlDbType.Int){Value = id},
      };

      var model0 = Framework.Functions.Utilies.ConvertTo<tbl_CS_idt_external_customers>(Firstronic.Framework.Queries.GetDatatableFromQuery("SELECT *   FROM CS_idt_external_customers WHERE CustomerID=@Id ", parameters)).FirstOrDefault();

      if (model0 == null)
      {
        this.NotifyError("Not found.");
