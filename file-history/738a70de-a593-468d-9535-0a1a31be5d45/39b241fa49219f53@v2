    [Display(Name = "Default Location")]
    [MaxLength(50)]
    public string Default_Location { get; set; }

    [Display(Name = "Receiving Location")]
    [MaxLength(50)]
    public string Receiving_Location { get; set; }

    [Display(Name = "Shipping Location")]
    [MaxLength(50)]
