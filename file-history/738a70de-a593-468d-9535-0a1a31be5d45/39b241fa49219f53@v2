  public class tbl_Common_Building : BaseEntity
  {
    [Display(Name = "Building Key")]
    public int? Building_Key { get; set; }

    [Display(Name = "Building Code")]
    [MaxLength(100)]
    public string Building_Code { get; set; }

    [Display(Name = "Building Name")]
    [MaxLength(50)]
